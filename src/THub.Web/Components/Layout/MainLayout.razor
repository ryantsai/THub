@inherits LayoutComponentBase
@using System.Globalization
@inject IHostEnvironment HostEnvironment
@inject NavigationManager Navigation

<div class="app-shell">
    <aside class="sidebar">
        <a class="brand" href="/" aria-label='@Localizer["THub home"]'>
            <span class="brand-mark"><span></span><span></span><span></span></span>
            <span class="brand-copy"><strong>@Localizer["THub"]</strong><small>@Localizer["DATA OPERATIONS"]</small></span>
        </a>

        <nav class="primary-nav" aria-label='@Localizer["Primary navigation"]'>
            <span class="nav-section">@Localizer["Build and run"]</span>
            <NavLink href="/" Match="NavLinkMatch.All"><RadzenIcon Icon="home" />@Localizer["Home"]</NavLink>
            <NavLink href="/workflows"><RadzenIcon Icon="account_tree" />@Localizer["Workflows"]</NavLink>
            <AuthorizeView Policy="@Permissions.ConnectionView">
                <NavLink href="/connections"><RadzenIcon Icon="database" />@Localizer["Data connections"]</NavLink>
            </AuthorizeView>
            <NavLink href="/runs"><RadzenIcon Icon="play_circle" />@Localizer["Runs"]</NavLink>
            <AuthorizeView Policy="@Permissions.ScheduleManage">
                <NavLink href="/schedules"><RadzenIcon Icon="schedule" />@Localizer["Schedules"]</NavLink>
            </AuthorizeView>

            <span class="nav-section">@Localizer["Share and monitor"]</span>
            <NavLink href="/published-data"><RadzenIcon Icon="table_view" />@Localizer["Data tables"]</NavLink>
            <AuthorizeView Policy="@Permissions.PublicationManage">
                <NavLink href="/publications"><RadzenIcon Icon="api" />@Localizer["Data sharing"]</NavLink>
            </AuthorizeView>
            <AuthorizeView Policy="@Permissions.Administration">
                <NavLink href="/alerts/email"><RadzenIcon Icon="notifications_active" />@Localizer["Alerts"]</NavLink>
            </AuthorizeView>

            <AuthorizeView Policy="@Permissions.Administration">
                <span class="nav-section">@Localizer["Administration"]</span>
                <NavLink href="/trusted-actions"><RadzenIcon Icon="verified_user" />@Localizer["Trusted actions"]</NavLink>
            </AuthorizeView>
            <AuthorizeView Policy="@Permissions.AuditView">
                <NavLink href="/audit"><RadzenIcon Icon="policy" />@Localizer["Audit log"]</NavLink>
            </AuthorizeView>
        </nav>

        <div class="sidebar-foot">
            <AuthorizeView Policy="@Permissions.SecurityManage">
                <NavLink class="settings-link" href="/settings"><RadzenIcon Icon="settings" />@Localizer["Settings"]</NavLink>
            </AuthorizeView>
        </div>
    </aside>

    <main class="main-area">
        <header class="topbar">
            <div class="environment-pill"><span></span>@HostEnvironment.EnvironmentName</div>
            <div class="topbar-actions">
                <label class="language-switcher">
                    <span class="visually-hidden">@Localizer["Language"]</span>
                    <RadzenIcon Icon="language" />
                    <select aria-label='@Localizer["Language"]' value="@CurrentCulture" @onchange="ChangeCulture">
                        <option value="en">@Localizer["English"]</option>
                        <option value="zh-TW">繁體中文（台灣）</option>
                    </select>
                </label>
                <AuthorizeView>
                    <Authorized Context="authentication">
                        <div class="identity">
                            <div class="avatar">@Initials(authentication.User.Identity?.Name)</div>
                            <div><strong>@DisplayName(authentication.User.Identity?.Name)</strong><small>@Localizer["Signed in"]</small></div>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <section class="page-body">
            @Body
        </section>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @Localizer["THub hit an unexpected error."]
    <a href="." class="reload">@Localizer["Reload"]</a>
    <span class="dismiss">×</span>
</div>

@code {
    private string CurrentCulture =>
        CultureInfo.CurrentUICulture.Name.StartsWith("zh", StringComparison.OrdinalIgnoreCase)
            ? "zh-TW"
            : "en";

    private void ChangeCulture(ChangeEventArgs eventArgs)
    {
        var culture = string.Equals(eventArgs.Value?.ToString(), "zh-TW", StringComparison.Ordinal)
            ? "zh-TW"
            : "en";
        var currentPath = new Uri(Navigation.Uri).PathAndQuery;
        Navigation.NavigateTo(
            $"/culture/set?culture={Uri.EscapeDataString(culture)}&redirectUri={Uri.EscapeDataString(currentPath)}",
            forceLoad: true);
    }

    private static string DisplayName(string? identityName)
    {
        var value = string.IsNullOrWhiteSpace(identityName) ? "Windows user" : identityName;
        return value.Contains('\\') ? value[(value.LastIndexOf('\\') + 1)..] : value;
    }

    private static string Initials(string? identityName)
    {
        var name = DisplayName(identityName).Replace('.', ' ').Replace('_', ' ');
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }
}

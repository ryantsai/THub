@inherits LayoutComponentBase
@inject IHostEnvironment HostEnvironment

<div class="app-shell">
    <aside class="sidebar">
        <a class="brand" href="/" aria-label="THub home">
            <span class="brand-mark"><span></span><span></span><span></span></span>
            <span class="brand-copy"><strong>THub</strong><small>DATA OPERATIONS</small></span>
        </a>

        <nav class="primary-nav" aria-label="Primary navigation">
            <span class="nav-section">Build and run</span>
            <NavLink href="/" Match="NavLinkMatch.All"><RadzenIcon Icon="home" />Home</NavLink>
            <NavLink href="/workflows"><RadzenIcon Icon="account_tree" />Workflows</NavLink>
            <AuthorizeView Policy="@Permissions.ConnectionView">
                <NavLink href="/connections"><RadzenIcon Icon="database" />Data connections</NavLink>
            </AuthorizeView>
            <NavLink href="/runs"><RadzenIcon Icon="play_circle" />Runs</NavLink>
            <AuthorizeView Policy="@Permissions.ScheduleManage">
                <NavLink href="/schedules"><RadzenIcon Icon="schedule" />Schedules</NavLink>
            </AuthorizeView>

            <span class="nav-section">Share and monitor</span>
            <NavLink href="/published-data"><RadzenIcon Icon="table_view" />Data tables</NavLink>
            <AuthorizeView Policy="@Permissions.PublicationManage">
                <NavLink href="/publications"><RadzenIcon Icon="api" />Data sharing</NavLink>
            </AuthorizeView>
            <AuthorizeView Policy="@Permissions.Administration">
                <NavLink href="/alerts/email"><RadzenIcon Icon="notifications_active" />Alerts</NavLink>
            </AuthorizeView>

            <AuthorizeView Policy="@Permissions.Administration">
                <span class="nav-section">Administration</span>
                <NavLink href="/trusted-actions"><RadzenIcon Icon="verified_user" />Trusted actions</NavLink>
            </AuthorizeView>
            <AuthorizeView Policy="@Permissions.AuditView">
                <NavLink href="/audit"><RadzenIcon Icon="policy" />Audit log</NavLink>
            </AuthorizeView>
        </nav>

        <div class="sidebar-foot">
            <AuthorizeView Policy="@Permissions.SecurityManage">
                <NavLink class="settings-link" href="/settings"><RadzenIcon Icon="settings" />Settings</NavLink>
            </AuthorizeView>
        </div>
    </aside>

    <main class="main-area">
        <header class="topbar">
            <div class="environment-pill"><span></span>@HostEnvironment.EnvironmentName</div>
            <div class="topbar-actions">
                <AuthorizeView>
                    <Authorized Context="authentication">
                        <div class="identity">
                            <div class="avatar">@Initials(authentication.User.Identity?.Name)</div>
                            <div><strong>@DisplayName(authentication.User.Identity?.Name)</strong><small>Signed in</small></div>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <section class="page-body">
            @Body
        </section>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    THub hit an unexpected error.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">×</span>
</div>

@code {
    private static string DisplayName(string? identityName)
    {
        var value = string.IsNullOrWhiteSpace(identityName) ? "Windows user" : identityName;
        return value.Contains('\\') ? value[(value.LastIndexOf('\\') + 1)..] : value;
    }

    private static string Initials(string? identityName)
    {
        var name = DisplayName(identityName).Replace('.', ' ').Replace('_', ' ');
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }
}

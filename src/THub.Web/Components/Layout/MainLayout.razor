@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar">
        <a class="brand" href="/" aria-label="THub home">
            <span class="brand-mark"><span></span><span></span><span></span></span>
            <span class="brand-copy"><strong>THub</strong><small>DATA OPERATIONS</small></span>
        </a>

        <nav class="primary-nav" aria-label="Primary navigation">
            <span class="nav-section">Workspace</span>
            <NavLink href="/" Match="NavLinkMatch.All"><RadzenIcon Icon="space_dashboard" />Overview</NavLink>
            <NavLink href="/workflows"><RadzenIcon Icon="account_tree" />Workflows <span class="nav-count">12</span></NavLink>
            <NavLink href="/designer"><RadzenIcon Icon="polyline" />Designer</NavLink>
            <NavLink href="/runs"><RadzenIcon Icon="play_circle" />Runs <span class="status-dot"></span></NavLink>

            <span class="nav-section">Data plane</span>
            <AuthorizeView Policy="@Permissions.ConnectionManage">
                <NavLink href="/connections"><RadzenIcon Icon="database" />Connections</NavLink>
            </AuthorizeView>
            <NavLink href="/schedules"><RadzenIcon Icon="schedule" />Schedules</NavLink>
            <AuthorizeView Policy="@Permissions.PublicationManage">
                <NavLink href="/publications"><RadzenIcon Icon="api" />Publications</NavLink>
            </AuthorizeView>
        </nav>

        <div class="sidebar-foot">
            <div class="worker-status">
                <span class="pulse"></span>
                <div><strong>Worker online</strong><small>Heartbeat 8s ago</small></div>
                <span class="worker-version">v0.1</span>
            </div>
            <AuthorizeView Policy="@Permissions.Administration">
                <NavLink class="settings-link" href="/settings"><RadzenIcon Icon="settings" />Settings</NavLink>
            </AuthorizeView>
        </div>
    </aside>

    <main class="main-area">
        <header class="topbar">
            <div class="environment-pill"><span></span>Development</div>
            <div class="topbar-actions">
                <button class="command-search" type="button"><RadzenIcon Icon="search" />Search anything <kbd>Ctrl K</kbd></button>
                <button class="icon-action" type="button" aria-label="Notifications"><RadzenIcon Icon="notifications_none" /><span></span></button>
                <AuthorizeView>
                    <Authorized Context="authentication">
                        <div class="identity">
                            <div class="avatar">@Initials(authentication.User.Identity?.Name)</div>
                            <div><strong>@DisplayName(authentication.User.Identity?.Name)</strong><small>Windows account</small></div>
                            <RadzenIcon Icon="expand_more" />
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <section class="page-body">
            @Body
        </section>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    THub hit an unexpected error.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">×</span>
</div>

@code {
    private static string DisplayName(string? identityName)
    {
        var value = string.IsNullOrWhiteSpace(identityName) ? "Windows user" : identityName;
        return value.Contains('\\') ? value[(value.LastIndexOf('\\') + 1)..] : value;
    }

    private static string Initials(string? identityName)
    {
        var name = DisplayName(identityName).Replace('.', ' ').Replace('_', ' ');
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }
}


@page "/connections"
@attribute [Authorize]
@implements IDisposable
@using THub.Application.Connections
@using THub.Domain.Connections
@using THub.Domain.Security
@inject ConnectionManagementService ConnectionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NotificationService Notifications
@inject TimeProvider TimeProvider
@inject AccessControlEvaluator AccessControl

<PageTitle>Connections · THub</PageTitle>

<div class="page-heading">
    <div>
        <div class="eyebrow">Data plane</div>
        <h1>Connections</h1>
        <p>Approved database, FTP/FTPS, and bounded local file connections.</p>
    </div>
    <div class="heading-actions">
        <RadzenButton Text="New connection" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@NewConnection" Disabled="@(Busy || !CanCreate)" />
        <RadzenButton Text="Refresh" Icon="refresh" ButtonStyle="ButtonStyle.Light" Click="@LoadAsync" Disabled="@Busy" />
    </div>
</div>

@if (Loading)
{
    <div class="page-state"><RadzenProgressBar Mode="ProgressBarMode.Indeterminate" /><p>Loading connections…</p></div>
}
else if (LoadError is not null)
{
    <div class="page-state error"><RadzenIcon Icon="error_outline" /><p>@LoadError</p><button type="button" @onclick="LoadAsync">Try again</button></div>
}
else
{
    <div class="connections-layout">
        <section class="resource-grid" aria-label="Configured connections">
            @if (Items.Count == 0)
            {
                <div class="page-state empty-card"><RadzenIcon Icon="cable" /><h3>No connections yet</h3><p>Add an approved source before configuring workflow nodes or publications.</p></div>
            }
            @foreach (var item in Items)
            {
                <article class="resource-card @(Edit.Id == item.Id ? "selected" : null)">
                    <span class="resource-logo @(item.Kind == ConnectionKind.SqlServer ? "sql" : "files")"><RadzenIcon Icon="@KindIcon(item.Kind)" /></span>
                    <div><h2>@item.Name</h2><p>@KindLabel(item.Kind)</p></div>
                    <span class="status-chip @(item.IsEnabled ? null : "draft")">@(item.IsEnabled ? "Enabled" : "Disabled")</span>
                    <dl><dt>Connector</dt><dd>@item.Kind</dd><dt>Updated</dt><dd>@item.UpdatedAtUtc.ToLocalTime().ToString("g")</dd></dl>
                    @if (CanManage.Contains(item.Id))
                    {
                        <button type="button" @onclick="() => EditConnectionAsync(item.Id)">Manage connection →</button>
                    }
                </article>
            }
        </section>

        @if (ShowEditor)
        {
            <section class="panel connection-editor" aria-label="Connection editor">
                <div class="panel-head"><div><h2>@(Edit.Id is null ? "New connection" : "Edit connection")</h2><p>Credentials are encrypted before they are stored in the THub control plane.</p></div><button class="close-editor" type="button" title="Close" @onclick="CloseEditor">×</button></div>
                <div class="connection-form">
                    <label><span>Name</span><input maxlength="200" @bind="Edit.Name" disabled="@Busy" /></label>
                    <label><span>Connector</span>
                        <select @bind="Edit.Kind" disabled="@(Busy || Edit.Id is not null)">
                            <option value="@ConnectionKind.SqlServer">SQL Server</option>
                            <option value="@ConnectionKind.MySql">MySQL</option>
                            <option value="@ConnectionKind.PostgreSql">PostgreSQL</option>
                            <option value="@ConnectionKind.Oracle">Oracle</option>
                            <option value="@ConnectionKind.Ftp">FTP / FTPS</option>
                            <option value="@ConnectionKind.CsvFile">CSV files</option>
                            <option value="@ConnectionKind.ExcelFile">Excel workbooks</option>
                        </select>
                    </label>

                    @if (IsDatabase(Edit.Kind))
                    {
                        <label><span>Host / server</span><input placeholder="db01.contoso.local" maxlength="253" @bind="Edit.Server" disabled="@Busy" /></label>
                        @if (Edit.Kind != ConnectionKind.SqlServer)
                        {
                            <label><span>Port</span><input type="number" min="1" max="65535" @bind="Edit.Port" disabled="@Busy" /></label>
                        }
                        <label><span>@(Edit.Kind == ConnectionKind.Oracle ? "Service name" : "Database")</span><input placeholder="Warehouse" maxlength="128" @bind="Edit.Database" disabled="@Busy" /></label>
                        <label><span>Authentication</span>
                            <select @bind="Edit.AuthenticationKind" disabled="@(Busy || Edit.Kind != ConnectionKind.SqlServer)">
                                <option value="@DatabaseAuthenticationKind.Integrated">Windows integrated</option>
                                <option value="@DatabaseAuthenticationKind.UserPassword">Database username/password</option>
                            </select>
                        </label>
                        @if (Edit.AuthenticationKind == DatabaseAuthenticationKind.UserPassword)
                        {
                            <label><span>Credential reference</span><input placeholder="warehouse_writer" maxlength="200" autocomplete="off" spellcheck="false" @bind="Edit.CredentialSecretReference" disabled="@Busy" /><small>Stable identifier used by workflows and connection metadata.</small></label>
                            <label><span>Database username</span><input maxlength="256" autocomplete="off" spellcheck="false" @bind="Edit.CredentialUserName" disabled="@Busy" /><small>@CredentialInputHint(Edit)</small></label>
                            <label><span>Database password</span><input type="password" maxlength="4096" autocomplete="new-password" @bind="Edit.CredentialPassword" disabled="@Busy" /></label>
                        }
                        <label class="check"><input type="checkbox" @bind="Edit.Encrypt" disabled="@Busy" /><span>Require transport encryption</span></label>
                        <label class="check"><input type="checkbox" @bind="Edit.TrustServerCertificate" disabled="@Busy" /><span>Trust server certificate (development only)</span></label>
                        <label><span>Connect timeout (seconds)</span><input type="number" min="1" max="60" @bind="Edit.ConnectTimeoutSeconds" disabled="@Busy" /></label>
                        <label><span>Command timeout (seconds)</span><input type="number" min="1" max="300" @bind="Edit.CommandTimeoutSeconds" disabled="@Busy" /></label>
                        <label><span>Maximum batch rows</span><input type="number" min="1" max="10000" @bind="Edit.MaximumBatchRows" disabled="@Busy" /></label>
                    }
                    else if (Edit.Kind == ConnectionKind.Ftp)
                    {
                        <label><span>FTP host</span><input placeholder="ftp.contoso.local" maxlength="253" @bind="Edit.Server" disabled="@Busy" /></label>
                        <label><span>Port</span><input type="number" min="1" max="65535" @bind="Edit.Port" disabled="@Busy" /></label>
                        <label><span>Transport security</span>
                            <select @bind="Edit.FtpEncryptionMode" disabled="@Busy">
                                <option value="@FtpEncryptionMode.None">Plain FTP (unencrypted)</option>
                                <option value="@FtpEncryptionMode.Explicit">Explicit FTPS</option>
                                <option value="@FtpEncryptionMode.Implicit">Implicit FTPS</option>
                            </select>
                        </label>
                        @if (Edit.FtpEncryptionMode == FtpEncryptionMode.None)
                        {
                            <div class="transport-warning" role="alert"><RadzenIcon Icon="warning_amber" /><span>Plain FTP is unencrypted. The username, password, and file contents are exposed in transit.</span></div>
                        }
                        <label><span>Credential reference</span><input placeholder="ftp_partner" maxlength="200" autocomplete="off" spellcheck="false" @bind="Edit.CredentialSecretReference" disabled="@Busy" /></label>
                        <label><span>FTP username</span><input maxlength="256" autocomplete="off" spellcheck="false" @bind="Edit.CredentialUserName" disabled="@Busy" /><small>@CredentialInputHint(Edit)</small></label>
                        <label><span>FTP password</span><input type="password" maxlength="4096" autocomplete="new-password" @bind="Edit.CredentialPassword" disabled="@Busy" /></label>
                        <label class="check"><input type="checkbox" @bind="Edit.TrustServerCertificate" disabled="@(Busy || Edit.FtpEncryptionMode == FtpEncryptionMode.None)" /><span>Trust server certificate (development only)</span></label>
                        <label><span>Connect timeout (seconds)</span><input type="number" min="1" max="60" @bind="Edit.ConnectTimeoutSeconds" disabled="@Busy" /></label>
                        <label><span>Maximum file size (MiB)</span><input type="number" min="1" max="4096" @bind="Edit.MaximumFileMiB" disabled="@Busy" /></label>
                        <label><span>Maximum rows</span><input type="number" min="1" max="10000000" @bind="Edit.MaximumRows" disabled="@Busy" /></label>
                        <label><span>Maximum columns</span><input type="number" min="1" max="16384" @bind="Edit.MaximumColumns" disabled="@Busy" /></label>
                    }
                    else
                    {
                        <label class="wide"><span>Approved root</span><input placeholder="D:\Data\Inbound" maxlength="1024" @bind="Edit.ApprovedRoot" disabled="@Busy" /></label>
                        <label class="check wide"><input type="checkbox" @bind="Edit.AllowUncRoot" disabled="@Busy" /><span>Administrator approved this UNC root</span></label>
                        <label><span>Maximum file size (MiB)</span><input type="number" min="1" max="4096" @bind="Edit.MaximumFileMiB" disabled="@Busy" /></label>
                        <label><span>Maximum rows</span><input type="number" min="1" max="10000000" @bind="Edit.MaximumRows" disabled="@Busy" /></label>
                        <label><span>Maximum columns</span><input type="number" min="1" max="16384" @bind="Edit.MaximumColumns" disabled="@Busy" /></label>
                    }
                </div>
                @if (FormError is not null)
                {
                    <div class="form-error"><RadzenIcon Icon="error_outline" />@FormError</div>
                }
                @if (ProbeResult is not null)
                {
                    <div class="probe-result @(ProbeResult.IsSuccessful ? "ok" : "failed")"><RadzenIcon Icon="@(ProbeResult.IsSuccessful ? "check_circle" : "warning")" /><div><strong>@ProbeResult.Message</strong><small>@ProbeResult.Elapsed.TotalMilliseconds.ToString("0") ms@(ProbeResult.ServerVersion is null ? string.Empty : $" · SQL {ProbeResult.ServerVersion}")</small></div></div>
                }
                <div class="editor-actions">
                    @if (Edit.Id is not null)
                    {
                        <RadzenButton Text="Test connection" Icon="network_check" ButtonStyle="ButtonStyle.Light" Click="@ProbeAsync" Disabled="@Busy" />
                        <RadzenButton Text="@(Edit.IsEnabled ? "Disable" : "Enable")" Icon="power_settings_new" ButtonStyle="@(Edit.IsEnabled ? ButtonStyle.Danger : ButtonStyle.Success)" Click="@ToggleAsync" Disabled="@Busy" />
                    }
                    <span></span>
                    <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@CloseEditor" Disabled="@Busy" />
                    <RadzenButton Text="Save connection" Icon="save" ButtonStyle="ButtonStyle.Primary" Click="@SaveAsync" Disabled="@Busy" />
                </div>
            </section>
        }
    </div>
}

@code {
    private readonly CancellationTokenSource cancellation = new();
    private IReadOnlyList<ConnectionSummary> Items { get; set; } = [];
    private ConnectionEditModel Edit { get; set; } = ConnectionEditModel.Create();
    private bool ShowEditor { get; set; }
    private bool Loading { get; set; }
    private bool Busy { get; set; }
    private string? LoadError { get; set; }
    private string? FormError { get; set; }
    private ConnectionProbeResult? ProbeResult { get; set; }
    private bool CanCreate { get; set; }
    private HashSet<Guid> CanManage { get; } = [];

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        Loading = true;
        LoadError = null;
        try
        {
            var authentication = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            CanCreate = await AccessControl.HasPermissionAsync(
                authentication.User,
                Permissions.ConnectionManage,
                cancellationToken: cancellation.Token);
            CanManage.Clear();
            var visible = new List<ConnectionSummary>();
            foreach (var connection in await ConnectionService.ListAsync(cancellation.Token))
            {
                var canManage = await AccessControl.HasPermissionAsync(
                    authentication.User,
                    Permissions.ConnectionManage,
                    AccessResourceKind.Connection,
                    connection.Id,
                    cancellation.Token);
                var canView = canManage || await AccessControl.HasPermissionAsync(
                    authentication.User,
                    Permissions.ConnectionView,
                    AccessResourceKind.Connection,
                    connection.Id,
                    cancellation.Token);
                if (canView)
                {
                    visible.Add(connection);
                }

                if (canManage)
                {
                    CanManage.Add(connection.Id);
                }
            }

            Items = visible;
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            LoadError = "Connections are temporarily unavailable.";
        }
        finally
        {
            Loading = false;
        }
    }

    private void NewConnection()
    {
        if (!CanCreate)
        {
            return;
        }

        Edit = ConnectionEditModel.Create();
        FormError = null;
        ProbeResult = null;
        ShowEditor = true;
    }

    private async Task EditConnectionAsync(Guid id)
    {
        if (!CanManage.Contains(id))
        {
            Notify(NotificationSeverity.Error, "You do not have permission to manage this connection.");
            return;
        }

        Busy = true;
        try
        {
            var details = await ConnectionService.GetAsync(id, cancellation.Token);
            if (details is null)
            {
                Notify(NotificationSeverity.Error, "The connection no longer exists.");
                await LoadAsync();
                return;
            }

            Edit = ConnectionEditModel.From(details);
            FormError = null;
            ProbeResult = null;
            ShowEditor = true;
        }
        finally
        {
            Busy = false;
        }
    }

    private async Task SaveAsync()
    {
        if (Edit.Id is Guid existingId ? !CanManage.Contains(existingId) : !CanCreate)
        {
            Notify(NotificationSeverity.Error, "You do not have permission to save this connection.");
            return;
        }

        Busy = true;
        FormError = null;
        ProbeResult = null;
        try
        {
            var configuration = Edit.ToConfiguration();
            ConnectionCommandResult result;
            if (Edit.Id is { } id)
            {
                result = await ConnectionService.UpdateAsync(
                    id,
                    Edit.Name,
                    configuration,
                    Edit.ToCredential(),
                    Edit.UpdatedAtUtc,
                    TimeProvider.GetUtcNow(),
                    cancellation.Token);
            }
            else
            {
                var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                result = await ConnectionService.CreateAsync(
                    Edit.Name,
                    configuration,
                    Edit.ToCredential(),
                    state.User.Identity?.Name ?? "unknown",
                    TimeProvider.GetUtcNow(),
                    cancellation.Token);
            }

            if (result.Status != ConnectionSaveStatus.Saved || result.Connection is null)
            {
                FormError = result.Message ?? "The connection could not be saved.";
                return;
            }

            Edit = ConnectionEditModel.From(result.Connection);
            Notify(NotificationSeverity.Success, "Connection metadata was saved.");
            await LoadAsync();
        }
        catch (ArgumentException exception)
        {
            FormError = exception.Message;
        }
        catch (ConnectionCredentialProtectionException)
        {
            FormError = "Credential encryption is unavailable. Ask an administrator to configure the THub credential master key.";
        }
        catch (OverflowException)
        {
            FormError = "The configured file size is outside the supported range.";
        }
        finally
        {
            Busy = false;
        }
    }

    private async Task ProbeAsync()
    {
        if (Edit.Id is not { } id || !CanManage.Contains(id))
        {
            return;
        }

        Busy = true;
        try
        {
            ProbeResult = await ConnectionService.ProbeAsync(id, cancellation.Token);
        }
        finally
        {
            Busy = false;
        }
    }

    private async Task ToggleAsync()
    {
        if (Edit.Id is not { } id || !CanManage.Contains(id))
        {
            return;
        }

        Busy = true;
        FormError = null;
        try
        {
            var result = await ConnectionService.SetEnabledAsync(
                id,
                !Edit.IsEnabled,
                Edit.UpdatedAtUtc,
                TimeProvider.GetUtcNow(),
                cancellation.Token);
            if (result.Status != ConnectionSaveStatus.Saved || result.Connection is null)
            {
                FormError = result.Message ?? "The connection state could not be changed.";
                return;
            }

            Edit = ConnectionEditModel.From(result.Connection);
            await LoadAsync();
        }
        finally
        {
            Busy = false;
        }
    }

    private void CloseEditor()
    {
        ShowEditor = false;
        FormError = null;
        ProbeResult = null;
    }

    private void Notify(NotificationSeverity severity, string detail) => Notifications.Notify(new NotificationMessage
    {
        Severity = severity,
        Summary = severity == NotificationSeverity.Error ? "Connection failed" : "Connection updated",
        Detail = detail,
        Duration = 5_000
    });

    private static bool IsDatabase(ConnectionKind kind) => kind is ConnectionKind.SqlServer
        or ConnectionKind.MySql or ConnectionKind.PostgreSql or ConnectionKind.Oracle;

    private static string KindIcon(ConnectionKind kind) => IsDatabase(kind) ? "database" : kind == ConnectionKind.Ftp ? "cloud" : "folder";
    private static string CredentialInputHint(ConnectionEditModel edit) =>
        edit.HasStoredCredential
            ? "A credential is stored. Leave both fields blank to keep it, or enter both to rotate it."
            : "Enter both fields to create the encrypted credential.";

    private static string KindLabel(ConnectionKind kind) => kind switch
    {
        ConnectionKind.SqlServer => "SQL Server",
        ConnectionKind.MySql => "MySQL",
        ConnectionKind.PostgreSql => "PostgreSQL",
        ConnectionKind.Oracle => "Oracle Database",
        ConnectionKind.Ftp => "FTP / FTPS remote files",
        ConnectionKind.CsvFile => "Bounded CSV file root",
        ConnectionKind.ExcelFile => "Bounded XLSX/XLSM root",
        _ => kind.ToString()
    };

    public void Dispose()
    {
        cancellation.Cancel();
        cancellation.Dispose();
    }

    private sealed class ConnectionEditModel
    {
        private ConnectionKind kind = ConnectionKind.SqlServer;
        public Guid? Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public ConnectionKind Kind
        {
            get => kind;
            set
            {
                if (kind == value) return;
                kind = value;
                if (Id is not null) return;
                Port = value switch
                {
                    ConnectionKind.MySql => 3306,
                    ConnectionKind.PostgreSql => 5432,
                    ConnectionKind.Oracle => 1521,
                    ConnectionKind.Ftp => 21,
                    _ => Port
                };
                if (value is ConnectionKind.MySql or ConnectionKind.PostgreSql or ConnectionKind.Oracle)
                {
                    AuthenticationKind = DatabaseAuthenticationKind.UserPassword;
                }
            }
        }
        public bool IsEnabled { get; set; } = true;
        public DateTimeOffset UpdatedAtUtc { get; set; }
        public string Server { get; set; } = string.Empty;
        public string Database { get; set; } = string.Empty;
        public int Port { get; set; } = 5432;
        public FtpEncryptionMode FtpEncryptionMode { get; set; } = FtpEncryptionMode.Explicit;
        public DatabaseAuthenticationKind AuthenticationKind { get; set; } = DatabaseAuthenticationKind.Integrated;
        public string CredentialSecretReference { get; set; } = string.Empty;
        public string CredentialUserName { get; set; } = string.Empty;
        public string CredentialPassword { get; set; } = string.Empty;
        public bool HasStoredCredential { get; set; }
        public bool Encrypt { get; set; } = true;
        public bool TrustServerCertificate { get; set; }
        public int ConnectTimeoutSeconds { get; set; } = 15;
        public int CommandTimeoutSeconds { get; set; } = 30;
        public int MaximumBatchRows { get; set; } = 1_000;
        public string ApprovedRoot { get; set; } = string.Empty;
        public bool AllowUncRoot { get; set; }
        public long MaximumFileMiB { get; set; } = 256;
        public int MaximumRows { get; set; } = 1_000_000;
        public int MaximumColumns { get; set; } = 1_024;

        public static ConnectionEditModel Create() => new();

        public static ConnectionEditModel From(ConnectionDetails details)
        {
            var model = new ConnectionEditModel
            {
                Id = details.Id,
                Name = details.Name,
                Kind = details.Kind,
                HasStoredCredential = details.HasStoredCredential,
                IsEnabled = details.IsEnabled,
                UpdatedAtUtc = details.UpdatedAtUtc
            };
            if (details.Configuration is SqlServerConnectionConfiguration sql)
            {
                model.Server = sql.Server;
                model.Database = sql.Database;
                model.AuthenticationKind = sql.Authentication.Kind;
                model.CredentialSecretReference = sql.Authentication.CredentialSecretReference ?? string.Empty;
                model.Encrypt = sql.Encrypt;
                model.TrustServerCertificate = sql.TrustServerCertificate;
                model.ConnectTimeoutSeconds = sql.ConnectTimeoutSeconds;
                model.CommandTimeoutSeconds = sql.CommandTimeoutSeconds;
                model.MaximumBatchRows = sql.MaximumBatchRows;
            }
            else if (details.Configuration is RelationalDatabaseConnectionConfiguration database)
            {
                model.Server = database.Host;
                model.Port = database.Port;
                model.Database = database.Database;
                model.AuthenticationKind = database.Authentication.Kind;
                model.CredentialSecretReference = database.Authentication.CredentialSecretReference ?? string.Empty;
                model.Encrypt = database.Encrypt;
                model.TrustServerCertificate = database.TrustServerCertificate;
                model.ConnectTimeoutSeconds = database.ConnectTimeoutSeconds;
                model.CommandTimeoutSeconds = database.CommandTimeoutSeconds;
                model.MaximumBatchRows = database.MaximumBatchRows;
            }
            else if (details.Configuration is FtpConnectionConfiguration ftp)
            {
                model.Server = ftp.Host;
                model.Port = ftp.Port;
                model.FtpEncryptionMode = ftp.EncryptionMode;
                model.TrustServerCertificate = ftp.TrustServerCertificate;
                model.CredentialSecretReference = ftp.CredentialSecretReference;
                model.ConnectTimeoutSeconds = ftp.ConnectTimeoutSeconds;
                model.MaximumFileMiB = ftp.MaximumFileBytes / (1_024 * 1_024);
                model.MaximumRows = ftp.MaximumRows;
                model.MaximumColumns = ftp.MaximumColumns;
            }
            else if (details.Configuration is FileConnectionConfiguration file)
            {
                model.ApprovedRoot = file.ApprovedRoot;
                model.AllowUncRoot = file.AllowUncRoot;
                model.MaximumFileMiB = file.MaximumFileBytes / (1_024 * 1_024);
                model.MaximumRows = file.MaximumRows;
                model.MaximumColumns = file.MaximumColumns;
            }

            return model;
        }

        public ConnectionCredential? ToCredential()
        {
            var usesCredential = Kind == ConnectionKind.Ftp ||
                IsDatabase(Kind) &&
                AuthenticationKind == DatabaseAuthenticationKind.UserPassword;
            if (!usesCredential)
            {
                return null;
            }

            if (string.IsNullOrWhiteSpace(CredentialUserName) &&
                string.IsNullOrEmpty(CredentialPassword))
            {
                return null;
            }

            if (string.IsNullOrWhiteSpace(CredentialUserName) ||
                string.IsNullOrEmpty(CredentialPassword))
            {
                throw new ArgumentException(
                    "Enter both the credential username and password.");
            }

            return new ConnectionCredential(
                CredentialUserName,
                CredentialPassword);
        }

        public ConnectionConfiguration ToConfiguration() => Kind switch
        {
            ConnectionKind.SqlServer => new SqlServerConnectionConfiguration(
                Server,
                Database,
                Encrypt,
                TrustServerCertificate,
                ConnectTimeoutSeconds,
                CommandTimeoutSeconds,
                MaximumBatchRows,
                new DatabaseAuthenticationConfiguration(
                    AuthenticationKind,
                    AuthenticationKind == DatabaseAuthenticationKind.UserPassword
                        ? CredentialSecretReference
                        : null)),
            ConnectionKind.MySql or ConnectionKind.PostgreSql or ConnectionKind.Oracle =>
                new RelationalDatabaseConnectionConfiguration(
                    Kind,
                    Server,
                    Port,
                    Database,
                    Encrypt,
                    TrustServerCertificate,
                    ConnectTimeoutSeconds,
                    CommandTimeoutSeconds,
                    MaximumBatchRows,
                    new DatabaseAuthenticationConfiguration(
                        DatabaseAuthenticationKind.UserPassword,
                        CredentialSecretReference)),
            ConnectionKind.Ftp => new FtpConnectionConfiguration(
                Server,
                Port,
                FtpEncryptionMode,
                TrustServerCertificate,
                CredentialSecretReference,
                ConnectTimeoutSeconds,
                checked(MaximumFileMiB * 1_024 * 1_024),
                MaximumRows,
                MaximumColumns),
            _ => new FileConnectionConfiguration(
                Kind,
                ApprovedRoot,
                AllowUncRoot,
                checked(MaximumFileMiB * 1_024 * 1_024),
                MaximumRows,
                MaximumColumns)
        };
    }
}

@page "/workflows"
@attribute [Authorize(Policy = Permissions.WorkflowView)]
@implements IDisposable
@using THub.Application.Workflows.Management
@using THub.Domain.Security
@inject WorkflowCatalogService WorkflowCatalog
@inject WorkflowRunService WorkflowRuns
@inject WorkflowPackageService WorkflowPackages
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NotificationService Notifications
@inject DialogService Dialogs
@inject NavigationManager Navigation
@inject AccessControlEvaluator AccessControl
@inject IJSRuntime JS

<PageTitle>Workflows · THub</PageTitle>

<div class="page-heading">
    <div>
        <div class="eyebrow">Workspace</div>
        <h1>Workflows</h1>
        <p>Design, version, publish, and monitor durable data movement.</p>
    </div>
    @if (CanCreate)
    {
        <div class="heading-actions">
            <RadzenButton Text="Import" Icon="upload_file" ButtonStyle="ButtonStyle.Light" Click="@OpenImportPickerAsync" />
            <InputFile id="workflow-package-input" OnChange="@ImportAsync" accept=".json,.thub-workflow.json,application/json" hidden />
            <RadzenButton Text="New workflow" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@NewWorkflow" />
        </div>
    }
</div>

<section class="panel">
    <div class="panel-head">
        <div>
            <h2>All workflows</h2>
            <p>@Summary</p>
        </div>
        <RadzenButton Text="Refresh" Icon="refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@LoadAsync" Disabled="@Loading" />
    </div>

    @if (Loading)
    {
        <div class="page-state"><RadzenProgressBar Mode="ProgressBarMode.Indeterminate" /><p>Loading workflows…</p></div>
    }
    else if (Error is not null)
    {
        <div class="page-state error"><RadzenIcon Icon="error_outline" /><p>@Error</p><button type="button" @onclick="LoadAsync">Try again</button></div>
    }
    else if (Items.Count == 0)
    {
        <div class="page-state"><RadzenIcon Icon="account_tree" /><h3>No workflows yet</h3><p>Create a workflow, connect its steps, validate it, then publish an immutable version.</p></div>
    }
    else
    {
        <div class="table-scroll">
            <table class="activity-table">
                <thead><tr><th>Name</th><th>Status</th><th>Version</th><th>Schedule</th><th>Next run</th><th>Owner</th><th></th></tr></thead>
                <tbody>
                    @foreach (var workflow in Items)
                    {
                        <tr>
                            <td><div class="workflow-name"><span class="mini-flow-icon"><RadzenIcon Icon="account_tree" /></span>@if (CanEdit.Contains(workflow.Id)){<a href="@($"/designer/{workflow.Id}")">@workflow.Name</a>}else{<span>@workflow.Name</span>}</div></td>
                            <td><span class="status-chip @workflow.Status.ToString().ToLowerInvariant()">@workflow.Status</span></td>
                            <td class="muted">Draft r@(workflow.DraftRevision) · @(workflow.PublishedVersionNumber is null ? "not published" : $"v{workflow.PublishedVersionNumber}")</td>
                            <td><code>@(workflow.CronExpression ?? "Manual")</code></td>
                            <td class="muted">@(workflow.NextRunAtUtc?.ToLocalTime().ToString("g") ?? "—")</td>
                            <td class="muted">@workflow.Owner</td>
                            <td class="workflow-actions">
                                @if (CanEdit.Contains(workflow.Id))
                                {
                                    <a href="@($"/designer/{workflow.Id}")" aria-label="Open @workflow.Name">Open</a>
                                }
                                <button type="button" disabled="@Loading" @onclick="() => ExportAsync(workflow.Id)">Export</button>
                                @if (workflow.Status == THub.Domain.Workflows.WorkflowStatus.Published)
                                {
                                    @if (CanExecute.Contains(workflow.Id))
                                    {
                                        <button type="button" disabled="@Loading" @onclick="() => QueueAsync(workflow.Id)">Run now</button>
                                    }
                                }
                                @if (CanDelete.Contains(workflow.Id)
                                    && workflow.Status != THub.Domain.Workflows.WorkflowStatus.Archived)
                                {
                                    <button type="button" disabled="@Loading" @onclick="() => ArchiveAsync(workflow)">Archive</button>
                                    @if (workflow.Status == THub.Domain.Workflows.WorkflowStatus.Draft
                                        && workflow.PublishedVersionNumber is null)
                                    {
                                        <button type="button" disabled="@Loading" @onclick="() => DeleteAsync(workflow)">Delete</button>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@code {
    private readonly CancellationTokenSource cancellation = new();
    private IReadOnlyList<WorkflowListItemDto> Items { get; set; } = [];
    private bool Loading { get; set; }
    private string? Error { get; set; }
    private bool CanCreate { get; set; }
    private HashSet<Guid> CanEdit { get; } = [];
    private HashSet<Guid> CanExecute { get; } = [];
    private HashSet<Guid> CanDelete { get; } = [];

    private string Summary =>
        $"{Items.Count} shown · {Items.Count(item => item.Status == THub.Domain.Workflows.WorkflowStatus.Published)} published · " +
        $"{Items.Count(item => item.Status == THub.Domain.Workflows.WorkflowStatus.Draft)} drafts · " +
        $"{Items.Count(item => item.Status == THub.Domain.Workflows.WorkflowStatus.Paused)} paused";

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        Loading = true;
        Error = null;
        try
        {
            var result = await WorkflowCatalog.ListAsync(
                new WorkflowListRequest(Limit: WorkflowCatalogService.MaximumPageSize),
                cancellation.Token);
            if (result.IsSuccess)
            {
                var authentication = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                CanCreate = await AccessControl.HasPermissionAsync(
                    authentication.User,
                    Permissions.WorkflowCreate,
                    cancellationToken: cancellation.Token);
                CanEdit.Clear();
                CanExecute.Clear();
                CanDelete.Clear();
                var visible = new List<WorkflowListItemDto>();
                foreach (var workflow in result.Value!.Items)
                {
                    if (await AccessControl.HasPermissionAsync(
                            authentication.User,
                            Permissions.WorkflowView,
                            AccessResourceKind.Workflow,
                            workflow.Id,
                            cancellation.Token))
                    {
                        visible.Add(workflow);
                    }

                    if (await AccessControl.HasPermissionAsync(
                            authentication.User,
                            Permissions.WorkflowEdit,
                            AccessResourceKind.Workflow,
                            workflow.Id,
                            cancellation.Token))
                    {
                        CanEdit.Add(workflow.Id);
                    }

                    if (await AccessControl.HasPermissionAsync(
                            authentication.User,
                            Permissions.WorkflowExecute,
                            AccessResourceKind.Workflow,
                            workflow.Id,
                            cancellation.Token))
                    {
                        CanExecute.Add(workflow.Id);
                    }

                    if (await AccessControl.HasPermissionAsync(
                            authentication.User,
                            Permissions.WorkflowDelete,
                            AccessResourceKind.Workflow,
                            workflow.Id,
                            cancellation.Token))
                    {
                        CanDelete.Add(workflow.Id);
                    }
                }

                Items = visible;
            }
            else
            {
                Error = string.Join(" ", result.Issues.Select(issue => issue.Message));
            }
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            Error = "Workflows could not be loaded. Check the control-plane database and try again.";
        }
        finally
        {
            Loading = false;
        }
    }

    private void NewWorkflow() => Navigation.NavigateTo("/designer");

    private async Task OpenImportPickerAsync() =>
        await JS.InvokeVoidAsync("thub.clickElement", "workflow-package-input");

    private async Task ExportAsync(Guid workflowId)
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (!await AccessControl.HasPermissionAsync(
                state.User,
                Permissions.WorkflowView,
                AccessResourceKind.Workflow,
                workflowId,
                cancellation.Token))
        {
            Notifications.Notify(NotificationSeverity.Error, "Not authorized", "Workflow view permission is required.");
            return;
        }

        Loading = true;
        try
        {
            var result = await WorkflowPackages.ExportAsync(workflowId, cancellation.Token);
            if (!result.IsSuccess)
            {
                Notifications.Notify(
                    NotificationSeverity.Error,
                    "Export failed",
                    result.Issues.FirstOrDefault()?.Message ?? "The workflow could not be exported.");
                return;
            }

            await JS.InvokeVoidAsync(
                "thub.downloadTextFile",
                cancellation.Token,
                result.Value!.FileName,
                result.Value.Content);
        }
        finally
        {
            Loading = false;
        }
    }

    private async Task ImportAsync(InputFileChangeEventArgs args)
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (!await AccessControl.HasPermissionAsync(
                state.User,
                Permissions.WorkflowCreate,
                cancellationToken: cancellation.Token))
        {
            Notifications.Notify(NotificationSeverity.Error, "Not authorized", "Workflow create permission is required.");
            return;
        }

        Loading = true;
        try
        {
            var file = args.File;
            var maximumBytes = WorkflowPackageService.MaximumPackageCharacters * 4L;
            await using var stream = file.OpenReadStream(maximumBytes, cancellation.Token);
            using var reader = new StreamReader(stream);
            var packageJson = await reader.ReadToEndAsync(cancellation.Token);
            var result = await WorkflowPackages.ImportAsync(
                packageJson,
                state.User.Identity?.Name ?? "unknown",
                cancellation.Token);
            if (!result.IsSuccess)
            {
                Notifications.Notify(
                    NotificationSeverity.Error,
                    "Import failed",
                    result.Issues.FirstOrDefault()?.Message ?? "The workflow package could not be imported.");
                return;
            }

            var imported = result.Value!;
            Notifications.Notify(new NotificationMessage
            {
                Severity = imported.Warnings.Count == 0
                    ? NotificationSeverity.Success
                    : NotificationSeverity.Warning,
                Summary = "Workflow imported as a draft",
                Detail = imported.Warnings.Count == 0
                    ? "Connection references were resolved."
                    : string.Join(" ", imported.Warnings),
                Duration = 8_000
            });
            Navigation.NavigateTo($"/designer/{imported.Workflow.Id}");
        }
        catch (IOException exception)
        {
            Notifications.Notify(NotificationSeverity.Error, "Import failed", exception.Message);
        }
        finally
        {
            Loading = false;
        }
    }

    private async Task ArchiveAsync(WorkflowListItemDto workflow)
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (!await AccessControl.HasPermissionAsync(
                state.User,
                Permissions.WorkflowDelete,
                AccessResourceKind.Workflow,
                workflow.Id,
                cancellation.Token))
        {
            Notifications.Notify(NotificationSeverity.Error, "Not authorized", "Workflow delete permission is required.");
            return;
        }

        var confirmed = await Dialogs.Confirm(
            $"Archive '{workflow.Name}'? Schedules and manual execution will stop, while versions and run history remain available.",
            "Archive workflow",
            new ConfirmOptions { OkButtonText = "Archive", CancelButtonText = "Cancel" });
        if (confirmed != true)
        {
            return;
        }

        Loading = true;
        try
        {
            var result = await WorkflowCatalog.ArchiveAsync(
                new ArchiveWorkflowCommand(workflow.Id, workflow.DraftRevision),
                cancellation.Token);
            Notifications.Notify(
                result.IsSuccess ? NotificationSeverity.Success : NotificationSeverity.Error,
                result.IsSuccess ? "Workflow archived" : "Archive failed",
                result.IsSuccess
                    ? "Versions and run history were preserved."
                    : result.Issues.FirstOrDefault()?.Message ?? "The workflow could not be archived.");
            if (result.IsSuccess)
            {
                await LoadAsync();
            }
        }
        finally
        {
            Loading = false;
        }
    }

    private async Task DeleteAsync(WorkflowListItemDto workflow)
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (!await AccessControl.HasPermissionAsync(
                state.User,
                Permissions.WorkflowDelete,
                AccessResourceKind.Workflow,
                workflow.Id,
                cancellation.Token))
        {
            Notifications.Notify(NotificationSeverity.Error, "Not authorized", "Workflow delete permission is required.");
            return;
        }

        var confirmed = await Dialogs.Confirm(
            $"Permanently delete the unused draft '{workflow.Name}'? This cannot be undone.",
            "Delete workflow",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });
        if (confirmed != true)
        {
            return;
        }

        Loading = true;
        try
        {
            var result = await WorkflowCatalog.DeleteAsync(
                new DeleteWorkflowCommand(workflow.Id, workflow.DraftRevision),
                cancellation.Token);
            Notifications.Notify(
                result.IsSuccess ? NotificationSeverity.Success : NotificationSeverity.Error,
                result.IsSuccess ? "Draft deleted" : "Delete failed",
                result.IsSuccess
                    ? "The unused draft was permanently removed."
                    : result.Issues.FirstOrDefault()?.Message ?? "The workflow could not be deleted.");
            if (result.IsSuccess)
            {
                await LoadAsync();
            }
        }
        finally
        {
            Loading = false;
        }
    }

    private async Task QueueAsync(Guid workflowId)
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (!await AccessControl.HasPermissionAsync(
                state.User,
                Permissions.WorkflowExecute,
                AccessResourceKind.Workflow,
                workflowId,
                cancellation.Token))
        {
            Notifications.Notify(NotificationSeverity.Error, "Not authorized", "Workflow execution permission is required.");
            return;
        }

        Loading = true;
        try
        {
            var result = await WorkflowRuns.QueueAsync(
                new QueueWorkflowRunCommand(
                    workflowId,
                    state.User.Identity?.Name ?? "unknown"),
                cancellation.Token);
            Notifications.Notify(new NotificationMessage
            {
                Severity = result.IsSuccess ? NotificationSeverity.Success : NotificationSeverity.Error,
                Summary = result.IsSuccess ? "Run queued" : "Run could not be queued",
                Detail = result.IsSuccess
                    ? $"Run {result.Value!.Id.ToString("N")[..8].ToUpperInvariant()} is waiting for a worker lease."
                    : result.Issues.FirstOrDefault()?.Message ?? "The request failed.",
                Duration = 5_000
            });
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            Notifications.Notify(
                NotificationSeverity.Error,
                "Run could not be queued",
                "The control plane is temporarily unavailable. No run was confirmed.");
        }
        finally
        {
            Loading = false;
        }
    }

    public void Dispose()
    {
        cancellation.Cancel();
        cancellation.Dispose();
    }
}

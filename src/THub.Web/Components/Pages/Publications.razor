    private async Task OpenTokensAsync()
    {
        SelectedTab = DetailTab.Tokens;
        await LoadTokensAsync();
    }

    private async Task LoadTokensAsync()
    {
        if (Selected is null) return;
        var result = await TokenService.ListAsync(Selected.Id, cancellation.Token);
        if (result.IsSuccess) Tokens = result.Value!;
        else Notify(false, result.Problem?.Message ?? "Tokens could not be loaded.");
    }

    private async Task CreateTokenAsync()
    {
        if (Selected is null) return;
        Busy = true;
        try
        {
            var expires = new DateTimeOffset(TokenExpiresLocal, TimeZoneInfo.Local.GetUtcOffset(TokenExpiresLocal)).ToUniversalTime();
            var result = await TokenService.CreateAsync(new CreatePublicationTokenCommand(Selected.Id, TokenName, expires, await GetActorAsync()), cancellation.Token);
            if (!result.IsSuccess || result.Value is null)
            {
                Notify(false, result.Problem?.Message ?? "The token could not be created.");
                return;
            }
            CreatedToken = result.Value;
            TokenCreateVisible = false;
            TokenName = string.Empty;
            await LoadTokensAsync();
        }
        finally { Busy = false; }
    }

    private async Task RevokeTokenAsync(Guid tokenId)
    {
        if (Selected is null) return;
        Busy = true;
        try
        {
            var result = await TokenService.RevokeAsync(new RevokePublicationTokenCommand(Selected.Id, tokenId, await GetActorAsync()), cancellation.Token);
            Notify(result.IsSuccess, result.Problem?.Message ?? "Token revoked.");
            await LoadTokensAsync();
        }
        finally { Busy = false; }
    }

    private async Task OpenGrantsAsync()
    {
        SelectedTab = DetailTab.Grants;
        if (Selected is null) return;
        var result = await GrantService.GetAsync(Selected.Id, cancellation.Token);
        if (!result.IsSuccess || result.Value is null)
        {
            Notify(false, result.Problem?.Message ?? "Role grants could not be loaded.");
            return;
        }
        GrantFingerprint = result.Value.Fingerprint;
        GrantRows = AccessRoles.Select(role =>
        {
            var existing = result.Value.Grants.SingleOrDefault(grant => grant.RoleId == role.Id);
            return new GrantRowModel(role.Id, role.Name, existing);
        }).ToList();
    }

    private async Task SaveGrantsAsync()
    {
        if (Selected is null) return;
        Busy = true;
        try
        {
            var result = await GrantService.ReplaceAsync(new ReplacePublicationGrantsCommand(
                Selected.Id,
                GrantFingerprint,
                GrantRows.Select(row => row.ToCommand()).ToArray()), cancellation.Token);
            if (!result.IsSuccess || result.Value is null)
            {
                Notify(false, result.Problem?.Message ?? "Role grants could not be saved.");
                return;
            }
            GrantFingerprint = result.Value.Fingerprint;
            Notify(true, "Editor role grants saved.");
        }
        finally { Busy = false; }
    }

    private PublicationConcurrencyMode DetermineConcurrency()
    {
        if (Selected?.Kind != PublicationKind.Editor ||
            Inspection?.Kind == PublicationSourceObjectKind.View ||
            !SupportsWritableEditor ||
            !ColumnPolicies.Any(column => column.IsWritable))
            return PublicationConcurrencyMode.ReadOnly;
        return ColumnPolicies.Any(column => column.IsRowVersion)
            ? PublicationConcurrencyMode.RowVersion
            : PublicationConcurrencyMode.OriginalValues;
    }

    private bool SupportsWritableEditor => VersionApplyConnectionId != Guid.Empty;

    private IEnumerable<ConnectionSummary> EligibleApplyConnections
    {
        get
        {
            var read = DatabaseConnections.SingleOrDefault(
                connection => connection.Id == VersionConnectionId);
            return read is null
                ? []
                : DatabaseConnections.Where(connection =>
                    connection.Id != VersionConnectionId &&
                    connection.Kind == read.Kind);
        }
    }

    private bool CanWriteColumn(ColumnPolicyModel column) =>
        Selected?.Kind == PublicationKind.Editor &&
        Inspection?.Kind == PublicationSourceObjectKind.Table &&
        SupportsWritableEditor &&
        column.Include &&
        column.IsSupported &&
        column.IsReadable &&
        !column.IsKey &&
        !column.IsGenerated &&
        !column.IsRowVersion;

    private static List<ColumnPolicyModel> BuildColumnPolicies(PublicationSourceObjectInspectionDto inspection) => inspection.Columns.Select(column =>
    {
        var foreignKey = inspection.ForeignKeys.FirstOrDefault(key => key.Columns.Any(item => string.Equals(item.LocalColumn, column.Name, StringComparison.OrdinalIgnoreCase)));
        var foreignKeyColumn = foreignKey?.Columns.Single(item => string.Equals(item.LocalColumn, column.Name, StringComparison.OrdinalIgnoreCase));
        return new ColumnPolicyModel(column, MakeAlias(column.Name), foreignKey, foreignKeyColumn);
    }).ToList();

    private static List<ForeignKeyPolicyModel> BuildForeignKeyPolicies(
        PublicationSourceObjectInspectionDto inspection) =>
        inspection.ForeignKeys
            .Select(foreignKey => new ForeignKeyPolicyModel(foreignKey))
            .ToList();

    private static string MakeAlias(string sourceName)
    {
        var filtered = new string(sourceName.Select(character => char.IsAsciiLetterOrDigit(character) || character is '_' or '-' ? character : '_').ToArray());
        if (string.IsNullOrEmpty(filtered) || !char.IsAsciiLetter(filtered[0])) filtered = $"column_{filtered}";
        return filtered.Length <= 100 ? filtered : filtered[..100];
    }

    private void ResetVersionWizard()
    {
        VersionVisible = false;
        VersionConnectionId = Guid.Empty;
        VersionApplyConnectionId = Guid.Empty;
        VersionConnectionDetails = null;
        SourceObjects = [];
        SelectedObjectKey = string.Empty;
        Inspection = null;
        ColumnPolicies = [];
        ForeignKeyPolicies = [];
        VersionSettings = new();
    }

    private async Task<string> GetActorAsync() => (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User.Identity?.Name ?? "unknown";
    private void Notify(bool success, string detail) => Notifications.Notify(new NotificationMessage { Severity = success ? NotificationSeverity.Success : NotificationSeverity.Error, Summary = success ? "Publication updated" : "Publication operation failed", Detail = detail, Duration = 6_000 });
    private static string ObjectKey(PublicationSourceObjectDto source) => $"{source.Schema}\u001f{source.Name}\u001f{source.Kind}";
    private static string RouteText(PublicationDetailDto publication) => publication.Kind == PublicationKind.RestApi ? $"GET /api/v1/publications/{publication.Slug}/rows" : $"/data/{publication.Slug}";
    private string? PublicationApiBaseUrl
    {
        get
        {
            var value = Configuration["PublicationApi:PublicBaseUrl"];
            return string.IsNullOrWhiteSpace(value) ? null : value.Trim().TrimEnd('/');
        }
    }
    private string ConsumerUrl(string resource) => $"{PublicationApiBaseUrl ?? "(publication-api-host)"}/api/v1/publications/{Selected!.Slug}/{resource}";
    private string OpenApiUrl => $"{PublicationApiBaseUrl ?? "(publication-api-host)"}/openapi/v1.json";
    private static string StateCss(PublicationState state) => state switch { PublicationState.Active => string.Empty, PublicationState.Draft or PublicationState.Disabled => "draft", PublicationState.Archived => "failed", _ => string.Empty };
    private static string TokenCss(PublicationAccessTokenStatus status) => status == PublicationAccessTokenStatus.Active ? string.Empty : status == PublicationAccessTokenStatus.Expired ? "draft" : "failed";

    public void Dispose() { cancellation.Cancel(); cancellation.Dispose(); }


    private sealed class VersionSettingsModel
    {
        public int DefaultPageSize { get; set; } = 100; public int MaximumPageSize { get; set; } = 500; public int RequestsPerWindow { get; set; } = 600; public int RateLimitWindowSeconds { get; set; } = 60; public int MaximumConcurrentRequests { get; set; } = 10; public int EditorWindowSize { get; set; } = 250; public int RequestTimeoutSeconds { get; set; } = 30; public int CommandTimeoutSeconds { get; set; } = 30; public int MaximumResponseMiB { get; set; } = 10;
        public PublicationVersionSettings ToValue() => new(DefaultPageSize, MaximumPageSize, RequestsPerWindow, RateLimitWindowSeconds, MaximumConcurrentRequests, EditorWindowSize, RequestTimeoutSeconds, CommandTimeoutSeconds, checked(MaximumResponseMiB * 1_024 * 1_024));
    }

    private sealed class ColumnPolicyModel
    {
        public ColumnPolicyModel(PublicationSourceColumnDto column, string alias, PublicationSourceForeignKeyDto? foreignKey, PublicationSourceForeignKeyColumnDto? foreignKeyColumn)
        {
            Source = column; SourceName = column.Name; PublicAlias = alias; SourceTypeName = column.SourceTypeName; IsSupported = column.IsSupported && column.DataType is not null; Include = IsSupported; IsReadable = IsSupported; IsFilterable = IsSupported; IsSortable = IsSupported; IsWritable = false; IsKey = column.IsKey; KeyOrdinal = column.KeyOrdinal; IsRowVersion = column.IsRowVersion; IsGenerated = column.IsGenerated; ForeignKey = foreignKey; ForeignKeyColumn = foreignKeyColumn;
        }
        public PublicationSourceColumnDto Source { get; } public string SourceName { get; } public string PublicAlias { get; set; } public string SourceTypeName { get; } public bool IsSupported { get; } public bool Include { get; set; } public bool IsReadable { get; set; } public bool IsFilterable { get; set; } public bool IsSortable { get; set; } public bool IsWritable { get; set; } public bool IsKey { get; } public int? KeyOrdinal { get; } public bool IsRowVersion { get; } public bool IsGenerated { get; } public PublicationSourceForeignKeyDto? ForeignKey { get; } public PublicationSourceForeignKeyColumnDto? ForeignKeyColumn { get; }
        public CreatePublicationColumnCommand ToCommand(
            PublicationConcurrencyMode concurrency,
            IReadOnlyList<ForeignKeyPolicyModel> foreignKeyPolicies)
        {
            var approved = ForeignKey is null
                ? null
                : foreignKeyPolicies.SingleOrDefault(policy =>
                    policy.IsApproved && string.Equals(
                        policy.ConstraintName,
                        ForeignKey.ConstraintName,
                        StringComparison.OrdinalIgnoreCase));
            var fk = approved is null || ForeignKey is null || ForeignKeyColumn is null
                ? null
                : new CreatePublicationForeignKeyCommand(ForeignKey.ConstraintName, ForeignKeyColumn.Ordinal, ForeignKey.Columns.Count, ForeignKey.ReferencedSchema, ForeignKey.ReferencedObject, ForeignKeyColumn.ReferencedColumn, approved.DisplayColumn, approved.ApprovedSearchColumns, approved.LookupMode);
            return new(Source.Ordinal, Source.Name, PublicAlias, Source.DataType!.Value, Source.SourceTypeName, Source.IsNullable, IsReadable || IsKey, IsFilterable && IsReadable, IsSortable || IsKey, IsWritable && concurrency != PublicationConcurrencyMode.ReadOnly, IsKey, KeyOrdinal, IsRowVersion && concurrency == PublicationConcurrencyMode.RowVersion, IsGenerated, Source.MaximumLength, Source.NumericPrecision, Source.NumericScale, fk);
        }
    }

    private sealed class ForeignKeyPolicyModel
    {
        private readonly HashSet<string> approvedSearchColumns = new(StringComparer.OrdinalIgnoreCase);

        public ForeignKeyPolicyModel(PublicationSourceForeignKeyDto source)
        {
            Source = source;
            ConstraintName = source.ConstraintName;
            DisplayCandidates = source.DisplayCandidates;
            SearchCandidates = source.SearchCandidates;
            RecommendedDisplayColumn = source.RecommendedDisplayColumn;
            RecommendedLookupMode = source.RecommendedLookupMode;
            LookupMode = PublicationLookupMode.ServerFiltered;
            LocalMapping = string.Join(", ", source.Columns
                .OrderBy(column => column.Ordinal)
                .Select(column => $"{column.LocalColumn} → {column.ReferencedColumn}"));
        }

        public PublicationSourceForeignKeyDto Source { get; }
        public string ConstraintName { get; }
        public IReadOnlyList<string> DisplayCandidates { get; }
        public IReadOnlyList<string> SearchCandidates { get; }
        public string RecommendedDisplayColumn { get; }
        public PublicationLookupMode RecommendedLookupMode { get; }
        public string LocalMapping { get; }
        public bool IsApproved { get; set; }
        public string DisplayColumn { get; set; } = string.Empty;
        public PublicationLookupMode LookupMode { get; set; }
        public IReadOnlyList<string> ApprovedSearchColumns => approvedSearchColumns
            .OrderBy(column => column, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        public bool IsSearchColumnApproved(string column) => approvedSearchColumns.Contains(column);

        public void SetSearchColumn(string column, bool enabled)
        {
            if (enabled)
            {
                approvedSearchColumns.Add(column);
            }
            else
            {
                approvedSearchColumns.Remove(column);
            }
        }

        public string? Validate(IReadOnlyList<ColumnPolicyModel> columns)
        {
            if (string.IsNullOrWhiteSpace(DisplayColumn) || approvedSearchColumns.Count == 0)
            {
                return $"Lookup '{ConstraintName}' requires an explicitly selected display column and at least one search column.";
            }

            if (!DisplayCandidates.Contains(DisplayColumn, StringComparer.OrdinalIgnoreCase) ||
                approvedSearchColumns.Any(column => !SearchCandidates.Contains(column, StringComparer.OrdinalIgnoreCase)))
            {
                return $"Lookup '{ConstraintName}' contains a column outside the inspected candidate set.";
            }

            var components = columns
                .Where(column => string.Equals(
                    column.ForeignKey?.ConstraintName,
                    ConstraintName,
                    StringComparison.OrdinalIgnoreCase))
                .ToArray();
            if (components.Length != Source.Columns.Count ||
                components.Any(column => !column.Include || !column.IsReadable))
            {
                return $"Lookup '{ConstraintName}' requires every local component to be included and readable.";
            }

            if (components.Length > 1 &&
                (components.Select(column => column.IsWritable).Distinct().Count() != 1 ||
                 components.Select(column => column.Source.IsNullable).Distinct().Count() != 1))
            {
                return $"Composite lookup '{ConstraintName}' requires identical write and nullability policy for every component.";
            }

            if (components.Length > 1 && LookupMode == PublicationLookupMode.ListValidation)
            {
                return $"Composite lookup '{ConstraintName}' cannot use list validation.";
            }

            return null;
        }
    }

    private sealed class GrantRowModel(Guid roleId, string roleName, PublicationGrantDto? existing)
    {
        public Guid RoleId { get; } = roleId; public string RoleName { get; } = roleName; public bool CanView { get; set; } = existing?.CanView ?? false; public bool CanInsert { get; set; } = existing?.CanInsert ?? false; public bool CanUpdate { get; set; } = existing?.CanUpdate ?? false; public bool CanDelete { get; set; } = existing?.CanDelete ?? false; public bool CanApprove { get; set; } = existing?.CanApprove ?? false;
        public PublicationGrantCommand ToCommand() => new(RoleId, CanView, CanInsert, CanUpdate, CanDelete, CanApprove);
    }

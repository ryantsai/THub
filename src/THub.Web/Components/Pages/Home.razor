@page "/"
@attribute [Authorize(Policy = Permissions.WorkflowView)]

<PageTitle>Overview · THub</PageTitle>

<div class="page-heading">
    <div>
        <div class="eyebrow">Wednesday · 22 July</div>
        <h1>Data operations overview</h1>
        <p>A quiet control room for every pipeline, schedule, and published dataset.</p>
    </div>
    <div class="heading-actions">
        <RadzenButton Text="Import workflow" Icon="upload_file" ButtonStyle="ButtonStyle.Light" />
        <RadzenButton Text="New workflow" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@GoToDesigner" />
    </div>
</div>

<section class="metric-grid" aria-label="Workflow metrics">
    <article class="metric-card">
        <div class="metric-label"><span>Active workflows</span><span class="metric-icon"><RadzenIcon Icon="account_tree" /></span></div>
        <div class="metric-value">12</div><div class="metric-foot"><strong>+2</strong> since last month</div>
    </article>
    <article class="metric-card">
        <div class="metric-label"><span>Runs today</span><span class="metric-icon"><RadzenIcon Icon="play_circle" /></span></div>
        <div class="metric-value">1,284</div><div class="metric-foot"><strong>99.4%</strong> successful</div>
    </article>
    <article class="metric-card">
        <div class="metric-label"><span>Rows processed</span><span class="metric-icon"><RadzenIcon Icon="data_usage" /></span></div>
        <div class="metric-value">8.7M</div><div class="metric-foot">Across 6 connected sources</div>
    </article>
    <article class="metric-card alert">
        <div class="metric-label"><span>Needs attention</span><span class="metric-icon"><RadzenIcon Icon="warning_amber" /></span></div>
        <div class="metric-value">3</div><div class="metric-foot">2 failed · 1 paused</div>
    </article>
</section>

<div class="dashboard-grid">
    <section class="panel">
        <div class="panel-head"><div><h2>Recent workflow runs</h2><p>Live activity from the orchestration worker</p></div><a href="/runs">View all runs →</a></div>
        <div class="table-scroll">
            <table class="activity-table">
                <thead><tr><th>Workflow</th><th>Status</th><th>Triggered</th><th>Duration</th><th>Rows</th></tr></thead>
                <tbody>
                    @foreach (var run in Runs)
                    {
                        <tr>
                            <td><div class="workflow-name"><span class="mini-flow-icon"><RadzenIcon Icon="@run.Icon" /></span>@run.Name</div></td>
                            <td><span class="status-chip @run.Status.ToLowerInvariant()">@run.Status</span></td>
                            <td class="muted">@run.Triggered</td><td class="duration">@run.Duration</td><td class="duration">@run.Rows</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <div class="dashboard-stack">
        <section class="panel">
            <div class="panel-head"><div><h2>System health</h2><p>Runtime and dependency status</p></div><span class="status-chip">Healthy</span></div>
            <div class="health-list">
                <div class="health-item"><span class="health-icon"><RadzenIcon Icon="dns" /></span><div><strong>SQL Server</strong><small>THub metadata store</small></div><span class="health-value">14 ms</span></div>
                <div class="health-item"><span class="health-icon"><RadzenIcon Icon="memory" /></span><div><strong>Worker service</strong><small>NODE-DATA-01</small></div><span class="health-value">Online</span></div>
                <div class="health-item"><span class="health-icon"><RadzenIcon Icon="folder_open" /></span><div><strong>Local file agent</strong><small>3 watched locations</small></div><span class="health-value">Ready</span></div>
            </div>
        </section>
        <section class="panel">
            <div class="panel-head"><div><h2>Quick actions</h2><p>Common operations</p></div></div>
            <div class="quick-list">
                <a href="/connections"><RadzenIcon Icon="add_circle_outline" /><span>Add a data connection</span><small>→</small></a>
                <a href="/designer"><RadzenIcon Icon="schema" /><span>Design a workflow</span><small>→</small></a>
                <a href="/schedules"><RadzenIcon Icon="more_time" /><span>Create a schedule</span><small>→</small></a>
            </div>
        </section>
    </div>
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    private void GoToDesigner() => Navigation.NavigateTo("/designer");

    private static readonly RunRow[] Runs =
    [
        new("Daily customer sync", "Succeeded", "Schedule · 4 min ago", "01:42", "124,892", "sync_alt"),
        new("Order enrichment", "Running", "Schedule · 8 min ago", "00:38", "47,201", "hub"),
        new("Finance export", "Failed", "Ryan · 22 min ago", "00:11", "—", "table_view"),
        new("Inventory snapshot", "Succeeded", "Webhook · 37 min ago", "02:08", "803,443", "inventory_2"),
        new("Partner CSV intake", "Succeeded", "File watch · 1 hr ago", "00:54", "18,604", "description")
    ];

    private sealed record RunRow(string Name, string Status, string Triggered, string Duration, string Rows, string Icon);
}

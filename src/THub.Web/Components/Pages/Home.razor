@page "/"
@attribute [Authorize(Policy = Permissions.WorkflowView)]
@implements IDisposable
@using THub.Application.Workflows.Management
@using THub.Domain.Runs
@using THub.Domain.Security
@using THub.Domain.Workflows
@inject WorkflowCatalogService WorkflowCatalog
@inject WorkflowRunHistoryService RunHistory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AccessControlEvaluator AccessControl
@inject NavigationManager Navigation
@inject TimeProvider TimeProvider

<PageTitle>@Localizer["Overview · THub"]</PageTitle>

<div class="page-heading">
    <div>
        <div class="eyebrow">@TimeProvider.GetLocalNow().ToString("dddd · d MMMM")</div>
        <h1>@Localizer["Good {0}, {1}.", Greeting, UserDisplayName]</h1>
        <p>@Localizer["Move data between your systems, automate the work, and see what happened."]</p>
    </div>
    <div class="heading-actions">
        <RadzenButton Text='@Localizer["View runs"]' Icon="history" ButtonStyle="ButtonStyle.Light" Click="@(() => Navigation.NavigateTo("/runs"))" />
        <AuthorizeView Policy="@Permissions.WorkflowEdit">
            <RadzenButton Text='@Localizer["Create workflow"]' Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@(() => Navigation.NavigateTo("/designer"))" />
        </AuthorizeView>
    </div>
</div>

@if (Loading)
{
    <div class="page-state"><RadzenProgressBar Mode="ProgressBarMode.Indeterminate" /><p>@Localizer["Loading operational state…"]</p></div>
}
else if (Error is not null)
{
    <div class="page-state error"><RadzenIcon Icon="error_outline" /><p>@Error</p><button type="button" @onclick="LoadAsync">@Localizer["Try again"]</button></div>
}
else
{
    <section class="getting-started" aria-labelledby="getting-started-title">
        <div class="section-intro">
            <div>
                <span class="eyebrow">@Localizer["Start here"]</span>
                <h2 id="getting-started-title">@JourneyTitle</h2>
            </div>
            <p>@Localizer["THub guides you from a data source to a result you can check."]</p>
        </div>
        <ol class="journey">
            <li>
                <span class="journey-number">1</span>
                <div><strong>@Localizer["Connect data"]</strong><small>@Localizer["Add the database or files you want to use."]</small></div>
                <AuthorizeView Policy="@Permissions.ConnectionManage"><a href="/connections">@Localizer["Add connection"]</a></AuthorizeView>
            </li>
            <li>
                <span class="journey-number">2</span>
                <div><strong>@Localizer["Build a workflow"]</strong><small>@Localizer["Choose the steps and what each one should do."]</small></div>
                <AuthorizeView Policy="@Permissions.WorkflowEdit"><a href="/designer">@Localizer["Create workflow"]</a></AuthorizeView>
            </li>
            <li>
                <span class="journey-number">3</span>
                <div><strong>@Localizer["Run it"]</strong><small>@Localizer["Publish when it is ready, then run it now or on a schedule."]</small></div>
                <a href="/workflows">@Localizer["Open workflows"]</a>
            </li>
            <li>
                <span class="journey-number">4</span>
                <div><strong>@Localizer["Check results"]</strong><small>@Localizer["Confirm success or see exactly where a run stopped."]</small></div>
                <a href="/runs">@Localizer["View runs"]</a>
            </li>
        </ol>
    </section>

    <section class="metric-grid summary-strip" aria-label='@Localizer["Workspace summary"]'>
        <article class="metric-card">
            <div class="metric-label"><span>@Localizer["Ready workflows"]</span><span class="metric-icon"><RadzenIcon Icon="account_tree" /></span></div>
            <div class="metric-value">@PublishedWorkflowCount</div><div class="metric-foot">@Localizer["{0} total", WorkflowCount]</div>
        </article>
        <article class="metric-card">
            <div class="metric-label"><span>@Localizer["Runs today"]</span><span class="metric-icon"><RadzenIcon Icon="play_circle" /></span></div>
            <div class="metric-value">@RunsToday</div><div class="metric-foot"><strong>@SuccessRate</strong> @Localizer["successful"]</div>
        </article>
        <article class="metric-card">
            <div class="metric-label"><span>@Localizer["Active schedules"]</span><span class="metric-icon"><RadzenIcon Icon="event_repeat" /></span></div>
            <div class="metric-value">@ActiveScheduleCount</div><div class="metric-foot">@NextScheduleText</div>
        </article>
        <article class="metric-card alert">
            <div class="metric-label"><span>@Localizer["Needs attention"]</span><span class="metric-icon"><RadzenIcon Icon="warning_amber" /></span></div>
            <div class="metric-value">@AttentionCount</div><div class="metric-foot">@Localizer["{0} failed · {1} paused", FailedRunCount, PausedWorkflowCount]</div>
        </article>
    </section>

    <div class="dashboard-grid">
        <section class="panel">
            <div class="panel-head"><div><h2>@Localizer["Recent runs"]</h2><p>@Localizer["The latest workflow activity you can access"]</p></div><a href="/runs">@Localizer["View all runs →"]</a></div>
            @if (RecentRuns.Count == 0)
            {
                <div class="page-state compact"><p>@Localizer["No runs have been queued."]</p></div>
            }
            else
            {
                <div class="table-scroll">
                    <table class="activity-table">
                        <thead><tr><th>@Localizer["Workflow"]</th><th>@Localizer["Status"]</th><th>@Localizer["Triggered"]</th><th>@Localizer["Duration"]</th><th>@Localizer["Version"]</th></tr></thead>
                        <tbody>
                            @foreach (var run in RecentRuns)
                            {
                                <tr>
                                    <td><div class="workflow-name"><span class="mini-flow-icon"><RadzenIcon Icon="account_tree" /></span>@run.WorkflowName</div></td>
                                    <td><span class="status-chip @StatusCss(run.Status)">@run.Status</span></td>
                                    <td class="muted">@TriggerText(run)</td>
                                    <td class="duration">@DurationText(run)</td>
                                    <td class="duration">v@(run.WorkflowVersion)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <div class="dashboard-stack">
            <section class="panel">
                <div class="panel-head"><div><h2>@Localizer["System status"]</h2><p>@Localizer["Checked when this page loaded"]</p></div><span class="status-chip">@Localizer["Ready"]</span></div>
                <div class="health-list">
                    <div class="health-item"><span class="health-icon"><RadzenIcon Icon="storage" /></span><div><strong>@Localizer["Workspace data"]</strong><small>@Localizer["Workflows and runs loaded normally"]</small></div><span class="health-value">@Localizer["Ready"]</span></div>
                    <div class="health-item"><span class="health-icon"><RadzenIcon Icon="memory" /></span><div><strong>@Localizer["Runs in progress"]</strong><small>@Localizer["Queued or currently running"]</small></div><span class="health-value">@ActiveRunCount active</span></div>
                    <div class="health-item"><span class="health-icon"><RadzenIcon Icon="schedule" /></span><div><strong>@Localizer["Schedules"]</strong><small>@Localizer["Workflows set to run automatically"]</small></div><span class="health-value">@ActiveScheduleCount active</span></div>
                </div>
            </section>
            <section class="panel">
                <div class="panel-head"><div><h2>@Localizer["Common tasks"]</h2><p>@Localizer["Go straight to the work you need"]</p></div></div>
                <div class="quick-list">
                    <AuthorizeView Policy="@Permissions.ConnectionManage"><a href="/connections"><RadzenIcon Icon="add_circle_outline" /><span>@Localizer["Add a data connection"]</span><small>→</small></a></AuthorizeView>
                    <AuthorizeView Policy="@Permissions.WorkflowEdit"><a href="/designer"><RadzenIcon Icon="schema" /><span>@Localizer["Create a workflow"]</span><small>→</small></a></AuthorizeView>
                    <AuthorizeView Policy="@Permissions.ScheduleManage"><a href="/schedules"><RadzenIcon Icon="more_time" /><span>@Localizer["Review automatic schedules"]</span><small>→</small></a></AuthorizeView>
                </div>
            </section>
        </div>
    </div>
}

@code {
    private readonly CancellationTokenSource cancellation = new();
    private IReadOnlyList<WorkflowListItemDto> Workflows { get; set; } = [];
    private IReadOnlyList<WorkflowRunListRecord> RecentRuns { get; set; } = [];
    private int WorkflowCount { get; set; }
    private bool Loading { get; set; }
    private string? Error { get; set; }
    private string UserDisplayName { get; set; } = "there";
    private string JourneyTitle => WorkflowCount == 0
        ? "Build your first automation in four steps"
        : "Four steps from data to result";
    private string Greeting => TimeProvider.GetLocalNow().Hour switch
    {
        < 12 => Localizer["morning"],
        < 18 => Localizer["afternoon"],
        _ => Localizer["evening"]
    };

    private int PublishedWorkflowCount => Workflows.Count(workflow => workflow.Status == WorkflowStatus.Published);
    private int PausedWorkflowCount => Workflows.Count(workflow => workflow.Status == WorkflowStatus.Paused);
    private int ActiveScheduleCount => Workflows.Count(workflow => workflow.Status == WorkflowStatus.Published && workflow.CronExpression is not null);
    private int ActiveRunCount => RecentRuns.Count(run => run.Status is WorkflowRunStatus.Queued or WorkflowRunStatus.Running);
    private int FailedRunCount => RecentRuns.Count(run => run.Status == WorkflowRunStatus.Failed);
    private int AttentionCount => FailedRunCount + PausedWorkflowCount;
    private int RunsToday => RecentRuns.Count(run => run.QueuedAtUtc >= TimeProvider.GetUtcNow().Date);
    private string SuccessRate
    {
        get
        {
            var completedToday = RecentRuns.Where(run => run.QueuedAtUtc >= TimeProvider.GetUtcNow().Date && run.Status is WorkflowRunStatus.Succeeded or WorkflowRunStatus.Failed or WorkflowRunStatus.Cancelled).ToArray();
            return completedToday.Length == 0
                ? "No completed runs"
                : $"{completedToday.Count(run => run.Status == WorkflowRunStatus.Succeeded) * 100d / completedToday.Length:0.#}%";
        }
    }
    private string NextScheduleText
    {
        get
        {
            var next = Workflows.Where(workflow => workflow.NextRunAtUtc is not null).MinBy(workflow => workflow.NextRunAtUtc)?.NextRunAtUtc;
            return next is null ? "No next occurrence" : $"Next {next.Value.ToLocalTime():g}";
        }
    }

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        Loading = true;
        Error = null;
        try
        {
            var workflowsTask = WorkflowCatalog.ListAsync(
                new WorkflowListRequest(Limit: WorkflowCatalogService.MaximumPageSize),
                cancellation.Token);
            var runsTask = RunHistory.ListAsync(new WorkflowRunListRequest(Limit: 50), cancellation.Token);
            await Task.WhenAll(workflowsTask, runsTask);

            var workflows = await workflowsTask;
            var runs = await runsTask;
            if (!workflows.IsSuccess || workflows.Value is null || !runs.IsSuccess || runs.Value is null)
            {
                Error = workflows.Issues.Concat(runs.Issues).FirstOrDefault()?.Message ?? "Operational data could not be loaded.";
                return;
            }

            var user = (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;
            UserDisplayName = FriendlyName(user.Identity?.Name);
            var visibleWorkflowIds = new HashSet<Guid>();
            var visibleWorkflows = new List<WorkflowListItemDto>();
            foreach (var workflow in workflows.Value.Items)
            {
                if (await AccessControl.HasPermissionAsync(
                        user,
                        Permissions.WorkflowView,
                        AccessResourceKind.Workflow,
                        workflow.Id,
                        cancellation.Token))
                {
                    visibleWorkflowIds.Add(workflow.Id);
                    visibleWorkflows.Add(workflow);
                }
            }

            Workflows = visibleWorkflows;
            WorkflowCount = visibleWorkflows.Count;
            RecentRuns = runs.Value.Items
                .Where(run => visibleWorkflowIds.Contains(run.WorkflowId))
                .Take(8)
                .ToArray();
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            Error = "Operational data is temporarily unavailable.";
        }
        finally
        {
            Loading = false;
        }
    }

    private static string StatusCss(WorkflowRunStatus status) => status switch
    {
        WorkflowRunStatus.Queued or WorkflowRunStatus.Running => "running",
        WorkflowRunStatus.Failed => "failed",
        WorkflowRunStatus.Cancelled => "draft",
        _ => string.Empty
    };

    private static string TriggerText(WorkflowRunListRecord run) =>
        run.ScheduledForUtc is not null ? $"Schedule · {run.QueuedAtUtc.ToLocalTime():g}" : $"{run.TriggeredBy} · {run.QueuedAtUtc.ToLocalTime():g}";

    private static string DurationText(WorkflowRunListRecord run)
    {
        if (run.StartedAtUtc is null)
        {
            return "—";
        }
        var duration = (run.CompletedAtUtc ?? DateTimeOffset.UtcNow) - run.StartedAtUtc.Value;
        return duration.TotalHours >= 1 ? duration.ToString(@"hh\:mm\:ss") : duration.ToString(@"mm\:ss");
    }

    private static string FriendlyName(string? identityName)
    {
        if (string.IsNullOrWhiteSpace(identityName))
        {
            return "there";
        }

        var accountName = identityName.Contains('\\')
            ? identityName[(identityName.LastIndexOf('\\') + 1)..]
            : identityName;
        var firstPart = accountName
            .Replace('.', ' ')
            .Replace('_', ' ')
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .FirstOrDefault();
        return string.IsNullOrWhiteSpace(firstPart)
            ? "there"
            : char.ToUpperInvariant(firstPart[0]) + firstPart[1..].ToLowerInvariant();
    }

    public void Dispose()
    {
        cancellation.Cancel();
        cancellation.Dispose();
    }
}

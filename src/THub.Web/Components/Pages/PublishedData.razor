@page "/published-data"
@attribute [Authorize]
@implements IDisposable
@using THub.Application.Publications
@using THub.Domain.Publications
@inject PublicationCatalogService Catalog
@inject PublicationAuthorizationService AuthorizationService
@inject PublicationRoleResolver RoleResolver
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Data tables · THub</PageTitle>

<div class="page-heading">
    <div><div class="eyebrow">Share and monitor</div><h1>Data tables</h1><p>Open the shared tables you can view or edit.</p></div>
    <RadzenButton Text="Refresh" Icon="refresh" ButtonStyle="ButtonStyle.Light" Click="@LoadAsync" Disabled="@Loading" />
</div>

<section class="panel">
    @if (Loading)
    {
        <div class="page-state"><RadzenProgressBar Mode="ProgressBarMode.Indeterminate" /><p>Checking which tables you can access…</p></div>
    }
    else if (Error is not null)
    {
        <div class="page-state error" role="alert"><RadzenIcon Icon="error_outline" /><p>@Error</p><button type="button" @onclick="LoadAsync">Try again</button></div>
    }
    else if (Items.Count == 0)
    {
        <div class="page-state"><RadzenIcon Icon="table_view" /><h2>No data tables are assigned</h2><p>Ask an administrator to share a table with your role.</p></div>
    }
    else
    {
        <div class="published-editor-grid">
            @foreach (var item in Items)
            {
                <article>
                    <div class="published-editor-icon"><RadzenIcon Icon="table_view" /></div>
                    <div><h2>@item.Name</h2><p><code>@item.Slug</code> · active governed spreadsheet</p></div>
                    <a href="@($"/data/{item.Slug}")">Open editor <RadzenIcon Icon="arrow_forward" /></a>
                </article>
            }
        </div>
    }
</section>

@code {
    private readonly CancellationTokenSource cancellation = new();
    private IReadOnlyList<PublicationSummaryDto> Items { get; set; } = [];
    private bool Loading { get; set; }
    private string? Error { get; set; }

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        Loading = true;
        Error = null;
        try
        {
            var authentication = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var roles = await RoleResolver.ResolveAsync(authentication.User, cancellation.Token);
            var result = await Catalog.ListAsync(
                new PublicationCatalogQuery(PublicationKind.Editor, PublicationState.Active),
                cancellation.Token);
            if (!result.IsSuccess || result.Value is null)
            {
                Error = result.Problem?.Message ?? "Published editors could not be loaded.";
                return;
            }

            var allowed = new List<PublicationSummaryDto>();
            foreach (var publication in result.Value)
            {
                var authorization = await AuthorizationService.AuthorizeAsync(
                    publication.Id,
                    roles,
                    PublicationOperation.View,
                    cancellation.Token);
                if (authorization.IsSuccess)
                {
                    allowed.Add(publication);
                }
            }
            Items = allowed;
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            Error = "Published editors are temporarily unavailable.";
        }
        finally
        {
            Loading = false;
        }
    }

    public void Dispose()
    {
        cancellation.Cancel();
        cancellation.Dispose();
    }
}

    private async Task SaveProfileAsync()
    {
        ProfileFormError = ValidateProfile();
        if (ProfileFormError is not null)
        {
            return;
        }

        Busy = true;
        try
        {
            var limits = new EmailDeliveryLimits(
                ProfileEditor.MaximumRecipients,
                ProfileEditor.MaximumSubjectLength,
                ProfileEditor.MaximumBodyLength,
                ProfileEditor.MaximumConcurrentSends);
            var domains = SplitValues(ProfileEditor.AllowedDomainsText);
            AlertResult<EmailDeliveryProfileDto> result;
            if (ProfileEditor.Id is Guid profileId)
            {
                result = await AlertAdministration.UpdateProfileAsync(
                    new UpdateEmailDeliveryProfileCommand(
                        profileId,
                        ProfileEditor.Name,
                        ProfileEditor.SmtpHost,
                        ProfileEditor.SmtpPort,
                        ProfileEditor.TransportSecurity,
                        ProfileEditor.SenderAddress,
                        domains,
                        NullIfWhitespace(ProfileEditor.CredentialSecretReference),
                        limits,
                        ProfileEditor.UpdatedAtUtc),
                    cancellation.Token);
            }
            else
            {
                result = await AlertAdministration.CreateProfileAsync(
                    new CreateEmailDeliveryProfileCommand(
                        ProfileEditor.Name,
                        ProfileEditor.SmtpHost,
                        ProfileEditor.SmtpPort,
                        ProfileEditor.TransportSecurity,
                        ProfileEditor.SenderAddress,
                        domains,
                        await GetActorAsync(),
                        NullIfWhitespace(ProfileEditor.CredentialSecretReference),
                        limits),
                    cancellation.Token);
            }

            if (!result.IsSuccess || result.Value is null)
            {
                ProfileFormError = result.Problem?.Message ?? "The Email delivery profile could not be saved.";
                return;
            }

            ProfileEditor = ProfileEditModel.From(result.Value);
            await LoadProfilesAsync();
            Notify(true, "Email delivery profile saved.");
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (ArgumentException exception)
        {
            ProfileFormError = exception.Message;
        }
        catch (Exception)
        {
            ProfileFormError = "The Email delivery profile could not be saved because the service is temporarily unavailable.";
        }
        finally
        {
            Busy = false;
        }
    }


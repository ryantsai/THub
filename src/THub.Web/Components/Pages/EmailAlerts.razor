    private string? ValidateProfile()
    {
        if (string.IsNullOrWhiteSpace(ProfileEditor.Name)
            || string.IsNullOrWhiteSpace(ProfileEditor.SmtpHost)
            || string.IsNullOrWhiteSpace(ProfileEditor.SenderAddress))
        {
            return "Profile name, SMTP host, and sender are required.";
        }

        var domains = SplitValues(ProfileEditor.AllowedDomainsText);
        if (domains.Count is < 1 or > 20)
        {
            return "Provide between 1 and 20 approved recipient domains.";
        }

        if (ProfileEditor.SmtpPort is < 1 or > 65_535
            || ProfileEditor.MaximumRecipients is < 1 or > EmailDeliveryLimits.AbsoluteMaximumRecipients
            || ProfileEditor.MaximumSubjectLength is < 1 or > EmailDeliveryLimits.AbsoluteMaximumSubjectLength
            || ProfileEditor.MaximumBodyLength is < 1 or > EmailDeliveryLimits.AbsoluteMaximumBodyLength
            || ProfileEditor.MaximumConcurrentSends is < 1 or > EmailDeliveryLimits.AbsoluteMaximumConcurrency)
        {
            return "One or more numeric profile bounds are outside the supported range.";
        }

        return null;
    }

    private string? ValidateRule()
    {
        if (SelectedWorkflowId is null || RuleEditor.ProfileId == Guid.Empty)
        {
            return "Select a workflow and an Email delivery profile.";
        }

        if (string.IsNullOrWhiteSpace(RuleEditor.Name)
            || string.IsNullOrWhiteSpace(RuleEditor.SubjectTemplate))
        {
            return "Rule name and subject template are required.";
        }

        if (RuleEditor.Triggers == WorkflowAlertTriggers.None)
        {
            return "Select at least one terminal workflow event.";
        }

        var recipients = SplitValues(RuleEditor.RecipientsText);
        if (recipients.Count is < 1 or > EmailDeliveryLimits.AbsoluteMaximumRecipients)
        {
            return $"Provide between 1 and {EmailDeliveryLimits.AbsoluteMaximumRecipients} recipients.";
        }

        return null;
    }

    private async Task<string> GetActorAsync() =>
        (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User.Identity?.Name
        ?? "unknown";

    private void Notify(bool success, string detail) => Notifications.Notify(new NotificationMessage
    {
        Severity = success ? NotificationSeverity.Success : NotificationSeverity.Error,
        Summary = success ? "Email policy updated" : "Email policy operation failed",
        Detail = detail,
        Duration = 6_000
    });

    private string ProfileName(Guid profileId) =>
        Profiles.SingleOrDefault(profile => profile.Id == profileId)?.Name ?? "Unavailable profile";

    private static string CredentialSummary(EmailDeliveryProfileDto profile) =>
        profile.CredentialSecretReference is null
            ? "Approved anonymous relay"
            : "Credential reference configured";

    private static string SecurityLabel(EmailTransportSecurity security) => security switch
    {
        EmailTransportSecurity.StartTlsRequired => "STARTTLS required",
        EmailTransportSecurity.ImplicitTls => "Implicit TLS",
        _ => "Unknown transport"
    };

    private static string TriggerSummary(WorkflowAlertTriggers triggers)
    {
        var values = new List<string>(3);
        if (triggers.HasFlag(WorkflowAlertTriggers.RunFailed)) values.Add("Failure");
        if (triggers.HasFlag(WorkflowAlertTriggers.RunSucceeded)) values.Add("Success");
        if (triggers.HasFlag(WorkflowAlertTriggers.RunCancelled)) values.Add("Cancellation");
        return string.Join(", ", values);
    }

    private static string ShortId(Guid id) => id.ToString("N")[..8].ToUpperInvariant();

    private static string DeliveryStatusCss(AlertDeliveryStatus status) => status switch
    {
        AlertDeliveryStatus.Sending or AlertDeliveryStatus.RetryScheduled => "running",
        AlertDeliveryStatus.DeadLettered => "failed",
        AlertDeliveryStatus.Pending => "draft",
        _ => string.Empty
    };

    private static string DeliveryTiming(EmailAlertDeliveryListItem delivery) => delivery.Status switch
    {
        AlertDeliveryStatus.Pending or AlertDeliveryStatus.RetryScheduled =>
            $"Next {delivery.NextAttemptAtUtc.ToLocalTime():g}",
        AlertDeliveryStatus.Sending when delivery.LeaseExpiresAtUtc is { } lease =>
            $"Lease until {lease.ToLocalTime():g}",
        _ when delivery.CompletedAtUtc is { } completed =>
            $"Completed {completed.ToLocalTime():g}",
        _ => "Awaiting outcome"
    };

    private static IReadOnlyList<string> SplitValues(string value) => value
        .Split([',', ';', '\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private static string? NullIfWhitespace(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();


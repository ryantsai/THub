@page "/alerts/email"
@attribute [Authorize(Policy = Permissions.Administration)]
@implements IDisposable
@using THub.Application.Alerts
@using THub.Application.Workflows.Management
@using THub.Domain.Alerts
@inject EmailAlertAdministrationService AlertAdministration
@inject EmailAlertMonitoringService AlertMonitoring
@inject WorkflowCatalogService WorkflowCatalog
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NotificationService Notifications

<PageTitle>@Localizer["Email alerts · THub"]</PageTitle>

<div class="page-heading">
    <div>
        <div class="eyebrow">@Localizer["Administration"]</div>
        <h1>@Localizer["Email alerts"]</h1>
        <p>@Localizer["Govern approved SMTP relays and durable workflow-event notifications."]</p>
    </div>
    <div class="heading-actions">
        @if (SelectedTab == AlertTab.Profiles)
        {
            <RadzenButton Text='@Localizer["New profile"]' Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@NewProfile" Disabled="@Busy" />
        }
        else if (SelectedTab == AlertTab.Rules)
        {
            <RadzenButton Text='@Localizer["New rule"]' Icon="add_alert" ButtonStyle="ButtonStyle.Primary" Click="@NewRule" Disabled="@(Busy || SelectedWorkflowId is null || !Profiles.Any(profile => profile.IsEnabled))" />
        }
        <RadzenButton Text='@Localizer["Refresh"]' Icon="refresh" ButtonStyle="ButtonStyle.Light" Click="@RefreshAsync" Disabled="@Busy" />
    </div>
</div>

<section class="email-policy-note" aria-label='@Localizer["Email delivery boundary"]'>
    <RadzenIcon Icon="verified_user" />
    <div>
        <strong>@Localizer["Durable, policy-controlled delivery"]</strong>
        <span>@Localizer["Email actions queue intent in SQL Server. SMTP delivery is at-least-once, so an ambiguous relay acknowledgement can produce a duplicate."]</span>
    </div>
</section>

<div class="alert-tabs" role="tablist" aria-label='@Localizer["Email alert management"]'>
    <button type="button" role="tab" aria-selected="@(SelectedTab == AlertTab.Profiles)" class="@(SelectedTab == AlertTab.Profiles ? "active" : null)" @onclick="() => SelectTab(AlertTab.Profiles)">
        <RadzenIcon Icon="outgoing_mail" /> @Localizer["Delivery profiles"] <span>@Profiles.Count</span>
    </button>
    <button type="button" role="tab" aria-selected="@(SelectedTab == AlertTab.Rules)" class="@(SelectedTab == AlertTab.Rules ? "active" : null)" @onclick="() => SelectTab(AlertTab.Rules)">
        <RadzenIcon Icon="notifications_active" /> @Localizer["Workflow rules"] <span>@Rules.Count</span>
    </button>
    <button type="button" role="tab" aria-selected="@(SelectedTab == AlertTab.Deliveries)" class="@(SelectedTab == AlertTab.Deliveries ? "active" : null)" @onclick="() => SelectTab(AlertTab.Deliveries)">
        <RadzenIcon Icon="mark_email_read" /> @Localizer["Delivery monitor"] <span>@DeliveryTotal</span>
    </button>
</div>

<div class="operation-status @(PageError is null ? "" : "error")" aria-live="polite" aria-atomic="true">
    @if (PageError is not null)
    {
        <RadzenIcon Icon="error_outline" /><span>@PageError</span>
    }
</div>

@if (Loading)
{
    <div class="page-state"><RadzenProgressBar Mode="ProgressBarMode.Indeterminate" /><p>@Localizer["Loading Email alert policy…"]</p></div>
}
else if (SelectedTab == AlertTab.Profiles)
{
    <section class="panel alert-catalog" role="tabpanel" aria-label='@Localizer["Email delivery profiles"]'>
        <div class="panel-head">
            <div><h2>@Localizer["Delivery profiles"]</h2><p>@Localizer["Administrator-owned relay, sender, TLS, recipient, and message limits."]</p></div>
        </div>
        @if (Profiles.Count == 0)
        {
            <div class="page-state compact"><RadzenIcon Icon="outgoing_mail" /><h3>@Localizer["No Email delivery profiles"]</h3><p>@Localizer["Create an approved relay profile before adding workflow rules or Email actions."]</p></div>
        }
        else
        {
            <div class="table-scroll">
                <table class="activity-table alert-table">
                    <thead><tr><th>@Localizer["Profile"]</th><th>@Localizer["Relay"]</th><th>@Localizer["Sender"]</th><th>@Localizer["Policy"]</th><th>@Localizer["Status"]</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var profile in Profiles)
                        {
                            <tr class="@(ProfileEditor.Id == profile.Id ? "selected" : null)">
                                <td><strong>@profile.Name</strong><small>@CredentialSummary(profile)</small></td>
                                <td><code>@profile.SmtpHost:@profile.SmtpPort</code><small>@SecurityLabel(profile.TransportSecurity)</small></td>
                                <td>@profile.SenderAddress</td>
                                <td><span>@profile.Limits.MaximumRecipients recipients</span><small>@profile.AllowedRecipientDomains.Count approved domain(s)</small></td>
                                <td><span class="status-chip @(profile.IsEnabled ? "" : "draft")">@(profile.IsEnabled ? "Enabled" : "Disabled")</span></td>
                                <td><button class="table-action" type="button" @onclick="() => EditProfile(profile)">@Localizer["Manage"]</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    @if (ProfileEditorVisible)
    {
        <section class="panel policy-editor" aria-labelledby="profile-editor-title">
            <div class="panel-head">
                <div><h2 id="profile-editor-title">@(ProfileEditor.Id is null ? "New delivery profile" : "Edit delivery profile")</h2><p>@Localizer["Enter only an approved secret-provider lookup key; never paste a username or password."]</p></div>
                <button class="icon-close" type="button" aria-label='@Localizer["Close profile editor"]' @onclick="CloseProfileEditor">×</button>
            </div>

            <div class="editor-section">
                <h3>@Localizer["Relay and sender"]</h3>
                <div class="policy-form">
                    <label><span>@Localizer["Profile name"] <b aria-hidden="true">*</b></span><input maxlength="200" required aria-required="true" @bind="ProfileEditor.Name" disabled="@Busy" /></label>
                    <label><span>@Localizer["SMTP host"] <b aria-hidden="true">*</b></span><input maxlength="253" placeholder='@Localizer["smtp.example.com"]' required aria-required="true" @bind="ProfileEditor.SmtpHost" disabled="@Busy" /></label>
                    <label><span>@Localizer["Port"]</span><input type="number" min="1" max="65535" @bind="ProfileEditor.SmtpPort" disabled="@Busy" /></label>
                    <label><span>@Localizer["Transport security"]</span>
                        <select @bind="ProfileEditor.TransportSecurity" disabled="@Busy">
                            <option value="@EmailTransportSecurity.StartTlsRequired">@Localizer["STARTTLS required"]</option>
                            <option value="@EmailTransportSecurity.ImplicitTls">@Localizer["Implicit TLS"]</option>
                        </select>
                    </label>
                    <label><span>@Localizer["Approved sender"] <b aria-hidden="true">*</b></span><input type="email" maxlength="320" placeholder="thub@example.com" required aria-required="true" @bind="ProfileEditor.SenderAddress" disabled="@Busy" /></label>
                    <label><span>@Localizer["Credential secret reference"]</span><input maxlength="500" autocomplete="off" spellcheck="false" placeholder="smtp/production" @bind="ProfileEditor.CredentialSecretReference" disabled="@Busy" /><small>@Localizer["Optional reference only. Username/password are resolved by the Worker from the approved secret provider at send time."]</small></label>
                </div>
            </div>

            <div class="editor-section divided">
                <h3>@Localizer["Recipient and message bounds"]</h3>
                <div class="policy-form bounds">
                    <label class="wide"><span>@Localizer["Allowed recipient domains"] <b aria-hidden="true">*</b></span><textarea rows="3" maxlength="3900" placeholder='@Localizer["example.com
subsidiary.example.com"]' @bind="ProfileEditor.AllowedDomainsText" disabled="@Busy"></textarea><small>@Localizer["One domain per line. Up to 20 domains; every recipient is checked before SMTP."]</small></label>
                    <label><span>@Localizer["Maximum recipients"]</span><input type="number" min="1" max="100" @bind="ProfileEditor.MaximumRecipients" disabled="@Busy" /></label>
                    <label><span>@Localizer["Maximum subject characters"]</span><input type="number" min="1" max="998" @bind="ProfileEditor.MaximumSubjectLength" disabled="@Busy" /></label>
                    <label><span>@Localizer["Maximum body characters"]</span><input type="number" min="1" max="1000000" @bind="ProfileEditor.MaximumBodyLength" disabled="@Busy" /></label>
                    <label><span>@Localizer["Maximum concurrent sends"]</span><input type="number" min="1" max="100" @bind="ProfileEditor.MaximumConcurrentSends" disabled="@Busy" /></label>
                </div>
            </div>

            @if (ProfileFormError is not null)
            {
                <div class="form-error" role="alert"><RadzenIcon Icon="error_outline" /><span>@ProfileFormError</span></div>
            }
            <div class="editor-actions policy-actions">
                @if (ProfileEditor.Id is not null)
                {
                    <RadzenButton Text='@Localizer["Reload current"]' Icon="history" ButtonStyle="ButtonStyle.Light" Click="@ReloadProfileAsync" Disabled="@Busy" />
                    <RadzenButton Text="@(ProfileEditor.IsEnabled ? "Disable" : "Enable")" Icon="power_settings_new" ButtonStyle="@(ProfileEditor.IsEnabled ? ButtonStyle.Danger : ButtonStyle.Success)" Click="@ToggleProfileAsync" Disabled="@Busy" />
                }
                <span></span>
                <RadzenButton Text='@Localizer["Cancel"]' ButtonStyle="ButtonStyle.Light" Click="@CloseProfileEditor" Disabled="@Busy" />
                <RadzenButton Text='@Localizer["Save profile"]' Icon="save" ButtonStyle="ButtonStyle.Primary" Click="@SaveProfileAsync" Disabled="@Busy" />
            </div>
        </section>
    }
}
else if (SelectedTab == AlertTab.Rules)
{
    <section class="panel workflow-picker" role="tabpanel" aria-label='@Localizer["Workflow alert rules"]'>
        <div class="panel-head"><div><h2>@Localizer["Workflow scope"]</h2><p>@Localizer["Rules subscribe to terminal run events and queue through the same durable Email outbox."]</p></div></div>
        <div class="workflow-filter">
            <label><span>@Localizer["Find workflow"]</span><input maxlength="200" placeholder='@Localizer["Search by workflow name"]' @bind="WorkflowSearch" disabled="@Busy" /></label>
            <RadzenButton Text='@Localizer["Search"]' Icon="search" ButtonStyle="ButtonStyle.Light" Click="@SearchWorkflowsAsync" Disabled="@Busy" />
            <label class="workflow-select"><span>@Localizer["Selected workflow"]</span>
                <select @bind="SelectedWorkflowId" @bind:after="ChangeWorkflowAsync" disabled="@Busy">
                    <option value="">@Localizer["Choose a workflow"]</option>
                    @foreach (var workflow in Workflows)
                    {
                        <option value="@workflow.Id">@workflow.Name · @workflow.Status</option>
                    }
                </select>
            </label>
            <small>@Localizer["Showing up to 100 matches. Search narrows larger catalogs without loading unbounded workflow metadata."]</small>
        </div>
    </section>

    <section class="panel alert-catalog rules-catalog">
        <div class="panel-head">
            <div><h2>@Localizer["Terminal-event rules"]</h2><p>@RuleSummary</p></div>
        </div>
        @if (SelectedWorkflowId is null)
        {
            <div class="page-state compact"><RadzenIcon Icon="account_tree" /><p>@Localizer["Select a workflow to manage its Email rules."]</p></div>
        }
        else if (Rules.Count == 0)
        {
            <div class="page-state compact"><RadzenIcon Icon="notifications_off" /><h3>@Localizer["No rules for this workflow"]</h3><p>@Localizer["Add a rule for failure, success, cancellation, or any supported combination."]</p></div>
        }
        else
        {
            <div class="table-scroll">
                <table class="activity-table alert-table">
                    <thead><tr><th>@Localizer["Rule"]</th><th>@Localizer["Events"]</th><th>@Localizer["Profile"]</th><th>@Localizer["Recipients"]</th><th>@Localizer["Status"]</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var rule in Rules)
                        {
                            <tr class="@(RuleEditor.Id == rule.Id ? "selected" : null)">
                                <td><strong>@rule.Name</strong><small>Updated @rule.UpdatedAtUtc.ToLocalTime().ToString("g")</small></td>
                                <td>@TriggerSummary(rule.Triggers)</td>
                                <td>@ProfileName(rule.EmailDeliveryProfileId)</td>
                                <td>@rule.Recipients.Count</td>
                                <td><span class="status-chip @(rule.IsEnabled ? "" : "draft")">@(rule.IsEnabled ? "Enabled" : "Disabled")</span></td>
                                <td><button class="table-action" type="button" @onclick="() => EditRule(rule)">@Localizer["Manage"]</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    @if (RuleEditorVisible)
    {
        <section class="panel policy-editor" aria-labelledby="rule-editor-title">
            <div class="panel-head">
                <div><h2 id="rule-editor-title">@(RuleEditor.Id is null ? "New workflow rule" : "Edit workflow rule")</h2><p>@Localizer["Templates accept only the documented run metadata variables—never source rows or secrets."]</p></div>
                <button class="icon-close" type="button" aria-label='@Localizer["Close rule editor"]' @onclick="CloseRuleEditor">×</button>
            </div>
            <div class="editor-section">
                <h3>@Localizer["Subscription"]</h3>
                <div class="policy-form">
                    <label><span>@Localizer["Rule name"] <b aria-hidden="true">*</b></span><input maxlength="200" required aria-required="true" @bind="RuleEditor.Name" disabled="@Busy" /></label>
                    <label><span>@Localizer["Delivery profile"] <b aria-hidden="true">*</b></span>
                        <select @bind="RuleEditor.ProfileId" disabled="@Busy">
                            <option value="@Guid.Empty">@Localizer["Choose an enabled profile"]</option>
                            @foreach (var profile in Profiles)
                            {
                                <option value="@profile.Id" disabled="@(!profile.IsEnabled && profile.Id != RuleEditor.ProfileId)">@profile.Name · @(profile.IsEnabled ? "enabled" : "disabled")</option>
                            }
                        </select>
                    </label>
                    <fieldset class="wide trigger-fieldset">
                        <legend>@Localizer["Terminal events"] <b aria-hidden="true">*</b></legend>
                        <label><input type="checkbox" @bind="RuleEditor.RunFailed" disabled="@Busy" /><span>@Localizer["Run failed"]</span></label>
                        <label><input type="checkbox" @bind="RuleEditor.RunSucceeded" disabled="@Busy" /><span>@Localizer["Run succeeded"]</span></label>
                        <label><input type="checkbox" @bind="RuleEditor.RunCancelled" disabled="@Busy" /><span>@Localizer["Run cancelled"]</span></label>
                    </fieldset>
                    <label class="wide"><span>@Localizer["Recipients"] <b aria-hidden="true">*</b></span><textarea rows="3" maxlength="32768" placeholder="ops@example.com&#10;data-owner@example.com" @bind="RuleEditor.RecipientsText" disabled="@Busy"></textarea><small>@Localizer["One address per line. The selected profile checks recipient count and approved domains."]</small></label>
                </div>
            </div>
            <div class="editor-section divided">
                <h3>@Localizer["Bounded template"]</h3>
                <div class="policy-form template-form">
                    <label class="wide"><span>@Localizer["Subject template"] <b aria-hidden="true">*</b></span><input maxlength="998" required aria-required="true" @bind="RuleEditor.SubjectTemplate" disabled="@Busy" /></label>
                    <label class="wide"><span>@Localizer["Plain-text body template"]</span><textarea rows="6" maxlength="1000000" @bind="RuleEditor.BodyTemplate" disabled="@Busy"></textarea></label>
                </div>
                <div class="template-help" aria-label='@Localizer["Allowed Email template variables"]'>
                    <strong>@Localizer["Allowed variables"]</strong>
                    <code>{{workflow.id}}</code><code>{{workflow.name}}</code><code>{{run.id}}</code><code>{{run.status}}</code><code>{{run.triggeredBy}}</code><code>{{run.startedAtUtc}}</code><code>{{run.completedAtUtc}}</code><code>{{error.code}}</code><code>{{error.category}}</code><code>{{error.summary}}</code>
                </div>
            </div>
            @if (SelectedRuleProfile is { } selectedProfile)
            {
                <div class="selected-policy"><RadzenIcon Icon="policy" /><span><strong>@Localizer["{0} policy:", selectedProfile.Name]</strong> @Localizer["{0} recipients, {1} subject characters, {2} body characters.", selectedProfile.Limits.MaximumRecipients, selectedProfile.Limits.MaximumSubjectLength, selectedProfile.Limits.MaximumBodyLength]</span></div>
            }
            @if (RuleFormError is not null)
            {
                <div class="form-error" role="alert"><RadzenIcon Icon="error_outline" /><span>@RuleFormError</span></div>
            }
            <div class="editor-actions policy-actions">
                @if (RuleEditor.Id is not null)
                {
                    <RadzenButton Text='@Localizer["Reload current"]' Icon="history" ButtonStyle="ButtonStyle.Light" Click="@ReloadRuleAsync" Disabled="@Busy" />
                    <RadzenButton Text="@(RuleEditor.IsEnabled ? "Disable" : "Enable")" Icon="power_settings_new" ButtonStyle="@(RuleEditor.IsEnabled ? ButtonStyle.Danger : ButtonStyle.Success)" Click="@ToggleRuleAsync" Disabled="@Busy" />
                }
                <span></span>
                <RadzenButton Text='@Localizer["Cancel"]' ButtonStyle="ButtonStyle.Light" Click="@CloseRuleEditor" Disabled="@Busy" />
                <RadzenButton Text='@Localizer["Save rule"]' Icon="save" ButtonStyle="ButtonStyle.Primary" Click="@SaveRuleAsync" Disabled="@Busy" />
            </div>
        </section>
    }
}
else
{
    <section class="panel alert-catalog" role="tabpanel" aria-label='@Localizer["Email delivery monitor"]'>
        <div class="panel-head">
            <div><h2>@Localizer["Durable delivery monitor"]</h2><p>@Localizer["Safe outbox state and retry outcomes. Message recipients, subjects, and bodies are intentionally not displayed."]</p></div>
        </div>
        <div class="delivery-filter">
            <label><span>@Localizer["Status"]</span>
                <select @bind="DeliveryStatusFilter" disabled="@Busy">
                    <option value="">@Localizer["All statuses"]</option>
                    @foreach (var status in Enum.GetValues<AlertDeliveryStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </label>
            <label><span>@Localizer["Delivery profile"]</span>
                <select @bind="DeliveryProfileFilter" disabled="@Busy">
                    <option value="">@Localizer["All profiles"]</option>
                    @foreach (var profile in Profiles)
                    {
                        <option value="@profile.Id">@profile.Name</option>
                    }
                </select>
            </label>
            <RadzenButton Text='@Localizer["Apply filters"]' Icon="filter_alt" ButtonStyle="ButtonStyle.Light" Click="@ApplyDeliveryFiltersAsync" Disabled="@Busy" />
            <small>@Localizer["{0} matching deliveries; newest 100 are shown.", DeliveryTotal]</small>
        </div>
        @if (Deliveries.Count == 0)
        {
            <div class="page-state compact"><RadzenIcon Icon="mail_outline" /><h3>@Localizer["No matching deliveries"]</h3><p>@Localizer["Delivery rows appear after a terminal workflow rule or Email action queues durable intent."]</p></div>
        }
        else
        {
            <div class="table-scroll">
                <table class="activity-table alert-table delivery-table">
                    <thead><tr><th>@Localizer["Delivery"]</th><th>@Localizer["Source"]</th><th>@Localizer["Profile"]</th><th>@Localizer["Status"]</th><th>@Localizer["Attempts"]</th><th>@Localizer["Timing"]</th><th>@Localizer["Last safe outcome"]</th></tr></thead>
                    <tbody>
                        @foreach (var delivery in Deliveries)
                        {
                            <tr>
                                <td><strong>@ShortId(delivery.Id)</strong><small>Run @ShortId(delivery.WorkflowRunId)@(delivery.WorkflowNodeId is null ? string.Empty : $" · {delivery.WorkflowNodeId}")</small></td>
                                <td>@delivery.Event<small>@delivery.Source</small></td>
                                <td>@delivery.ProfileName</td>
                                <td><span class="status-chip @DeliveryStatusCss(delivery.Status)">@delivery.Status</span></td>
                                <td>@delivery.AttemptCount / @delivery.MaximumAttempts</td>
                                <td>@delivery.CreatedAtUtc.ToLocalTime().ToString("g")<small>@DeliveryTiming(delivery)</small></td>
                                <td>@(delivery.LastErrorCode ?? delivery.ProviderMessageId ?? "—")<small>@(delivery.LastErrorSummary ?? (delivery.CompletedAtUtc is null ? "No terminal outcome" : "Completed"))</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
}

@code {
    private readonly CancellationTokenSource cancellation = new();
    private IReadOnlyList<EmailDeliveryProfileDto> Profiles { get; set; } = [];
    private IReadOnlyList<WorkflowListItemDto> Workflows { get; set; } = [];
    private IReadOnlyList<WorkflowAlertRuleDto> Rules { get; set; } = [];
    private IReadOnlyList<EmailAlertDeliveryListItem> Deliveries { get; set; } = [];
    private int DeliveryTotal { get; set; }
    private AlertDeliveryStatus? DeliveryStatusFilter { get; set; }
    private Guid? DeliveryProfileFilter { get; set; }
    private AlertTab SelectedTab { get; set; }
    private Guid? SelectedWorkflowId { get; set; }
    private string WorkflowSearch { get; set; } = string.Empty;
    private ProfileEditModel ProfileEditor { get; set; } = ProfileEditModel.Create();
    private RuleEditModel RuleEditor { get; set; } = RuleEditModel.Create(Guid.Empty);
    private bool ProfileEditorVisible { get; set; }
    private bool RuleEditorVisible { get; set; }
    private bool Loading { get; set; }
    private bool Busy { get; set; }
    private string? PageError { get; set; }
    private string? ProfileFormError { get; set; }
    private string? RuleFormError { get; set; }

    private EmailDeliveryProfileDto? SelectedRuleProfile =>
        Profiles.SingleOrDefault(profile => profile.Id == RuleEditor.ProfileId);

    private string RuleSummary => SelectedWorkflowId is null
        ? "Choose a workflow to view its alert policy."
        : $"{Rules.Count} configured rule{(Rules.Count == 1 ? string.Empty : "s")}.";

    protected override Task OnInitializedAsync() => RefreshAsync();

    private async Task RefreshAsync()
    {
        Loading = true;
        PageError = null;
        try
        {
            await LoadProfilesAsync();
            await LoadWorkflowOptionsAsync();
            await LoadRulesAsync();
            await LoadDeliveriesAsync();
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            PageError = "Email alert policy is temporarily unavailable.";
        }
        finally
        {
            Loading = false;
        }
    }

    private async Task LoadProfilesAsync()
    {
        var result = await AlertAdministration.ListProfilesAsync(cancellation.Token);
        if (!result.IsSuccess || result.Value is null)
        {
            PageError = result.Problem?.Message ?? "Email delivery profiles could not be loaded.";
            return;
        }

        Profiles = result.Value;
    }

    private async Task LoadWorkflowOptionsAsync()
    {
        var result = await WorkflowCatalog.ListAsync(
            new WorkflowListRequest(0, 100, NullIfWhitespace(WorkflowSearch)),
            cancellation.Token);
        if (!result.IsSuccess || result.Value is null)
        {
            PageError = result.Issues.FirstOrDefault()?.Message ?? "Workflows could not be loaded.";
            Workflows = [];
            return;
        }

        Workflows = result.Value.Items;
        if (SelectedWorkflowId is not null && Workflows.All(workflow => workflow.Id != SelectedWorkflowId))
        {
            SelectedWorkflowId = null;
            Rules = [];
            CloseRuleEditor();
        }
    }

    private async Task SearchWorkflowsAsync()
    {
        Busy = true;
        PageError = null;
        try
        {
            await LoadWorkflowOptionsAsync();
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            PageError = "The workflow catalog is temporarily unavailable.";
        }
        finally
        {
            Busy = false;
        }
    }

    private async Task LoadRulesAsync()
    {
        if (SelectedWorkflowId is not Guid workflowId)
        {
            Rules = [];
            return;
        }

        var result = await AlertAdministration.ListRulesAsync(workflowId, cancellation.Token);
        if (!result.IsSuccess || result.Value is null)
        {
            PageError = result.Problem?.Message ?? "Workflow alert rules could not be loaded.";
            Rules = [];
            return;
        }

        Rules = result.Value;
    }

    private async Task LoadDeliveriesAsync()
    {
        var result = await AlertMonitoring.ListAsync(
            new EmailAlertDeliveryListRequest(
                Limit: 100,
                Status: DeliveryStatusFilter,
                EmailDeliveryProfileId: DeliveryProfileFilter),
            cancellation.Token);
        if (!result.IsSuccess || result.Value is null)
        {
            PageError = result.Problem?.Message ?? "Email deliveries could not be loaded.";
            Deliveries = [];
            DeliveryTotal = 0;
            return;
        }

        Deliveries = result.Value.Items;
        DeliveryTotal = result.Value.TotalCount;
    }

    private async Task ApplyDeliveryFiltersAsync()
    {
        Busy = true;
        PageError = null;
        try
        {
            await LoadDeliveriesAsync();
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            PageError = "Email deliveries are temporarily unavailable.";
        }
        finally
        {
            Busy = false;
        }
    }

    private async Task ChangeWorkflowAsync()
    {
        CloseRuleEditor();
        PageError = null;
        try
        {
            await LoadRulesAsync();
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            PageError = "Workflow alert rules are temporarily unavailable.";
        }
    }

    private void SelectTab(AlertTab tab)
    {
        SelectedTab = tab;
        PageError = null;
    }

    private void NewProfile()
    {
        ProfileEditor = ProfileEditModel.Create();
        ProfileFormError = null;
        ProfileEditorVisible = true;
    }

    private void EditProfile(EmailDeliveryProfileDto profile)
    {
        ProfileEditor = ProfileEditModel.From(profile);

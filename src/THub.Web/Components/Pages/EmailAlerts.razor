    private sealed class ProfileEditModel
    {
        public Guid? Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string SmtpHost { get; set; } = string.Empty;
        public int SmtpPort { get; set; } = 587;
        public EmailTransportSecurity TransportSecurity { get; set; } = EmailTransportSecurity.StartTlsRequired;
        public string SenderAddress { get; set; } = string.Empty;
        public string AllowedDomainsText { get; set; } = string.Empty;
        public string CredentialSecretReference { get; set; } = string.Empty;
        public int MaximumRecipients { get; set; } = EmailDeliveryLimits.Default.MaximumRecipients;
        public int MaximumSubjectLength { get; set; } = EmailDeliveryLimits.Default.MaximumSubjectLength;
        public int MaximumBodyLength { get; set; } = EmailDeliveryLimits.Default.MaximumBodyLength;
        public int MaximumConcurrentSends { get; set; } = EmailDeliveryLimits.Default.MaximumConcurrentSends;
        public bool IsEnabled { get; set; } = true;
        public DateTimeOffset UpdatedAtUtc { get; set; }

        public static ProfileEditModel Create() => new();

        public static ProfileEditModel From(EmailDeliveryProfileDto profile) => new()
        {
            Id = profile.Id,
            Name = profile.Name,
            SmtpHost = profile.SmtpHost,
            SmtpPort = profile.SmtpPort,
            TransportSecurity = profile.TransportSecurity,
            SenderAddress = profile.SenderAddress,
            AllowedDomainsText = string.Join(Environment.NewLine, profile.AllowedRecipientDomains),
            CredentialSecretReference = profile.CredentialSecretReference ?? string.Empty,
            MaximumRecipients = profile.Limits.MaximumRecipients,
            MaximumSubjectLength = profile.Limits.MaximumSubjectLength,
            MaximumBodyLength = profile.Limits.MaximumBodyLength,
            MaximumConcurrentSends = profile.Limits.MaximumConcurrentSends,
            IsEnabled = profile.IsEnabled,
            UpdatedAtUtc = profile.UpdatedAtUtc
        };
    }

    private sealed class RuleEditModel
    {
        public Guid? Id { get; set; }
        public Guid ProfileId { get; set; }
        public string Name { get; set; } = string.Empty;
        public bool RunFailed { get; set; } = true;
        public bool RunSucceeded { get; set; }
        public bool RunCancelled { get; set; }
        public string RecipientsText { get; set; } = string.Empty;
        public string SubjectTemplate { get; set; } = "{{workflow.name}} · {{run.status}}";
        public string BodyTemplate { get; set; } = "Workflow {{workflow.name}} run {{run.id}} completed with status {{run.status}}.\n\n{{error.summary}}";
        public bool IsEnabled { get; set; } = true;
        public DateTimeOffset UpdatedAtUtc { get; set; }

        public WorkflowAlertTriggers Triggers =>
            (RunFailed ? WorkflowAlertTriggers.RunFailed : WorkflowAlertTriggers.None)
            | (RunSucceeded ? WorkflowAlertTriggers.RunSucceeded : WorkflowAlertTriggers.None)
            | (RunCancelled ? WorkflowAlertTriggers.RunCancelled : WorkflowAlertTriggers.None);

        public static RuleEditModel Create(Guid profileId) => new() { ProfileId = profileId };

        public static RuleEditModel From(WorkflowAlertRuleDto rule) => new()
        {
            Id = rule.Id,
            ProfileId = rule.EmailDeliveryProfileId,
            Name = rule.Name,
            RunFailed = rule.Triggers.HasFlag(WorkflowAlertTriggers.RunFailed),
            RunSucceeded = rule.Triggers.HasFlag(WorkflowAlertTriggers.RunSucceeded),
            RunCancelled = rule.Triggers.HasFlag(WorkflowAlertTriggers.RunCancelled),
            RecipientsText = string.Join(Environment.NewLine, rule.Recipients),
            SubjectTemplate = rule.SubjectTemplate,
            BodyTemplate = rule.BodyTemplate,
            IsEnabled = rule.IsEnabled,
            UpdatedAtUtc = rule.UpdatedAtUtc
        };
    }

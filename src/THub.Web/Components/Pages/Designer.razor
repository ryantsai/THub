        {
            variable.DataType = dataType;
            ValidationIssues = [];
        }
    }

    private void SetVariableConnection(
        WorkflowVariableEditor variable,
        ChangeEventArgs eventArgs)
    {
        variable.ConnectionId = Guid.TryParse(
            eventArgs.Value?.ToString(),
            out var connectionId)
            ? connectionId
            : null;
        variable.SchemaMetadata = null;
        variable.Error = null;
        ValidationIssues = [];
    }

    private void SetVariableText(
        WorkflowVariableEditor variable,
        string propertyName,
        ChangeEventArgs eventArgs)
    {
        var value = eventArgs.Value?.ToString() ?? string.Empty;
        if (propertyName == nameof(variable.Schema))
        {
            variable.Schema = value;
        }
        else if (propertyName == nameof(variable.Object))
        {
            variable.Object = value;
        }

        variable.SchemaMetadata = null;
        variable.Error = null;
        ValidationIssues = [];
    }

    private async Task LoadVariableSchemaAsync(WorkflowVariableEditor variable)
    {
        var connection = variable.ConnectionId is { } connectionId
            ? Connections.FirstOrDefault(candidate => candidate.Id == connectionId)
            : null;
        if (connection is null || !IsRelationalConnection(connection.Kind))
        {
            variable.Error = "Select an enabled relational connection first.";
            return;
        }

        SchemaBusy = true;
        variable.Error = null;
        try
        {
            var result = await SchemaInspection.InspectAsync(
                connection.Id,
                connection.Kind,
                variable.Schema,
                variable.Object,
                requireWritableTable: false,
                cancellation.Token);
            if (!result.IsSuccess)
            {
                variable.Error = result.Message;
                return;
            }

            variable.SchemaMetadata = result.Schema;
        }
        finally
        {
            SchemaBusy = false;
        }
    }

    private void AddFunction()

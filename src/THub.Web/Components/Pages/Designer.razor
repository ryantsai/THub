    private string GetEdgePath(DesignerEdge edge)
    {
        var from = Nodes.First(node => node.Id == edge.From);
        var to = Nodes.First(node => node.Id == edge.To);
        var x1 = from.X + 184;
        var y1 = from.Y + 39;
        var x2 = to.X;
        var y2 = to.Y + 39;
        var bend = Math.Max(55, Math.Abs(x2 - x1) / 2);
        return $"M{x1},{y1} C{x1 + bend},{y1} {x2 - bend},{y2} {x2},{y2}";
    }


@page "/designer"
@page "/designer/{WorkflowId:guid}"
@attribute [Authorize]
@implements IDisposable
@using System.Text.Json
@using System.Text.Json.Nodes
@using THub.Application.Alerts
@using THub.Application.Actions
@using THub.Application.Connections
@using THub.Application.Execution
@using THub.Application.Workflows
@using THub.Application.Workflows.Management
@using THub.Domain.Connections
@using THub.Domain.Actions
@using THub.Domain.Security
@using THub.Domain.Workflows
@inject ConnectionManagementService ConnectionService
@inject EmailAlertAdministrationService EmailAdministration
@inject TrustedActionAdministrationService TrustedActionAdministration
@inject WorkflowGraphValidator GraphValidator
@inject WorkflowNodeSettingsValidator NodeSettingsValidator
@inject WorkflowGraphSerializer GraphSerializer
@inject WorkflowCatalogService WorkflowCatalog
@inject WorkflowSchemaInspectionService SchemaInspection
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject AccessControlEvaluator AccessControl

<PageTitle>@Localizer["{0} · THub designer", WorkflowName]</PageTitle>

<div class="designer-heading">
    <div class="designer-breadcrumb">
        <a href="/workflows">@Localizer["Workflows"]</a><span>/</span>
        <input aria-label='@Localizer["Workflow name"]' @bind="WorkflowName" disabled="@Busy" />
    </div>
    <div class="designer-actions">
        <span class="draft-state"><i></i>@StatusText</span>
        <RadzenButton Text='@Localizer["Add step"]' Icon="add" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@ToggleNodeLibrary" Disabled="@Busy" />
        <RadzenButton Text='@Localizer["Workflow settings"]' Icon="tune" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@OpenWorkflowSettings" Disabled="@Busy" />
        <RadzenButton Text='@Localizer["Check workflow"]' Icon="fact_check" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@Validate" Disabled="@Busy" />
        <RadzenButton Text='@Localizer["Save"]' Icon="save" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="@SaveDraftAsync" Disabled="@(Busy || !CanEdit)" />
        <RadzenButton Text='@Localizer["Publish"]' Icon="rocket_launch" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small" Click="@PublishAsync" Disabled="@(Busy || !CanPublish)" />
    </div>
</div>

@if (Loading)
{
    <div class="page-state"><RadzenProgressBar Mode="ProgressBarMode.Indeterminate" /><p>@Localizer["Loading the workflow…"]</p></div>
}
else if (LoadError is not null)
{
    <div class="page-state error"><RadzenIcon Icon="error_outline" /><h3>@Localizer["Workflow unavailable"]</h3><p>@LoadError</p><a href="/workflows">@Localizer["Return to workflows"]</a></div>
}
else
{
    <div class="designer-shell @(NodeLibraryOpen ? "library-open" : null) @((SelectedNode is not null || WorkflowSettingsOpen || ValidationIssues.Count > 0) ? "inspector-open" : null)">
        @if (NodeLibraryOpen)
        {
        <aside class="node-palette" aria-label='@Localizer["Step library"]'>
            <div class="palette-head">
                <div><strong>@Localizer["Add a step"]</strong><small>@Localizer["Choose what should happen next"]</small></div>
                <button type="button" aria-label='@Localizer["Close step library"]' @onclick="ToggleNodeLibrary"><RadzenIcon Icon="close" /></button>
            </div>
            <div class="palette-search"><RadzenIcon Icon="search" /><input aria-label='@Localizer["Find a step"]' placeholder='@Localizer["Find a step…"]' @bind="Search" /></div>
            @foreach (var group in FilteredGroups)
            {
                <section class="palette-group">
                    <h3>@group.Name</h3>
                    @foreach (var tool in group.Tools)
                    {
                        <button class="tool-item" type="button" disabled="@(!tool.IsOperational)" title="@(tool.IsOperational ? tool.Description : "Disabled by administrator policy")" @onclick="() => AddNode(tool)">
                            <span class="tool-icon @tool.Tone"><RadzenIcon Icon="@tool.Icon" /></span>
                            <span><strong>@tool.Name</strong><small>@tool.Description</small></span>
                            <RadzenIcon Icon="@(tool.IsOperational ? "add" : "lock")" />
                        </button>
                    }
                </section>
            }
        </aside>
        }

        <section class="workflow-canvas" @onclick="ClearSelection">
            <div class="canvas-toolbar">
                <button type="button" title='@Localizer["Fit workflow"]' @onclick:stopPropagation @onclick="FitWorkflow"><RadzenIcon Icon="fit_screen" /></button>
                <span></span>
                <small>@Localizer["{0} steps · {1} links", Nodes.Count, Edges.Count]</small>
            </div>

            <svg class="edge-layer" aria-hidden="true">
                @foreach (var edge in Edges)
                {
                    <path d="@GetEdgePath(edge)" />
                }
            </svg>

            @foreach (var node in Nodes)
            {
                <button type="button" class="canvas-node @(SelectedNode == node ? "selected" : "")" style="@GetNodeStyle(node)" @onclick:stopPropagation @onclick="() => SelectNode(node)">
                    <span class="node-port input"></span>
                    <span class="node-icon @node.Tone"><RadzenIcon Icon="@node.Icon" /></span>
                    <span class="node-copy"><strong>@node.Name</strong><small>@node.Subtitle</small></span>
                    <span class="node-menu"><RadzenIcon Icon="more_vert" /></span>
                    <span class="node-state @node.State.ToLowerInvariant()">@node.State</span>
                    <span class="node-port output"></span>
                </button>
            }

            @if (Nodes.Count == 0)
            {
                <div class="canvas-empty">
                    <RadzenIcon Icon="account_tree" />
                    <strong>@Localizer["Start with a source"]</strong>
                    <span>@Localizer["Add a database, local file, or FTP source."]</span>
                    <button type="button" @onclick:stopPropagation @onclick="ToggleNodeLibrary"><RadzenIcon Icon="add" /> @Localizer["Add first step"]</button>
                </div>
            }
        </section>

        @if (SelectedNode is not null || WorkflowSettingsOpen || ValidationIssues.Count > 0)
        {
        <aside class="properties-panel">
            @if (SelectedNode is null && WorkflowSettingsOpen)
            {
            <div class="properties-head"><div><strong>@Localizer["Workflow settings"]</strong><small>@StatusText</small></div></div>
            <div class="properties-body workflow-properties">
                <label>@Localizer["What does this workflow do?"]<textarea rows="2" @bind="Description" disabled="@Busy"></textarea></label>
                <details class="workflow-values">
                    <summary><RadzenIcon Icon="schedule" /> @Localizer["Run automatically (optional)"]</summary>
                    <label>@Localizer["Schedule"]<input placeholder='@Localizer["For example: 0 8 * * 1-5"]' @bind="CronExpression" disabled="@Busy" /><small>@Localizer["Uses a five-part cron schedule. Leave empty to run only when you choose Run now."]</small></label>
                    <label>@Localizer["Time zone"]<input @bind="TimeZoneId" disabled="@Busy" /></label>
                </details>
                <details class="workflow-values">
                    <summary><RadzenIcon Icon="data_object" /> @Localizer["Variables & functions"]</summary>
                    <div class="built-in-values">
                        <strong>@Localizer["Run values"]</strong>
                        <code>@Localizer["runId"]</code><code>@Localizer["runStartedAtUtc"]</code><code>@Localizer["utcToday"]</code>
                    </div>
                    <div class="value-editor-head">
                        <strong>@Localizer["Global variables"]</strong>
                        <button type="button" @onclick="AddVariable"><RadzenIcon Icon="add" /> @Localizer["Add"]</button>
                    </div>
                    @foreach (var variable in Variables)
                    {
                        <div class="value-editor-card">
                            <div class="value-editor-row">
                                <label>@Localizer["Name"]<input value="@variable.Name" @onchange="eventArgs => SetVariableName(variable, eventArgs)" /></label>
                                <label>Source
                                    <select value="@variable.Kind.ToString()" @onchange="eventArgs => SetVariableKind(variable, eventArgs)">
                                        @foreach (var kind in Enum.GetValues<WorkflowVariableKind>())
                                        {
                                            <option value="@kind.ToString()">@kind</option>
                                        }
                                    </select>
                                </label>
                                <button type="button" aria-label="Delete variable @variable.Name" @onclick="() => RemoveVariable(variable)"><RadzenIcon Icon="delete_outline" /></button>
                            </div>
                            <label>Data type
                                <select value="@variable.DataType.ToString()" @onchange="eventArgs => SetVariableDataType(variable, eventArgs)">
                                    @foreach (var dataType in Enum.GetValues<WorkflowValueType>())
                                    {
                                        <option value="@dataType.ToString()">@dataType</option>
                                    }
                                </select>
                            </label>
                            @if (variable.Kind == WorkflowVariableKind.Literal)
                            {
                                <label>@Localizer["Value"]<input value="@variable.Value" @onchange="eventArgs => variable.Value = eventArgs.Value?.ToString() ?? string.Empty" /></label>
                            }
                            else
                            {
                                <label>Approved database connection
                                    <select value="@variable.ConnectionId" @onchange="eventArgs => SetVariableConnection(variable, eventArgs)">
                                        <option value="">@Localizer["Select a relational connection…"]</option>
                                        @foreach (var connection in Connections.Where(connection => connection.IsEnabled && IsRelationalConnection(connection.Kind)))
                                        {
                                            <option value="@connection.Id.ToString("D")">@connection.Name · @ConnectionKindLabel(connection.Kind)</option>
                                        }
                                    </select>
                                </label>
                                <div class="schema-object-fields">
                                    <label>@Localizer["Schema"]<input value="@variable.Schema" @onchange="eventArgs => SetVariableText(variable, nameof(variable.Schema), eventArgs)" /></label>
                                    <label>@Localizer["Table or view"]<input value="@variable.Object" @onchange="eventArgs => SetVariableText(variable, nameof(variable.Object), eventArgs)" /></label>
                                </div>
                                <button class="lookup-schema-button" type="button" disabled="@SchemaBusy" @onclick="() => LoadVariableSchemaAsync(variable)"><RadzenIcon Icon="schema" /> @Localizer["Open lookup schema"]</button>
                                @if (variable.Error is not null)
                                {
                                    <div class="schema-message error" role="alert">@variable.Error</div>
                                }
                                @if (variable.SchemaMetadata is { } lookupSchema)
                                {
                                    <div class="lookup-columns">
                                        <label>Value column
                                            <select value="@variable.ValueColumn" @onchange="eventArgs => variable.ValueColumn = eventArgs.Value?.ToString() ?? string.Empty">
                                                <option value="">@Localizer["Select column…"]</option>
                                                @foreach (var column in lookupSchema.Columns)
                                                {
                                                    <option value="@column.Name">@column.Name · @column.DataType</option>
                                                }
                                            </select>
                                        </label>
                                        <label>Filter column
                                            <select value="@variable.FilterColumn" @onchange="eventArgs => variable.FilterColumn = eventArgs.Value?.ToString() ?? string.Empty">
                                                <option value="">@Localizer["Select column…"]</option>
                                                @foreach (var column in lookupSchema.Columns)
                                                {
                                                    <option value="@column.Name">@column.Name · @column.DataType</option>
                                                }
                                            </select>
                                        </label>
                                    </div>
                                }
                                else
                                {
                                    <div class="lookup-columns">
                                        <label>@Localizer["Value column"]<input value="@variable.ValueColumn" @onchange="eventArgs => variable.ValueColumn = eventArgs.Value?.ToString() ?? string.Empty" /></label>
                                        <label>@Localizer["Filter column"]<input value="@variable.FilterColumn" @onchange="eventArgs => variable.FilterColumn = eventArgs.Value?.ToString() ?? string.Empty" /></label>
                                    </div>
                                }
                                <label>@Localizer["Filter value"]<input value="@variable.FilterValue" @onchange="eventArgs => variable.FilterValue = eventArgs.Value?.ToString() ?? string.Empty" /></label>
                                <small>@Localizer["The lookup must return exactly one scalar row. Object names are quoted and the filter value is parameterized."]</small>
                            }
                        </div>
                    }
                    <div class="value-editor-head">
                        <strong>@Localizer["JavaScript functions"]</strong>
                        <button type="button" @onclick="AddFunction"><RadzenIcon Icon="add" /> @Localizer["Add"]</button>
                    </div>
                    @foreach (var function in Functions)
                    {
                        <div class="value-editor-card">
                            <div class="value-editor-row">
                                <label>@Localizer["Name"]<input value="@function.Name" @onchange="eventArgs => function.Name = eventArgs.Value?.ToString() ?? string.Empty" /></label>
                                <label>@Localizer["Parameters"]<input placeholder='@Localizer["value, prefix"]' value="@function.Parameters" @onchange="eventArgs => function.Parameters = eventArgs.Value?.ToString() ?? string.Empty" /></label>
                                <button type="button" aria-label="Delete function @function.Name" @onclick="() => Functions.Remove(function)"><RadzenIcon Icon="delete_outline" /></button>
                            </div>
                            <label>@Localizer["Return expression"]<input placeholder='@Localizer["String(value).trim()"]' value="@function.Expression" @onchange="eventArgs => function.Expression = eventArgs.Value?.ToString() ?? string.Empty" /></label>
                            <small>@Localizer["Expression-only JavaScript. No CLR, filesystem, network, module, or dynamic code access."]</small>
                        </div>
                    }
                </details>
            </div>
            }

            @if (SelectedNode is not null)
            {
                <div class="properties-head"><div><strong>@SelectedNode.Name</strong><small>@SelectedNode.Kind</small></div><button type="button" @onclick="DeleteSelected" aria-label='@Localizer["Delete node"]'><RadzenIcon Icon="delete_outline" /></button></div>
                <div class="properties-body">
                    <label>@Localizer["Step name"]<input @bind="SelectedNode.Name" /></label>
                    @if (ExpectedConnectionKind(SelectedNode.Kind) is { } connectionKind)
                    {
                        <label>Approved connection
                            <select value="@(GetSettingString(SelectedNode, "connectionId"))" @onchange="SetSelectedConnection">
                                <option value="">Select a @ConnectionKindLabel(connectionKind) connection…</option>
                                @foreach (var connection in Connections.Where(connection => connection.IsEnabled && connection.Kind == connectionKind))
                                {
                                    <option value="@connection.Id.ToString("D")">@connection.Name</option>
                                }
                            </select>
                        </label>
                    }
                    @if (SelectedNode.Kind == WorkflowNodeKind.EmailAlert)
                    {
                        <label>Email delivery profile
                            <select value="@(GetSettingString(SelectedNode, "profileId"))" @onchange="SetSelectedEmailProfile">
                                <option value="">@Localizer["Select an enabled profile…"]</option>
                                @foreach (var profile in EmailProfiles.Where(profile => profile.IsEnabled))
                                {
                                    <option value="@profile.Id.ToString("D")">@profile.Name · @profile.SenderAddress</option>
                                }
                            </select>
                        </label>
                    }
                    @if (SelectedNode.Kind is WorkflowNodeKind.Webhook or WorkflowNodeKind.Executable)
                    {
                        var trustedKind = SelectedNode.Kind == WorkflowNodeKind.Webhook
                            ? TrustedActionKind.Webhook
                            : TrustedActionKind.Executable;
                        <label>Trusted action
                            <select value="@(GetSettingString(SelectedNode, "trustedActionId"))" @onchange="SetSelectedTrustedAction">
                                <option value="">@Localizer["Select an authorized action…"]</option>
                                @foreach (var action in TrustedActions.Where(action => action.Kind == trustedKind && action.IsEnabled))
                                {
                                    <option value="@action.Id.ToString("D")">@action.Name</option>
                                }
                            </select>
                        </label>
                    }
                    @if (SelectedNode.Kind == WorkflowNodeKind.Join)
                    {
                        <div class="join-input-summary"><span>@Localizer["Left input"]</span><code>@(GetSettingString(SelectedNode, "leftNodeId") ?? "Not connected")</code><span>@Localizer["Right input"]</span><code>@(GetSettingString(SelectedNode, "rightNodeId") ?? "Not connected")</code></div>
                    }
                    @if (IsRelationalNode(SelectedNode.Kind))
                    {
                        <section class="schema-designer" aria-label='@Localizer["Database object schema"]'>
                            <div class="schema-object-fields">
                                <label>Schema
                                    <input value="@(GetSettingString(SelectedNode, "schema"))" @onchange="SetSchema" />
                                </label>
                                <label>Table or view
                                    <input value="@(GetSettingString(SelectedNode, "object"))" @onchange="SetObject" />
                                </label>
                            </div>
                            @if (IsSource(SelectedNode.Kind))
                            {
                                <label>Batch rows
                                    <input type="number" min="1" max="10000" value="@GetSettingInt(SelectedNode, "batchSize", 1000)" @onchange="SetBatchSize" />
                                </label>
                            }
                            else
                            {
                                <label>Write mode
                                    <select aria-label='@Localizer["Database target write mode"]' value="@GetTargetMode(SelectedNode)" @onchange="SetTargetMode">
                                        <option value="insert">@Localizer["Insert"]</option>
                                        <option value="upsert" disabled="@(!CanTargetUpsert)">@Localizer["Upsert by primary key"]</option>
                                        <option value="delete" disabled="@(!CanTargetDelete)">@Localizer["Delete incoming keys"]</option>
                                    </select>
                                </label>
                            }
                            <div class="schema-actions">
                                <button type="button" @onclick="LoadSelectedSchemaAsync" disabled="@SchemaBusy"><RadzenIcon Icon="schema" /> @(SchemaBusy ? "Loading…" : "Open schema")</button>
                                @if (IsRelationalTarget(SelectedNode.Kind))
                                {
                                    <button type="button" @onclick="LoadMappingSchemasAsync" disabled="@SchemaBusy"><RadzenIcon Icon="account_tree" /> @Localizer["Load source + target"]</button>
                                }
                            </div>
                            @if (SchemaError is not null)
                            {
                                <div class="schema-message error" role="alert"><RadzenIcon Icon="error_outline" />@SchemaError</div>
                            }
                            @if (GetLoadedSchema(SelectedNode) is { } selectedSchema)
                            {
                                <div class="schema-browser">
                                    <div class="schema-browser-head">
                                        <div><strong>@selectedSchema.Schema.@selectedSchema.ObjectName</strong><span>@selectedSchema.Columns.Count columns</span></div>
                                        <span class="schema-status">@Localizer["Live metadata"]</span>
                                    </div>
                                    @if (IsSource(SelectedNode.Kind))
                                    {
                                        <div class="schema-column-list" aria-label='@Localizer["Source columns"]'>
                                            @foreach (var column in selectedSchema.Columns)
                                            {
                                                <label class="schema-column">
                                                    <input type="checkbox" checked="@IsSourceColumnSelected(SelectedNode, column.Name)" @onchange="eventArgs => ToggleSourceColumn(column.Name, eventArgs)" />
                                                    <span class="column-name">@column.Name</span>
                                                    <code>@column.SourceTypeName</code>
                                                    <small>@(column.IsNullable ? "nullable" : "required")</small>
                                                </label>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="schema-column-list" aria-label='@Localizer["Target columns"]'>
                                            @foreach (var column in selectedSchema.Columns)
                                            {
                                                <div class="schema-column @(column.IsWritable ? null : "locked")">
                                                    <RadzenIcon Icon="@(column.IsKey ? "key" : column.IsWritable ? "radio_button_unchecked" : "lock")" />
                                                    <span class="column-name">@column.Name</span>
                                                    <code>@column.SourceTypeName</code>
                                                    <small>@(column.IsKey ? "primary key" : column.IsWritable ? column.IsNullable ? "nullable" : "required" : "generated")</small>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            @if (IsRelationalTarget(SelectedNode.Kind) &&
                                GetLoadedSchema(SelectedNode) is { } targetSchema &&
                                GetMappingSourceNode(SelectedNode) is { } sourceNode &&
                                GetLoadedSchema(sourceNode) is { } sourceSchema)
                            {
                                <div class="mapping-designer" aria-label='@Localizer["Column mappings"]'>
                                    <div class="mapping-head">
                                        <div><strong>@Localizer["Column mappings"]</strong><span>@sourceNode.Name → @SelectedNode.Name</span></div>
                                        <div>
                                            <button type="button" @onclick="AutoMapColumns"><RadzenIcon Icon="auto_fix_high" /> @Localizer["Match names"]</button>
                                            <button type="button" @onclick="ClearMappings"><RadzenIcon Icon="clear_all" /> @Localizer["Clear"]</button>
                                        </div>
                                    </div>
                                    <div class="mapping-labels"><span>@Localizer["Destination"]</span><span>@Localizer["Value source"]</span><span>@Localizer["Value"]</span></div>
                                    @foreach (var targetColumn in GetMappableTargetColumns(SelectedNode, targetSchema))
                                    {
                                        var binding = GetBinding(SelectedNode, targetColumn.Name);
                                        <div class="mapping-row @(binding is null ? "unmapped" : "mapped")">
                                            <div class="mapping-column"><strong>@targetColumn.Name</strong><small>@targetColumn.DataType</small></div>
                                            <select aria-label="Value source for @targetColumn.Name" value="@(binding?.Kind.ToString() ?? string.Empty)" @onchange="eventArgs => SetBindingKind(targetColumn.Name, eventArgs)">
                                                <option value="">@Localizer["Not mapped"]</option>
                                                <option value="@WorkflowValueBindingKind.Column">@Localizer["Source column"]</option>
                                                <option value="@WorkflowValueBindingKind.Variable">@Localizer["Variable"]</option>
                                                <option value="@WorkflowValueBindingKind.JavaScript">@Localizer["JavaScript"]</option>
                                            </select>
                                            @if (binding?.Kind == WorkflowValueBindingKind.Column)
                                            {
                                                <select aria-label="Source column for @targetColumn.Name" value="@binding.Value" @onchange="eventArgs => SetBindingValue(targetColumn.Name, eventArgs)">
                                                    <option value="">@Localizer["Select column…"]</option>
                                                    @foreach (var sourceColumn in GetMappingSourceColumns(SelectedNode, sourceNode, sourceSchema))
                                                    {
                                                        <option value="@sourceColumn.Name">@sourceColumn.Name · @sourceColumn.DataType</option>
                                                    }
                                                </select>
                                            }
                                            else if (binding?.Kind == WorkflowValueBindingKind.Variable)
                                            {
                                                <select aria-label="Variable for @targetColumn.Name" value="@binding.Value" @onchange="eventArgs => SetBindingValue(targetColumn.Name, eventArgs)">
                                                    <option value="">@Localizer["Select variable…"]</option>
                                                    @foreach (var variableName in AvailableVariableNames)
                                                    {
                                                        <option value="@variableName">@variableName</option>
                                                    }
                                                </select>
                                            }
                                            else if (binding?.Kind == WorkflowValueBindingKind.JavaScript)
                                            {
                                                <input aria-label="JavaScript expression for @targetColumn.Name" placeholder="slug(row.Name)" value="@binding.Value" @onchange="eventArgs => SetBindingValue(targetColumn.Name, eventArgs)" />
                                            }
                                            else
                                            {
                                                <span class="mapping-empty">@Localizer["Uses target default"]</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </section>
                        <details class="advanced-settings">
                            <summary><RadzenIcon Icon="data_object" /> @Localizer["Advanced settings JSON"]</summary>
                            <label>@Localizer["Settings JSON"]<textarea class="settings-json" rows="11" spellcheck="false" @bind="SelectedNode.SettingsJson"></textarea></label>
                            <button class="format-settings" type="button" @onclick="FormatSelectedSettings"><RadzenIcon Icon="data_object" /> @Localizer["Format JSON"]</button>
                        </details>
                    }
                    else
                    {
                        <label>@Localizer["Settings JSON"]<textarea class="settings-json" rows="11" spellcheck="false" @bind="SelectedNode.SettingsJson"></textarea></label>
                        <button class="format-settings" type="button" @onclick="FormatSelectedSettings"><RadzenIcon Icon="data_object" /> @Localizer["Format JSON"]</button>
                    }
                    <small class="property-help">@Localizer["Settings are validated again at publication and execution boundaries. Connections and database objects must reference approved metadata."]</small>
                    @if (DependencyWarning is not null)
                    {
                        <small class="property-help warning">@DependencyWarning Raw JSON editing remains available.</small>
                    }

                    @if (!IsSource(SelectedNode.Kind))
                    {
                        <div class="property-section"><span>@Localizer["Incoming links"]</span></div>
                        <div class="link-editor">
                            <select aria-label='@Localizer["Connect from step"]' @bind="ConnectFromNodeId">
                                <option value="">@Localizer["Select upstream step…"]</option>
                                @foreach (var candidate in Nodes.Where(candidate => candidate != SelectedNode))
                                {
                                    <option value="@candidate.Id">@candidate.Name</option>
                                }
                            </select>
                            <button type="button" @onclick="ConnectSelected"><RadzenIcon Icon="add_link" /> @Localizer["Add"]</button>
                            @foreach (var edge in IncomingEdges)
                            {
                                <div class="link-row"><span>@NodeName(edge.From)</span><button type="button" aria-label="Remove link from @NodeName(edge.From)" @onclick="() => RemoveEdge(edge)"><RadzenIcon Icon="close" /></button></div>
                            }
                        </div>
                    }
                </div>
            }

            @if (ValidationIssues.Count > 0)
            {
                <div class="validation-panel" role="status">
                    <strong>@Localizer["{0} validation issues", ValidationIssues.Count]</strong>
                    @foreach (var issue in ValidationIssues.Take(8))
                    {
                        <button type="button" @onclick="() => SelectIssue(issue)"><span>@issue.Code</span>@issue.Message</button>
                    }
                </div>
            }
        </aside>
        }
    </div>
}

@code {
    [Parameter] public Guid? WorkflowId { get; set; }

    private readonly CancellationTokenSource cancellation = new();
    private string WorkflowName { get; set; } = "Untitled workflow";
    private string Description { get; set; } = string.Empty;
    private string Owner { get; set; } = string.Empty;
    private string? CronExpression { get; set; }
    private string TimeZoneId { get; set; } = TimeZoneInfo.Local.Id;
    private int DraftRevision { get; set; }
    private WorkflowStatus CurrentStatus { get; set; } = WorkflowStatus.Draft;
    private string Search { get; set; } = string.Empty;
    private string ConnectFromNodeId { get; set; } = string.Empty;
    private DesignerNode? SelectedNode { get; set; }
    private bool NodeLibraryOpen { get; set; }
    private bool WorkflowSettingsOpen { get; set; }
    private bool Busy { get; set; }
    private bool Loading { get; set; }
    private string? LoadError { get; set; }
    private System.Security.Claims.ClaimsPrincipal? CurrentUser { get; set; }
    private bool CanEdit { get; set; }

@page "/designer"
@page "/designer/{WorkflowId:guid}"
@attribute [Authorize(Policy = Permissions.WorkflowEdit)]
@implements IDisposable
@using System.Text.Json
@using System.Text.Json.Nodes
@using THub.Application.Alerts
@using THub.Application.Connections
@using THub.Application.Execution
@using THub.Application.Workflows
@using THub.Application.Workflows.Management
@using THub.Domain.Connections
@using THub.Domain.Workflows
@inject ConnectionManagementService ConnectionService
@inject EmailAlertAdministrationService EmailAdministration
@inject WorkflowGraphValidator GraphValidator
@inject WorkflowNodeSettingsValidator NodeSettingsValidator
@inject WorkflowGraphSerializer GraphSerializer
@inject WorkflowCatalogService WorkflowCatalog
@inject WorkflowSchemaInspectionService SchemaInspection
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NotificationService Notifications
@inject NavigationManager Navigation

<PageTitle>@WorkflowName · THub designer</PageTitle>

<div class="designer-heading">
    <div class="designer-breadcrumb">
        <a href="/workflows">Workflows</a><span>/</span>
        <input aria-label="Workflow name" @bind="WorkflowName" disabled="@Busy" />
    </div>
    <div class="designer-actions">
        <span class="draft-state"><i></i>@StatusText</span>
        <RadzenButton Text="Validate" Icon="fact_check" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@Validate" Disabled="@Busy" />
        <RadzenButton Text="Save draft" Icon="save" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="@SaveDraftAsync" Disabled="@Busy" />
        <RadzenButton Text="Publish" Icon="rocket_launch" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small" Click="@PublishAsync" Disabled="@Busy" />
    </div>
</div>

@if (Loading)
{
    <div class="page-state"><RadzenProgressBar Mode="ProgressBarMode.Indeterminate" /><p>Loading the workflow…</p></div>
}
else if (LoadError is not null)
{
    <div class="page-state error"><RadzenIcon Icon="error_outline" /><h3>Workflow unavailable</h3><p>@LoadError</p><a href="/workflows">Return to workflows</a></div>
}
else
{
    <div class="designer-shell">
        <aside class="node-palette">
            <div class="palette-head"><strong>Toolbox</strong><small>Click to add a step</small></div>
            <div class="palette-search"><RadzenIcon Icon="search" /><input placeholder="Find a tool…" @bind="Search" /></div>
            @foreach (var group in FilteredGroups)
            {
                <section class="palette-group">
                    <h3>@group.Name</h3>
                    @foreach (var tool in group.Tools)
                    {
                        <button class="tool-item" type="button" disabled="@(!tool.IsOperational)" title="@(tool.IsOperational ? tool.Description : "Disabled by administrator policy")" @onclick="() => AddNode(tool)">
                            <span class="tool-icon @tool.Tone"><RadzenIcon Icon="@tool.Icon" /></span>
                            <span><strong>@tool.Name</strong><small>@tool.Description</small></span>
                            <RadzenIcon Icon="@(tool.IsOperational ? "add" : "lock")" />
                        </button>
                    }
                </section>
            }
        </aside>

        <section class="workflow-canvas" @onclick="ClearSelection">
            <div class="canvas-toolbar">
                <button type="button" title="Fit workflow" @onclick:stopPropagation @onclick="FitWorkflow"><RadzenIcon Icon="fit_screen" /></button>
                <span></span>
                <small>@Nodes.Count steps · @Edges.Count links</small>
            </div>

            <svg class="edge-layer" aria-hidden="true">
                @foreach (var edge in Edges)
                {
                    <path d="@GetEdgePath(edge)" />
                }
            </svg>

            @foreach (var node in Nodes)
            {
                <button type="button" class="canvas-node @(SelectedNode == node ? "selected" : "")" style="@GetNodeStyle(node)" @onclick:stopPropagation @onclick="() => SelectNode(node)">
                    <span class="node-port input"></span>
                    <span class="node-icon @node.Tone"><RadzenIcon Icon="@node.Icon" /></span>
                    <span class="node-copy"><strong>@node.Name</strong><small>@node.Subtitle</small></span>
                    <span class="node-menu"><RadzenIcon Icon="more_vert" /></span>
                    <span class="node-state @node.State.ToLowerInvariant()">@node.State</span>
                    <span class="node-port output"></span>
                </button>
            }

            @if (Nodes.Count == 0)
            {
                <div class="canvas-empty"><RadzenIcon Icon="account_tree" /><strong>Start with a source</strong><span>Add a database, local file, or FTP source from the toolbox.</span></div>
            }
            <div class="canvas-hint"><RadzenIcon Icon="lightbulb" /><span>Steps are persisted as versioned JSON. Publishing freezes an immutable graph for every run.</span></div>
        </section>

        <aside class="properties-panel">
            <div class="properties-head"><div><strong>Workflow</strong><small>@StatusText</small></div></div>
            <div class="properties-body workflow-properties">
                <label>Description<textarea rows="2" @bind="Description" disabled="@Busy"></textarea></label>
                <label>Five-field cron<input placeholder="Manual (leave empty)" @bind="CronExpression" disabled="@Busy" /></label>
                <label>Time zone<input @bind="TimeZoneId" disabled="@Busy" /></label>
            </div>

            @if (SelectedNode is null)
            {
                <div class="empty-properties">
                    <span><RadzenIcon Icon="tune" /></span>
                    <h3>Nothing selected</h3>
                                <p>Select a step to configure its data operation and incoming links.</p>
                </div>
            }
            else
            {
                <div class="properties-head"><div><strong>@SelectedNode.Name</strong><small>@SelectedNode.Kind</small></div><button type="button" @onclick="DeleteSelected" aria-label="Delete node"><RadzenIcon Icon="delete_outline" /></button></div>
                <div class="properties-body">
                    <label>Step name<input @bind="SelectedNode.Name" /></label>
                    @if (ExpectedConnectionKind(SelectedNode.Kind) is { } connectionKind)
                    {
                        <label>Approved connection
                            <select value="@(GetSettingString(SelectedNode, "connectionId"))" @onchange="SetSelectedConnection">
                                <option value="">Select a @ConnectionKindLabel(connectionKind) connection…</option>
                                @foreach (var connection in Connections.Where(connection => connection.IsEnabled && connection.Kind == connectionKind))
                                {
                                    <option value="@connection.Id.ToString("D")">@connection.Name</option>
                                }
                            </select>
                        </label>
                    }
                    @if (SelectedNode.Kind == WorkflowNodeKind.EmailAlert)
                    {
                        <label>Email delivery profile
                            <select value="@(GetSettingString(SelectedNode, "profileId"))" @onchange="SetSelectedEmailProfile">
                                <option value="">Select an enabled profile…</option>
                                @foreach (var profile in EmailProfiles.Where(profile => profile.IsEnabled))
                                {
                                    <option value="@profile.Id.ToString("D")">@profile.Name · @profile.SenderAddress</option>
                                }
                            </select>
                        </label>
                    }
                    @if (SelectedNode.Kind == WorkflowNodeKind.Join)
                    {
                        <div class="join-input-summary"><span>Left input</span><code>@(GetSettingString(SelectedNode, "leftNodeId") ?? "Not connected")</code><span>Right input</span><code>@(GetSettingString(SelectedNode, "rightNodeId") ?? "Not connected")</code></div>
                    }
                    @if (IsRelationalNode(SelectedNode.Kind))
                    {
                        <section class="schema-designer" aria-label="Database object schema">
                            <div class="schema-object-fields">
                                <label>Schema
                                    <input value="@(GetSettingString(SelectedNode, "schema"))" @onchange="SetSchema" />
                                </label>
                                <label>Table or view
                                    <input value="@(GetSettingString(SelectedNode, "object"))" @onchange="SetObject" />
                                </label>
                            </div>
                            @if (IsSource(SelectedNode.Kind))
                            {
                                <label>Batch rows
                                    <input type="number" min="1" max="10000" value="@GetSettingInt(SelectedNode, "batchSize", 1000)" @onchange="SetBatchSize" />
                                </label>
                            }
                            <div class="schema-actions">
                                <button type="button" @onclick="LoadSelectedSchemaAsync" disabled="@SchemaBusy"><RadzenIcon Icon="schema" /> @(SchemaBusy ? "Loading…" : "Open schema")</button>
                                @if (IsRelationalTarget(SelectedNode.Kind))
                                {
                                    <button type="button" @onclick="LoadMappingSchemasAsync" disabled="@SchemaBusy"><RadzenIcon Icon="account_tree" /> Load source + target</button>
                                }
                            </div>
                            @if (SchemaError is not null)
                            {
                                <div class="schema-message error" role="alert"><RadzenIcon Icon="error_outline" />@SchemaError</div>
                            }
                            @if (GetLoadedSchema(SelectedNode) is { } selectedSchema)
                            {
                                <div class="schema-browser">
                                    <div class="schema-browser-head">
                                        <div><strong>@selectedSchema.Schema.@selectedSchema.ObjectName</strong><span>@selectedSchema.Columns.Count columns</span></div>
                                        <span class="schema-status">Live metadata</span>
                                    </div>
                                    @if (IsSource(SelectedNode.Kind))
                                    {
                                        <div class="schema-column-list" aria-label="Source columns">
                                            @foreach (var column in selectedSchema.Columns)
                                            {
                                                <label class="schema-column">
                                                    <input type="checkbox" checked="@IsSourceColumnSelected(SelectedNode, column.Name)" @onchange="eventArgs => ToggleSourceColumn(column.Name, eventArgs)" />
                                                    <span class="column-name">@column.Name</span>
                                                    <code>@column.SourceTypeName</code>
                                                    <small>@(column.IsNullable ? "nullable" : "required")</small>
                                                </label>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="schema-column-list" aria-label="Target columns">
                                            @foreach (var column in selectedSchema.Columns)
                                            {
                                                <div class="schema-column @(column.IsWritable ? null : "locked")">
                                                    <RadzenIcon Icon="@(column.IsWritable ? "radio_button_unchecked" : "lock")" />
                                                    <span class="column-name">@column.Name</span>
                                                    <code>@column.SourceTypeName</code>
                                                    <small>@(column.IsWritable ? column.IsNullable ? "nullable" : "required" : "generated")</small>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            @if (IsRelationalTarget(SelectedNode.Kind) &&
                                GetLoadedSchema(SelectedNode) is { } targetSchema &&
                                GetMappingSourceNode(SelectedNode) is { } sourceNode &&
                                GetLoadedSchema(sourceNode) is { } sourceSchema)
                            {
                                <div class="mapping-designer" aria-label="Column mappings">
                                    <div class="mapping-head">
                                        <div><strong>Column mappings</strong><span>@sourceNode.Name → @SelectedNode.Name</span></div>
                                        <div>
                                            <button type="button" @onclick="AutoMapColumns"><RadzenIcon Icon="auto_fix_high" /> Match names</button>
                                            <button type="button" @onclick="ClearMappings"><RadzenIcon Icon="clear_all" /> Clear</button>
                                        </div>
                                    </div>
                                    <div class="mapping-labels"><span>Source column</span><span></span><span>Destination column</span></div>
                                    @foreach (var sourceColumn in GetMappingSourceColumns(SelectedNode, sourceNode, sourceSchema))
                                    {
                                        <div class="mapping-row @(string.IsNullOrEmpty(GetMappedTarget(SelectedNode, sourceColumn.Name)) ? "unmapped" : "mapped")">
                                            <div class="mapping-column"><strong>@sourceColumn.Name</strong><small>@sourceColumn.DataType</small></div>
                                            <span class="mapping-arrow"><RadzenIcon Icon="east" /></span>
                                            <select aria-label="Map @sourceColumn.Name" value="@GetMappedTarget(SelectedNode, sourceColumn.Name)" @onchange="eventArgs => SetColumnMapping(sourceColumn.Name, eventArgs)">
                                                <option value="">Not mapped</option>
                                                @foreach (var targetColumn in targetSchema.Columns.Where(column => column.IsWritable))
                                                {
                                                    <option value="@targetColumn.Name">@targetColumn.Name · @targetColumn.DataType</option>
                                                }
                                            </select>
                                        </div>
                                    }
                                </div>
                            }
                        </section>
                        <details class="advanced-settings">
                            <summary><RadzenIcon Icon="data_object" /> Advanced settings JSON</summary>
                            <label>Settings JSON<textarea class="settings-json" rows="11" spellcheck="false" @bind="SelectedNode.SettingsJson"></textarea></label>
                            <button class="format-settings" type="button" @onclick="FormatSelectedSettings"><RadzenIcon Icon="data_object" /> Format JSON</button>
                        </details>
                    }
                    else
                    {
                        <label>Settings JSON<textarea class="settings-json" rows="11" spellcheck="false" @bind="SelectedNode.SettingsJson"></textarea></label>
                        <button class="format-settings" type="button" @onclick="FormatSelectedSettings"><RadzenIcon Icon="data_object" /> Format JSON</button>
                    }
                    <small class="property-help">Settings are validated again at publication and execution boundaries. Connections and database objects must reference approved metadata.</small>
                    @if (DependencyWarning is not null)
                    {
                        <small class="property-help warning">@DependencyWarning Raw JSON editing remains available.</small>
                    }

                    @if (!IsSource(SelectedNode.Kind))
                    {
                        <div class="property-section"><span>Incoming links</span></div>
                        <div class="link-editor">
                            <select aria-label="Connect from step" @bind="ConnectFromNodeId">
                                <option value="">Select upstream step…</option>
                                @foreach (var candidate in Nodes.Where(candidate => candidate != SelectedNode))
                                {
                                    <option value="@candidate.Id">@candidate.Name</option>
                                }
                            </select>
                            <button type="button" @onclick="ConnectSelected"><RadzenIcon Icon="add_link" /> Add</button>
                            @foreach (var edge in IncomingEdges)
                            {
                                <div class="link-row"><span>@NodeName(edge.From)</span><button type="button" aria-label="Remove link from @NodeName(edge.From)" @onclick="() => RemoveEdge(edge)"><RadzenIcon Icon="close" /></button></div>
                            }
                        </div>
                    }
                </div>
            }

            @if (ValidationIssues.Count > 0)
            {
                <div class="validation-panel" role="status">
                    <strong>@ValidationIssues.Count validation issue@(ValidationIssues.Count == 1 ? "" : "s")</strong>
                    @foreach (var issue in ValidationIssues.Take(8))
                    {
                        <button type="button" @onclick="() => SelectIssue(issue)"><span>@issue.Code</span>@issue.Message</button>
                    }
                </div>
            }
        </aside>
    </div>
}

@code {
    [Parameter] public Guid? WorkflowId { get; set; }

    private readonly CancellationTokenSource cancellation = new();
    private string WorkflowName { get; set; } = "Untitled workflow";
    private string Description { get; set; } = string.Empty;
    private string Owner { get; set; } = string.Empty;
    private string? CronExpression { get; set; }
    private string TimeZoneId { get; set; } = TimeZoneInfo.Local.Id;
    private int DraftRevision { get; set; }
    private WorkflowStatus CurrentStatus { get; set; } = WorkflowStatus.Draft;
    private string Search { get; set; } = string.Empty;
    private string ConnectFromNodeId { get; set; } = string.Empty;
    private DesignerNode? SelectedNode { get; set; }
    private bool Busy { get; set; }
    private bool Loading { get; set; }
    private string? LoadError { get; set; }
    private IReadOnlyList<GraphValidationIssue> ValidationIssues { get; set; } = [];
    private IReadOnlyList<ConnectionSummary> Connections { get; set; } = [];
    private IReadOnlyList<EmailDeliveryProfileDto> EmailProfiles { get; set; } = [];
    private string? DependencyWarning { get; set; }
    private bool SchemaBusy { get; set; }
    private string? SchemaError { get; set; }
    private readonly Dictionary<string, WorkflowObjectSchemaDto> LoadedSchemas =
        new(StringComparer.OrdinalIgnoreCase);
    private readonly List<DesignerNode> Nodes = [];
    private readonly List<DesignerEdge> Edges = [];

    private string StatusText => WorkflowId is null
        ? "Unsaved draft"
        : $"{CurrentStatus} · revision {DraftRevision}";

    private IEnumerable<DesignerEdge> IncomingEdges => SelectedNode is null
        ? []
        : Edges.Where(edge => edge.To == SelectedNode.Id).ToArray();

    private static readonly PaletteGroup[] Groups =
    [
        new("Sources", [
            new("SQL Server", "Read an approved table", WorkflowNodeKind.SqlSource, "database", "blue", true),
            new("MySQL", "Read an approved table or view", WorkflowNodeKind.MySqlSource, "database", "blue", true),
            new("PostgreSQL", "Read an approved table or view", WorkflowNodeKind.PostgreSqlSource, "database", "blue", true),
            new("Oracle", "Read an approved table or view", WorkflowNodeKind.OracleSource, "database", "blue", true),
            new("FTP file", "Read CSV, tab text, or Excel", WorkflowNodeKind.FtpSource, "cloud_download", "green", true),
            new("CSV file", "Read a bounded local CSV", WorkflowNodeKind.CsvSource, "description", "green", true),
            new("Excel workbook", "Read XLSX or XLSM", WorkflowNodeKind.ExcelSource, "grid_on", "green", true)]),
        new("Transform", [
            new("Select & map", "Rename and cast columns", WorkflowNodeKind.SelectColumns, "schema", "violet", true),
            new("Filter rows", "Apply typed conditions", WorkflowNodeKind.FilterRows, "filter_alt", "amber", true),
            new("Join", "Combine exactly two streams", WorkflowNodeKind.Join, "join_inner", "violet", true)]),
        new("Destinations", [
            new("SQL target", "Insert into an approved table", WorkflowNodeKind.SqlTarget, "storage", "blue", true),
            new("MySQL target", "Insert into an approved table", WorkflowNodeKind.MySqlTarget, "storage", "blue", true),
            new("PostgreSQL target", "Insert into an approved table", WorkflowNodeKind.PostgreSqlTarget, "storage", "blue", true),
            new("Oracle target", "Insert into an approved table", WorkflowNodeKind.OracleTarget, "storage", "blue", true),
            new("FTP target", "Create CSV, tab text, or Excel", WorkflowNodeKind.FtpTarget, "cloud_upload", "green", true),
            new("CSV target", "Write beneath an approved root", WorkflowNodeKind.CsvTarget, "description", "green", true),
            new("Excel target", "Write an XLSX workbook", WorkflowNodeKind.ExcelTarget, "grid_on", "green", true)]),
        new("Actions", [
            new("Email alert", "Queue a durable Email message", WorkflowNodeKind.EmailAlert, "mail", "rose", true),
            new("Webhook", "Disabled until allow-list policy exists", WorkflowNodeKind.Webhook, "webhook", "rose", false),
            new("Executable", "Disabled until sandbox policy exists", WorkflowNodeKind.Executable, "terminal", "slate", false)])
    ];

    private IEnumerable<PaletteGroup> FilteredGroups => string.IsNullOrWhiteSpace(Search)
        ? Groups
        : Groups.Select(group => new PaletteGroup(group.Name, group.Tools
            .Where(tool => tool.Name.Contains(Search, StringComparison.OrdinalIgnoreCase)).ToArray()))
            .Where(group => group.Tools.Length > 0);

    protected override async Task OnInitializedAsync()
    {
        var authentication = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        Owner = authentication.User.Identity?.Name ?? "unknown";
        try
        {
            var connectionsTask = ConnectionService.ListAsync(cancellation.Token);
            var profilesTask = EmailAdministration.ListProfilesAsync(cancellation.Token);
            await Task.WhenAll(connectionsTask, profilesTask);
            Connections = await connectionsTask;
            var profiles = await profilesTask;
            if (profiles.IsSuccess && profiles.Value is not null)
            {
                EmailProfiles = profiles.Value;
            }
            else
            {
                DependencyWarning = "Email profiles could not be listed.";
            }
        }
        catch (Exception) when (!cancellation.IsCancellationRequested)
        {
            DependencyWarning = "Approved connection/profile selectors are temporarily unavailable.";
        }
        if (WorkflowId is null)
        {
            return;
        }

        Loading = true;
        try
        {
            var result = await WorkflowCatalog.LoadAsync(WorkflowId.Value, cancellation.Token);
            if (!result.IsSuccess)
            {
                LoadError = string.Join(" ", result.Issues.Select(issue => issue.Message));
                return;
            }

            ApplyDetails(result.Value!);
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            LoadError = "The workflow could not be loaded from the control-plane database.";
        }
        finally
        {
            Loading = false;
        }
    }

    private void ApplyDetails(WorkflowDetailsDto details)
    {
        WorkflowId = details.Id;
        WorkflowName = details.Name;
        Description = details.Description;
        Owner = details.Owner;
        CronExpression = details.CronExpression;
        TimeZoneId = details.TimeZoneId;
        DraftRevision = details.DraftRevision;
        CurrentStatus = details.Status;
        Nodes.Clear();
        Edges.Clear();
        var graph = GraphSerializer.Deserialize(details.GraphJson);
        Nodes.AddRange(graph.Nodes.Select(node => new DesignerNode(
            node.Id,
            node.Kind,
            node.Name,
            SubtitleFor(node.Kind),
            IconFor(node.Kind),
            ToneFor(node.Kind),
            "Saved",
            node.X,
            node.Y,
            node.SettingsJson)));
        Edges.AddRange(graph.Edges.Select(edge => new DesignerEdge(edge.FromNodeId, edge.ToNodeId)));
    }

    private void AddNode(PaletteTool tool)
    {
        if (!tool.IsOperational)
        {
            return;
        }

        var previous = Nodes.LastOrDefault();
        var id = $"{tool.Kind.ToString().ToLowerInvariant()}-{Guid.NewGuid():N}"[..Math.Min(48, tool.Kind.ToString().Length + 33)];
        var x = previous is null ? 80 : Math.Min(previous.X + 255, 845);
        var y = previous is null || x > previous.X ? previous?.Y ?? 135 : previous.Y + 195;
        var node = new DesignerNode(
            id,
            tool.Kind,
            tool.Name,
            SubtitleFor(tool.Kind),
            tool.Icon,
            tool.Tone,
            "Draft",
            x,
            y,
            DefaultSettings(tool.Kind));
        Nodes.Add(node);
        if (previous is not null && !IsSource(tool.Kind))
        {
            Edges.Add(new(previous.Id, node.Id));
        }
        SelectedNode = node;
        ValidationIssues = [];
    }

    private void SelectNode(DesignerNode node)
    {
        SelectedNode = node;
        ConnectFromNodeId = string.Empty;
        SchemaError = null;
    }

    private void ClearSelection() => SelectedNode = null;

    private void DeleteSelected()
    {
        if (SelectedNode is null)
        {
            return;
        }
        Nodes.Remove(SelectedNode);
        Edges.RemoveAll(edge => edge.From == SelectedNode.Id || edge.To == SelectedNode.Id);
        LoadedSchemas.Remove(SelectedNode.Id);
        SelectedNode = null;
        ValidationIssues = [];
    }

    private void ConnectSelected()
    {
        if (SelectedNode is null || string.IsNullOrWhiteSpace(ConnectFromNodeId))
        {
            return;
        }
        if (!Edges.Any(edge => edge.From == ConnectFromNodeId && edge.To == SelectedNode.Id))
        {
            Edges.Add(new(ConnectFromNodeId, SelectedNode.Id));
            SynchronizeJoinInputs();
        }
        ConnectFromNodeId = string.Empty;
    }

    private void RemoveEdge(DesignerEdge edge)
    {
        Edges.Remove(edge);
        SynchronizeJoinInputs();
    }

    private void SynchronizeJoinInputs()
    {
        if (SelectedNode?.Kind != WorkflowNodeKind.Join)
        {
            return;
        }

        var inputs = Edges
            .Where(edge => edge.To == SelectedNode.Id)
            .Select(edge => edge.From)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(2)
            .ToArray();
        SetSettingString(SelectedNode, "leftNodeId", inputs.ElementAtOrDefault(0));
        SetSettingString(SelectedNode, "rightNodeId", inputs.ElementAtOrDefault(1));
    }

    private void FormatSelectedSettings()
    {
        if (SelectedNode is null)
        {
            return;
        }

        try
        {
            var node = JsonNode.Parse(SelectedNode.SettingsJson, documentOptions: new JsonDocumentOptions
            {
                AllowTrailingCommas = false,
                CommentHandling = JsonCommentHandling.Disallow,
                MaxDepth = 32
            });
            if (node is not JsonObject)
            {
                throw new JsonException("Settings must be an object.");
            }
            SelectedNode.SettingsJson = node.ToJsonString(new JsonSerializerOptions { WriteIndented = true });
        }
        catch (JsonException exception)
        {
            Notifications.Notify(NotificationSeverity.Error, "Settings JSON is invalid", exception.Message);
        }
    }

    private static string? GetSettingString(DesignerNode node, string propertyName)
    {
        try
        {
            using var document = JsonDocument.Parse(node.SettingsJson);
            return document.RootElement.TryGetProperty(propertyName, out var value) && value.ValueKind == JsonValueKind.String
                ? value.GetString()
                : null;
        }
        catch (JsonException)
        {
            return null;
        }
    }

    private void SetSettingString(DesignerNode node, string propertyName, string? value)
    {
        try
        {
            var settings = JsonNode.Parse(node.SettingsJson) as JsonObject ?? new JsonObject();
            settings[propertyName] = value ?? string.Empty;
            node.SettingsJson = settings.ToJsonString();
            ValidationIssues = [];
        }
        catch (JsonException)
        {
            Notifications.Notify(
                NotificationSeverity.Error,
                "Settings JSON is invalid",
                "Repair the JSON object before using a governed selector.");
        }
    }

    private void SetSelectedConnection(ChangeEventArgs eventArgs)
    {
        if (SelectedNode is not null)
        {
            SetSettingString(SelectedNode, "connectionId", eventArgs.Value?.ToString());
            LoadedSchemas.Remove(SelectedNode.Id);
            if (IsRelationalTarget(SelectedNode.Kind))
            {
                ClearMappings();
            }
            SchemaError = null;
        }
    }

    private void SetSchema(ChangeEventArgs eventArgs) =>
        SetRelationalSetting("schema", eventArgs);

    private void SetObject(ChangeEventArgs eventArgs) =>
        SetRelationalSetting("object", eventArgs);

    private void SetRelationalSetting(string propertyName, ChangeEventArgs eventArgs)
    {
        if (SelectedNode is null)
        {
            return;
        }

        SetSettingString(SelectedNode, propertyName, eventArgs.Value?.ToString());
        LoadedSchemas.Remove(SelectedNode.Id);
        if (IsRelationalTarget(SelectedNode.Kind))
        {
            ClearMappings();
        }
        SchemaError = null;
    }

    private void SetBatchSize(ChangeEventArgs eventArgs)
    {
        if (SelectedNode is null ||
            !int.TryParse(
                eventArgs.Value?.ToString(),
                System.Globalization.NumberStyles.Integer,
                System.Globalization.CultureInfo.InvariantCulture,
                out var value))
        {
            return;
        }

        SetSettingInt(SelectedNode, "batchSize", Math.Clamp(value, 1, 10_000));
    }

    private async Task LoadSelectedSchemaAsync()
    {
        if (SelectedNode is null)
        {
            return;
        }

        SchemaBusy = true;
        SchemaError = null;
        try
        {
            _ = await LoadNodeSchemaAsync(SelectedNode);
        }
        finally
        {
            SchemaBusy = false;
        }
    }

    private async Task LoadMappingSchemasAsync()
    {
        if (SelectedNode is null || !IsRelationalTarget(SelectedNode.Kind))
        {
            return;
        }

        SchemaBusy = true;
        SchemaError = null;
        try
        {
            var targetLoaded = await LoadNodeSchemaAsync(SelectedNode);
            var sourceNode = GetMappingSourceNode(SelectedNode);
            if (sourceNode is null)
            {
                SchemaError = "Connect one relational source through optional select/filter steps before opening the mapper.";
                return;
            }

            var sourceLoaded = await LoadNodeSchemaAsync(sourceNode);
            if (targetLoaded && sourceLoaded && GetMappings(SelectedNode).Count == 0)
            {
                AutoMapColumns();
            }
        }
        finally
        {
            SchemaBusy = false;
        }
    }

    private async Task<bool> LoadNodeSchemaAsync(DesignerNode node)
    {
        if (ExpectedConnectionKind(node.Kind) is not { } kind ||
            !IsRelationalConnection(kind) ||
            !Guid.TryParse(GetSettingString(node, "connectionId"), out var connectionId))
        {
            SchemaError = $"Select an enabled {ConnectionKindLabel(ExpectedConnectionKind(node.Kind) ?? ConnectionKind.SqlServer)} connection first.";
            return false;
        }

        var result = await SchemaInspection.InspectAsync(
            connectionId,
            kind,
            GetSettingString(node, "schema") ?? string.Empty,
            GetSettingString(node, "object") ?? string.Empty,
            IsRelationalTarget(node.Kind),
            cancellation.Token);
        if (!result.IsSuccess)
        {
            SchemaError = $"{node.Name}: {result.Message}";
            return false;
        }

        LoadedSchemas[node.Id] = result.Schema!;
        return true;
    }

    private WorkflowObjectSchemaDto? GetLoadedSchema(DesignerNode node) =>
        LoadedSchemas.GetValueOrDefault(node.Id);

    private DesignerNode? GetMappingSourceNode(DesignerNode target)
    {
        var current = target;
        var visited = new HashSet<string>(StringComparer.OrdinalIgnoreCase) { target.Id };
        while (visited.Count <= Nodes.Count)
        {
            var incoming = Edges
                .Where(edge => string.Equals(edge.To, current.Id, StringComparison.OrdinalIgnoreCase))
                .Select(edge => edge.From)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToArray();
            if (incoming.Length != 1)
            {
                return null;
            }

            current = Nodes.FirstOrDefault(node =>
                string.Equals(node.Id, incoming[0], StringComparison.OrdinalIgnoreCase));
            if (current is null || !visited.Add(current.Id))
            {
                return null;
            }

            if (IsSource(current.Kind))
            {
                return IsRelationalNode(current.Kind) ? current : null;
            }

            if (current.Kind is not (WorkflowNodeKind.SelectColumns or WorkflowNodeKind.FilterRows))
            {
                return null;
            }
        }

        return null;
    }

    private IReadOnlyList<WorkflowSchemaColumnDto> GetEffectiveSourceColumns(
        DesignerNode sourceNode,
        WorkflowObjectSchemaDto sourceSchema)
    {
        var selected = GetSettingStringArray(sourceNode, "columns");
        return selected is null
            ? sourceSchema.Columns
            : sourceSchema.Columns
                .Where(column => selected.Contains(column.Name, StringComparer.OrdinalIgnoreCase))
                .ToArray();
    }

    private IReadOnlyList<WorkflowSchemaColumnDto> GetMappingSourceColumns(
        DesignerNode target,
        DesignerNode sourceNode,
        WorkflowObjectSchemaDto sourceSchema)
    {
        IReadOnlyList<WorkflowSchemaColumnDto> columns =
            GetEffectiveSourceColumns(sourceNode, sourceSchema);
        var current = target;
        var visited = new HashSet<string>(StringComparer.OrdinalIgnoreCase) { target.Id };
        while (!string.Equals(current.Id, sourceNode.Id, StringComparison.OrdinalIgnoreCase))
        {
            var incoming = Edges
                .Where(edge => string.Equals(edge.To, current.Id, StringComparison.OrdinalIgnoreCase))
                .Select(edge => edge.From)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToArray();
            if (incoming.Length != 1)
            {
                return [];
            }

            current = Nodes.First(node =>
                string.Equals(node.Id, incoming[0], StringComparison.OrdinalIgnoreCase));
            if (!visited.Add(current.Id))
            {
                return [];
            }

            if (current.Kind == WorkflowNodeKind.SelectColumns)
            {
                var selected = GetSettingStringArray(current, "columns") ?? [];
                columns = columns
                    .Where(column => selected.Contains(column.Name, StringComparer.OrdinalIgnoreCase))
                    .ToArray();
            }
        }

        return columns;
    }

    private bool IsSourceColumnSelected(DesignerNode node, string columnName)
    {
        var selected = GetSettingStringArray(node, "columns");
        return selected is null || selected.Contains(columnName, StringComparer.OrdinalIgnoreCase);
    }

    private void ToggleSourceColumn(string columnName, ChangeEventArgs eventArgs)
    {
        if (SelectedNode is null || GetLoadedSchema(SelectedNode) is not { } schema)
        {
            return;
        }

        var isSelected = eventArgs.Value is true ||
            string.Equals(eventArgs.Value?.ToString(), "true", StringComparison.OrdinalIgnoreCase);
        var selected = GetSettingStringArray(SelectedNode, "columns")?.ToList()
            ?? schema.Columns.Select(column => column.Name).ToList();
        selected.RemoveAll(name => string.Equals(name, columnName, StringComparison.OrdinalIgnoreCase));
        if (isSelected)
        {
            var ordinal = schema.Columns
                .Select((column, index) => (column, index))
                .First(item => string.Equals(item.column.Name, columnName, StringComparison.OrdinalIgnoreCase))
                .index;
            selected.Insert(Math.Min(ordinal, selected.Count), columnName);
        }

        SetSettingStringArray(SelectedNode, "columns", selected);
    }

    private string? GetMappedTarget(DesignerNode node, string sourceColumn) =>
        GetMappings(node).GetValueOrDefault(sourceColumn);

    private void SetColumnMapping(string sourceColumn, ChangeEventArgs eventArgs)
    {
        if (SelectedNode is null)
        {
            return;
        }

        var targetColumn = eventArgs.Value?.ToString();
        var settings = ParseSettings(SelectedNode);
        var mappings = settings["mappings"] as JsonObject ?? new JsonObject();
        settings["mappings"] = mappings;
        _ = mappings.Remove(sourceColumn);
        if (!string.IsNullOrWhiteSpace(targetColumn))
        {
            foreach (var duplicate in mappings
                         .Where(mapping =>
                             mapping.Value is JsonValue jsonValue &&
                             jsonValue.TryGetValue<string>(out var existingTarget) &&
                             string.Equals(
                                 existingTarget,
                                 targetColumn,
                                 StringComparison.OrdinalIgnoreCase))
                         .Select(mapping => mapping.Key)
                         .ToArray())
            {
                _ = mappings.Remove(duplicate);
            }
            mappings[sourceColumn] = targetColumn;
        }

        SelectedNode.SettingsJson = settings.ToJsonString();
        ValidationIssues = [];
    }

    private void AutoMapColumns()
    {
        if (SelectedNode is null ||
            GetLoadedSchema(SelectedNode) is not { } targetSchema ||
            GetMappingSourceNode(SelectedNode) is not { } sourceNode ||
            GetLoadedSchema(sourceNode) is not { } sourceSchema)
        {
            return;
        }

        var writableTargets = targetSchema.Columns
            .Where(column => column.IsWritable)
            .ToDictionary(column => column.Name, StringComparer.OrdinalIgnoreCase);
        var settings = ParseSettings(SelectedNode);
        var mappings = new JsonObject();
        foreach (var source in GetMappingSourceColumns(SelectedNode, sourceNode, sourceSchema))
        {
            if (writableTargets.TryGetValue(source.Name, out var target) &&
                source.DataType == target.DataType)
            {
                mappings[source.Name] = target.Name;
            }
        }

        settings["mappings"] = mappings;
        SelectedNode.SettingsJson = settings.ToJsonString();
        ValidationIssues = [];
    }

    private void ClearMappings()
    {
        if (SelectedNode is null)
        {
            return;
        }

        var settings = ParseSettings(SelectedNode);
        settings["mappings"] = new JsonObject();
        SelectedNode.SettingsJson = settings.ToJsonString();
        ValidationIssues = [];
    }

    private static IReadOnlyDictionary<string, string> GetMappings(DesignerNode node)
    {
        try
        {
            using var document = JsonDocument.Parse(node.SettingsJson);
            if (!document.RootElement.TryGetProperty("mappings", out var mappings) ||
                mappings.ValueKind != JsonValueKind.Object)
            {
                return new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            }

            return mappings.EnumerateObject()
                .Where(property => property.Value.ValueKind == JsonValueKind.String)
                .ToDictionary(
                    property => property.Name,
                    property => property.Value.GetString() ?? string.Empty,
                    StringComparer.OrdinalIgnoreCase);
        }
        catch (JsonException)
        {
            return new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        }
    }

    private static IReadOnlyList<string>? GetSettingStringArray(
        DesignerNode node,
        string propertyName)
    {
        try
        {
            using var document = JsonDocument.Parse(node.SettingsJson);
            if (!document.RootElement.TryGetProperty(propertyName, out var value))
            {
                return null;
            }

            return value.ValueKind == JsonValueKind.Array
                ? value.EnumerateArray()
                    .Where(item => item.ValueKind == JsonValueKind.String)
                    .Select(item => item.GetString() ?? string.Empty)
                    .ToArray()
                : null;
        }
        catch (JsonException)
        {
            return null;
        }
    }

    private static int GetSettingInt(
        DesignerNode node,
        string propertyName,
        int defaultValue)
    {
        try
        {
            using var document = JsonDocument.Parse(node.SettingsJson);
            return document.RootElement.TryGetProperty(propertyName, out var value) &&
                   value.TryGetInt32(out var parsed)
                ? parsed
                : defaultValue;
        }
        catch (JsonException)
        {
            return defaultValue;
        }
    }

    private static JsonObject ParseSettings(DesignerNode node)
    {
        try
        {
            return JsonNode.Parse(node.SettingsJson) as JsonObject ?? new JsonObject();
        }
        catch (JsonException)
        {
            return new JsonObject();
        }
    }

    private void SetSettingInt(DesignerNode node, string propertyName, int value)
    {
        var settings = ParseSettings(node);
        settings[propertyName] = value;
        node.SettingsJson = settings.ToJsonString();
        ValidationIssues = [];
    }

    private void SetSettingStringArray(
        DesignerNode node,
        string propertyName,
        IReadOnlyList<string> values)
    {
        var settings = ParseSettings(node);
        settings[propertyName] = new JsonArray(
            values.Select(value => JsonValue.Create(value)).ToArray<JsonNode?>());
        node.SettingsJson = settings.ToJsonString();
        ValidationIssues = [];
    }


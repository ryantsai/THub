    protected override async Task OnInitializedAsync()
    {
        var authentication = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        CurrentUser = authentication.User;
        Owner = authentication.User.Identity?.Name ?? "unknown";
        CurrentRoleIds = await AccessControl.ResolveRoleIdsAsync(
            authentication.User,
            cancellation.Token);
        if (WorkflowId is null)
        {
            CanEdit = await AccessControl.HasPermissionAsync(
                authentication.User,
                Permissions.WorkflowCreate,
                cancellationToken: cancellation.Token);
            CanPublish = CanEdit && await AccessControl.HasPermissionAsync(
                authentication.User,
                Permissions.WorkflowPublish,
                cancellationToken: cancellation.Token);
            CanTargetUpsert = await AccessControl.HasPermissionAsync(
                authentication.User,
                Permissions.WorkflowTargetUpsert,
                cancellationToken: cancellation.Token);
            CanTargetDelete = await AccessControl.HasPermissionAsync(
                authentication.User,
                Permissions.WorkflowTargetDelete,
                cancellationToken: cancellation.Token);
        }
        else
        {
            CanEdit = await AccessControl.HasPermissionAsync(
                authentication.User,
                Permissions.WorkflowEdit,
                AccessResourceKind.Workflow,
                WorkflowId.Value,
                cancellation.Token);
            CanPublish = await AccessControl.HasPermissionAsync(
                authentication.User,
                Permissions.WorkflowPublish,
                AccessResourceKind.Workflow,
                WorkflowId.Value,
                cancellation.Token);
            CanTargetUpsert = await AccessControl.HasPermissionAsync(
                authentication.User,
                Permissions.WorkflowTargetUpsert,
                AccessResourceKind.Workflow,
                WorkflowId.Value,
                cancellation.Token);
            CanTargetDelete = await AccessControl.HasPermissionAsync(
                authentication.User,
                Permissions.WorkflowTargetDelete,
                AccessResourceKind.Workflow,
                WorkflowId.Value,
                cancellation.Token);
        }

        if (!CanEdit)
        {
            LoadError = "You do not have permission to edit this workflow.";
            return;
        }

        try
        {
            var connectionsTask = ConnectionService.ListAsync(cancellation.Token);
            var profilesTask = EmailAdministration.ListProfilesAsync(cancellation.Token);
            var trustedActionsTask = TrustedActionAdministration.ListAvailableAsync(
                CurrentRoleIds,
                cancellation.Token);
            await Task.WhenAll(connectionsTask, profilesTask, trustedActionsTask);
            var connections = await connectionsTask;
            var visibleConnections = new List<ConnectionSummary>(connections.Count);
            foreach (var connection in connections)
            {
                if (await AccessControl.HasPermissionAsync(
                        CurrentUser,
                        Permissions.ConnectionView,
                        AccessResourceKind.Connection,
                        connection.Id,
                        cancellation.Token))
                {
                    visibleConnections.Add(connection);
                }
            }

            Connections = visibleConnections;
            var profiles = await profilesTask;
            if (profiles.IsSuccess && profiles.Value is not null)
            {
                EmailProfiles = profiles.Value;
            }
            else
            {
                DependencyWarning = "Email profiles could not be listed.";
            }
            TrustedActions = await trustedActionsTask;
        }
        catch (Exception) when (!cancellation.IsCancellationRequested)
        {
            DependencyWarning = "Approved connection/profile selectors are temporarily unavailable.";
        }
        if (WorkflowId is null)
        {
            return;
        }

        Loading = true;
        try
        {
            var result = await WorkflowCatalog.LoadAsync(WorkflowId.Value, cancellation.Token);
            if (!result.IsSuccess)
            {
                LoadError = string.Join(" ", result.Issues.Select(issue => issue.Message));
                return;
            }

            ApplyDetails(result.Value!);
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            LoadError = "THub could not load this workflow. Try again or return to the workflow list.";
        }
        finally
        {
            Loading = false;
        }
    }

    private void ApplyDetails(WorkflowDetailsDto details)
    {
        WorkflowId = details.Id;
        WorkflowName = details.Name;
        Description = details.Description;
        Owner = details.Owner;
        CronExpression = details.CronExpression;
        TimeZoneId = details.TimeZoneId;
        DraftRevision = details.DraftRevision;
        CurrentStatus = details.Status;
        Nodes.Clear();
        Edges.Clear();
        Variables.Clear();
        Functions.Clear();
        var graph = GraphSerializer.Deserialize(details.GraphJson);
        Nodes.AddRange(graph.Nodes.Select(node => new DesignerNode(
            node.Id,
            node.Kind,
            node.Name,
            SubtitleFor(node.Kind),
            IconFor(node.Kind),
            ToneFor(node.Kind),
            "Saved",
            node.X,
            node.Y,
            node.SettingsJson)));
        Edges.AddRange(graph.Edges.Select(edge => new DesignerEdge(edge.FromNodeId, edge.ToNodeId)));
        Variables.AddRange(graph.Variables.Select(variable => new WorkflowVariableEditor(variable)));
        Functions.AddRange(graph.Functions.Select(function => new WorkflowFunctionEditor(function)));
    }

    private void AddVariable()
    {
        var ordinal = Variables.Count + 1;
        var name = $"variable{ordinal}";
        while (Variables.Any(variable =>
                   string.Equals(variable.Name, name, StringComparison.OrdinalIgnoreCase)))
        {
            name = $"variable{++ordinal}";
        }

        Variables.Add(new WorkflowVariableEditor
        {
            Name = name,
            Kind = WorkflowVariableKind.Literal,
            DataType = WorkflowValueType.String,
            Value = string.Empty
        });
        ValidationIssues = [];
    }

    private void RemoveVariable(WorkflowVariableEditor variable)
    {
        _ = Variables.Remove(variable);
        ValidationIssues = [];
    }

    private void SetVariableName(
        WorkflowVariableEditor variable,
        ChangeEventArgs eventArgs)
    {
        variable.Name = eventArgs.Value?.ToString() ?? string.Empty;
        ValidationIssues = [];
    }

    private void SetVariableKind(
        WorkflowVariableEditor variable,
        ChangeEventArgs eventArgs)
    {
        if (Enum.TryParse<WorkflowVariableKind>(
                eventArgs.Value?.ToString(),
                out var kind))
        {
            variable.Kind = kind;
            variable.Error = null;
            variable.SchemaMetadata = null;
            ValidationIssues = [];
        }
    }

    private void SetVariableDataType(
        WorkflowVariableEditor variable,

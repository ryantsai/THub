    private static ConnectionKind? ExpectedConnectionKind(WorkflowNodeKind kind) => kind switch
    {
        WorkflowNodeKind.SqlSource or WorkflowNodeKind.SqlTarget => ConnectionKind.SqlServer,
        WorkflowNodeKind.MySqlSource or WorkflowNodeKind.MySqlTarget => ConnectionKind.MySql,
        WorkflowNodeKind.PostgreSqlSource or WorkflowNodeKind.PostgreSqlTarget => ConnectionKind.PostgreSql,
        WorkflowNodeKind.OracleSource or WorkflowNodeKind.OracleTarget => ConnectionKind.Oracle,
        WorkflowNodeKind.FtpSource or WorkflowNodeKind.FtpTarget => ConnectionKind.Ftp,
        WorkflowNodeKind.CsvSource or WorkflowNodeKind.CsvTarget => ConnectionKind.CsvFile,
        WorkflowNodeKind.ExcelSource or WorkflowNodeKind.ExcelTarget => ConnectionKind.ExcelFile,
        _ => null
    };

    private static string ConnectionKindLabel(ConnectionKind kind) => kind switch
    {
        ConnectionKind.SqlServer => "SQL Server",
        ConnectionKind.CsvFile => "CSV",
        ConnectionKind.ExcelFile => "Excel",
        _ => kind.ToString()
    };

    private void Validate()
    {
        var graph = BuildGraph();
        ValidationIssues = GraphValidator.Validate(graph)
            .Concat(NodeSettingsValidator.Validate(graph))
            .GroupBy(issue => (issue.Code, issue.NodeId, issue.Message))
            .Select(group => group.First())
            .ToArray();
        Notifications.Notify(
            ValidationIssues.Count == 0 ? NotificationSeverity.Success : NotificationSeverity.Warning,
            ValidationIssues.Count == 0 ? "Workflow is valid" : "Validation needs attention",
            ValidationIssues.Count == 0
                ? $"{Nodes.Count} steps and {Edges.Count} links are ready to publish."
                : ValidationIssues[0].Message);
    }

    private async Task SaveDraftAsync()
    {
        Busy = true;
        try
        {
            var graphJson = GraphSerializer.Serialize(BuildGraph());
            WorkflowOperationResult<WorkflowDetailsDto> result;
            if (WorkflowId is null)
            {
                result = await WorkflowCatalog.CreateAsync(
                    new CreateWorkflowCommand(
                        WorkflowName,
                        Description,
                        Owner,
                        graphJson,
                        NormalizeCron(),
                        TimeZoneId),
                    cancellation.Token);
            }
            else
            {
                result = await WorkflowCatalog.SaveAsync(
                    new SaveWorkflowCommand(
                        WorkflowId.Value,
                        DraftRevision,
                        WorkflowName,
                        Description,
                        Owner,
                        graphJson,
                        NormalizeCron(),
                        TimeZoneId),
                    cancellation.Token);
            }

            if (!result.IsSuccess)
            {
                NotifyIssues("Draft was not saved", result.Issues);
                return;
            }

            var wasNew = WorkflowId is null;
            ApplyDetails(result.Value!);
            Notifications.Notify(NotificationSeverity.Success, "Draft saved", $"Revision {DraftRevision} is durable.");
            if (wasNew)
            {
                Navigation.NavigateTo($"/designer/{WorkflowId}", replace: true);
            }
        }
        catch (WorkflowGraphSerializationException exception)
        {
            Notifications.Notify(NotificationSeverity.Error, "Graph could not be serialized", exception.Message);
        }
        finally
        {
            Busy = false;
        }
    }

    private async Task PublishAsync()
    {
        if (WorkflowId is null)
        {
            await SaveDraftAsync();
            if (WorkflowId is null)
            {
                return;
            }
        }

        Busy = true;
        try
        {
            var result = await WorkflowCatalog.PublishAsync(
                new PublishWorkflowCommand(WorkflowId.Value, DraftRevision, Owner),
                cancellation.Token);
            if (!result.IsSuccess)
            {
                NotifyIssues("Workflow was not published", result.Issues);
                return;
            }

            ApplyDetails(result.Value!.Workflow);
            ValidationIssues = [];
            Notifications.Notify(
                NotificationSeverity.Success,
                result.Value.CreatedNewVersion ? "Workflow published" : "Workflow resumed",
                $"Immutable version {result.Value.Version.Version} is active.");
        }
        finally
        {
            Busy = false;
        }
    }

    private void NotifyIssues(string title, IReadOnlyList<WorkflowIssue> issues)
    {
        Notifications.Notify(
            NotificationSeverity.Error,
            title,
            issues.Count == 0 ? "The operation failed." : string.Join(" ", issues.Take(3).Select(issue => issue.Message)));
    }

    private void SelectIssue(GraphValidationIssue issue)
    {
        if (issue.NodeId is not null)
        {
            SelectedNode = Nodes.FirstOrDefault(node =>
                string.Equals(node.Id, issue.NodeId, StringComparison.OrdinalIgnoreCase));
        }
    }

    private WorkflowGraph BuildGraph() => new(
        Nodes.Select(node => new WorkflowNode(
            node.Id,
            node.Kind,
            node.Name,
            node.X,
            node.Y,
            node.SettingsJson)).ToArray(),
        Edges.Select(edge => new WorkflowEdge(edge.From, edge.To)).ToArray());

    private string? NormalizeCron() => string.IsNullOrWhiteSpace(CronExpression)
        ? null
        : CronExpression.Trim();

    private void FitWorkflow()
    {
        var index = 0;
        foreach (var node in Nodes)
        {
            node.X = 80 + (index % 4) * 255;
            node.Y = 135 + (index / 4) * 195;
            index++;
        }
    }

    private string NodeName(string id) =>
        Nodes.FirstOrDefault(node => node.Id == id)?.Name ?? id;

    private static bool IsSource(WorkflowNodeKind kind) => kind is
        WorkflowNodeKind.SqlSource or WorkflowNodeKind.MySqlSource
            or WorkflowNodeKind.PostgreSqlSource or WorkflowNodeKind.OracleSource
            or WorkflowNodeKind.FtpSource or WorkflowNodeKind.CsvSource
            or WorkflowNodeKind.ExcelSource;

    private static bool IsRelationalNode(WorkflowNodeKind kind) => kind is
        WorkflowNodeKind.SqlSource or WorkflowNodeKind.MySqlSource
            or WorkflowNodeKind.PostgreSqlSource or WorkflowNodeKind.OracleSource
            or WorkflowNodeKind.SqlTarget or WorkflowNodeKind.MySqlTarget
            or WorkflowNodeKind.PostgreSqlTarget or WorkflowNodeKind.OracleTarget;

    private static bool IsRelationalTarget(WorkflowNodeKind kind) =>
        IsRelationalNode(kind) && !IsSource(kind);

    private static bool IsRelationalConnection(ConnectionKind kind) => kind is
        ConnectionKind.SqlServer or ConnectionKind.MySql
            or ConnectionKind.PostgreSql or ConnectionKind.Oracle;

